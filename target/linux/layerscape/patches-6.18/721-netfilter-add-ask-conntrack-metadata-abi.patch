+#if defined(CONFIG_INET_IPSEC_OFFLOAD) || defined(CONFIG_INET6_IPSEC_OFFLOAD)
+static bool
+nf_ct_set_layerscape_xfrm_handles(struct comcerto_fp_info *fp_info,
+				  struct xfrm_state *xfrm[],
+				  int num_xfrm, int xfrm_dir)
+{
+	int base = xfrm_dir == XFRM_POLICY_OUT ?
+		MAX_SUPPORTED_XFRMS_PER_DIR : 0;
+	bool changed = false;
+	int i;
+
+	if (num_xfrm > MAX_SUPPORTED_XFRMS_PER_DIR)
+		num_xfrm = MAX_SUPPORTED_XFRMS_PER_DIR;
+
+	for (i = 0; i < MAX_SUPPORTED_XFRMS_PER_DIR; i++) {
+		u16 handle = 0;
+
+		if (i < num_xfrm && xfrm[i])
+			handle = xfrm[i]->handle;
+		if (fp_info->xfrm_handle[base + i] == handle)
+			continue;
+
+		fp_info->xfrm_handle[base + i] = handle;
+		changed = true;
+	}
+
+	return changed;
+}
+
+bool nf_ct_update_layerscape_xfrm_in(struct nf_conn *ct,
+				     enum ip_conntrack_info ctinfo,
+				     const struct sk_buff *skb,
+				     const struct nf_hook_state *state)
+{
+	struct comcerto_fp_info *fp_info = &ct->fp_info[CTINFO2DIR(ctinfo)];
+	struct xfrm_state *xfrm[MAX_SUPPORTED_XFRMS_PER_DIR] = {};
+	struct sec_path *sp;
+	int num_xfrm = 0;
+	int i;
+
+	if (state && state->hook == NF_INET_LOCAL_OUT)
+		return false;
+
+	sp = skb_sec_path(skb);
+	if (sp && sp->len) {
+		for (i = sp->len - 1;
+		     i >= 0 && num_xfrm < MAX_SUPPORTED_XFRMS_PER_DIR;
+		     i--)
+			xfrm[num_xfrm++] = sp->xvec[i];
+	}
+
+	return nf_ct_set_layerscape_xfrm_handles(fp_info, xfrm,
+						 num_xfrm,
+						 XFRM_POLICY_FWD);
+}
+
+bool nf_ct_update_layerscape_xfrm_out(struct nf_conn *ct,
+				      enum ip_conntrack_info ctinfo,
+				      const struct sk_buff *skb)
+{
+	struct comcerto_fp_info *fp_info = &ct->fp_info[CTINFO2DIR(ctinfo)];
+	struct xfrm_state *xfrm[MAX_SUPPORTED_XFRMS_PER_DIR] = {};
+	struct dst_entry *dst;
+	int num_xfrm = 0;
+
+	dst = skb_dst(skb);
+	if (!dst || !dst->xfrm) {
+		struct sec_path *sp = skb_sec_path(skb);
+
+		if (skb->ipsec_offload || (sp && sp->len))
+			return false;
+	}
+
+	while (dst && dst->xfrm && num_xfrm < MAX_SUPPORTED_XFRMS_PER_DIR) {
+		xfrm[num_xfrm++] = dst->xfrm;
+		dst = xfrm_dst_child(dst);
+	}
+
+	return nf_ct_set_layerscape_xfrm_handles(fp_info, xfrm,
+						 num_xfrm,
+						 XFRM_POLICY_OUT);
+}
