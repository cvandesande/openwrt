+static int ctnetlink_dump_layerscape_fp_dir(struct sk_buff *skb,
+					    const struct comcerto_fp_info *fp_info,
+					    u16 attr)
+{
+	struct nlattr *nest_parms;
+
+	nest_parms = nla_nest_start(skb, attr);
+	if (!nest_parms)
+		return -1;
+
+	if (nla_put_u32(skb, CTA_COMCERTO_FP_MARK, fp_info->mark) ||
+	    nla_put_u32(skb, CTA_COMCERTO_FP_IFINDEX, fp_info->ifindex) ||
+	    nla_put_u32(skb, CTA_COMCERTO_FP_IIF, fp_info->iif) ||
+	    nla_put_u32(skb, CTA_COMCERTO_FP_UNDERLYING_IIF,
+			fp_info->underlying_iif) ||
+	    nla_put(skb, CTA_COMCERTO_FP_XFRM_HANDLE,
+		    sizeof(fp_info->xfrm_handle), fp_info->xfrm_handle) ||
+	    nla_put_u16(skb, CTA_COMCERTO_FP_UNDERLYING_VID,
+			fp_info->underlying_vlan_id))
+		goto nla_put_failure;
+
+	nla_nest_end(skb, nest_parms);
+	return 0;
+
+nla_put_failure:
+	nla_nest_cancel(skb, nest_parms);
+	return -1;
+}
+
+static int ctnetlink_dump_layerscape_fp(struct sk_buff *skb,
+					const struct nf_conn *ct)
+{
+	if (ctnetlink_dump_layerscape_fp_dir(skb,
+					     &ct->fp_info[IP_CT_DIR_ORIGINAL],
+					     CTA_LAYERSCAPE_FP_ORIG) < 0 ||
+	    ctnetlink_dump_layerscape_fp_dir(skb,
+					     &ct->fp_info[IP_CT_DIR_REPLY],
+					     CTA_LAYERSCAPE_FP_REPLY) < 0)
+		return -1;
+
+	return 0;
+}
