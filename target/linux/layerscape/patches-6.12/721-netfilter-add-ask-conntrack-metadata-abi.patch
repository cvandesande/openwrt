+static void nf_ct_update_layerscape_fp(struct nf_conn *ct,
+				       enum ip_conntrack_info ctinfo,
+				       const struct sk_buff *skb)
+{
+	struct comcerto_fp_info *fp_info;
+	const struct net_device *dev;
+	int underlying_iif;
+
+	dev = skb->dev;
+	if (!dev)
+		return;
+
+	fp_info = &ct->fp_info[CTINFO2DIR(ctinfo)];
+	fp_info->mark = skb->mark;
+	fp_info->ifindex = dev->ifindex;
+	fp_info->iif = skb->skb_iif ? skb->skb_iif : dev->ifindex;
+	underlying_iif = skb->layerscape_underlying_iif ?
+		skb->layerscape_underlying_iif : dev->ifindex;
+
+	if (is_vlan_dev(dev)) {
+		const struct net_device *real_dev = vlan_dev_real_dev(dev);
+
+		fp_info->underlying_iif = underlying_iif ?
+			underlying_iif :
+			(real_dev ? real_dev->ifindex : dev->ifindex);
+		fp_info->underlying_vlan_id = vlan_dev_vlan_id(dev);
+		return;
+	}
+
+	fp_info->underlying_iif = underlying_iif;
+	fp_info->underlying_vlan_id = skb_vlan_tag_present(skb) ?
+		skb_vlan_tag_get_id(skb) : 0;
+}
