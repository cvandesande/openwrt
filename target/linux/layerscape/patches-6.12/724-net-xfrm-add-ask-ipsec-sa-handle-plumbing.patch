+static bool xfrm_ipsec_native_gso_prepare(struct xfrm_state *x,
+					  struct sk_buff *skb)
+{
+	struct skb_shared_info *shinfo = skb_shinfo(skb);
+	unsigned int hdr_len;
+	unsigned int target;
+	unsigned int mtu;
+
+	mtu = xfrm_ipsec_native_mtu(x, skb);
+	if (!mtu)
+		return false;
+
+	if (skb_gso_validate_network_len(skb, mtu))
+		return true;
+
+	if (shinfo->gso_size == GSO_BY_FRAGS)
+		return false;
+
+	hdr_len = skb_transport_header(skb) - skb_network_header(skb);
+	if (shinfo->gso_type & (SKB_GSO_TCPV4 | SKB_GSO_TCPV6))
+		hdr_len += tcp_hdrlen(skb);
+	else if (shinfo->gso_type & SKB_GSO_UDP_L4)
+		hdr_len += sizeof(struct udphdr);
+	else
+		return false;
+
+	if (hdr_len >= mtu)
+		return false;
+
+	target = mtu - hdr_len;
+	if (!target || target >= shinfo->gso_size || target > 0xffff)
+		return false;
+
+	shinfo->gso_size = target;
+
+	return skb_gso_validate_network_len(skb, mtu);
+}
