+#endif
+
+#ifdef NLKEY_SUPPORT
+#define NLKEY_SA_CREATE		0x0A01
+#define NLKEY_SA_DELETE		0x0A02
+#define NLKEY_SA_FLUSH		0x0A03
+#define NLKEY_SA_SET_KEYS	0x0A04
+#define NLKEY_SA_SET_TUNNEL	0x0A05
+#define NLKEY_SA_SET_NATT	0x0A06
+#define NLKEY_SA_SET_STATE	0x0A07
+#define NLKEY_SA_SET_LIFETIME	0x0A08
+#define NLKEY_SA_NOTIFY		0x0A09
+#define NLKEY_SA_INFO_UPDATE	0x0A0C
+#define NLKEY_SA_SET_OFFLOAD	0x0A0D
+#define NLKEY_NULL_MSG		0x0000
+
+#define NLKEY_HDR_LEN		4
+#define NLKEY_MSG_LEN		256
+#define NLKEY_MAX_NUM_KEYS	2
+#define NLKEY_MAX_KEY_LEN	(512 / 8)
+
+struct nlkey_msg {
+	unsigned short fcode;
+	unsigned short length;
+	unsigned short payload[NLKEY_MSG_LEN / sizeof(unsigned short)];
+};
+
+struct nlkey_sa_id {
+	unsigned int spi;
+	unsigned char sa_type;
+	unsigned char proto_family;
+	unsigned char replay_window;
+#define NLKEY_SAFLAGS_ESN	0x1
+#define NLKEY_SAFLAGS_INBOUND	0x2
+	unsigned char flags;
+	unsigned int dst_ip[4];
+	unsigned int src_ip[4];
+	unsigned short mtu;
+	unsigned short dev_mtu;
+};
+
+struct nlkey_sa_create {
+	unsigned short sagd;
+	unsigned short parent_sa_sagd;
+	struct nlkey_sa_id said;
+};
+
+struct nlkey_sa_delete {
+	unsigned short sagd;
+	unsigned short rsvd;
+};
+
+struct nlkey_sa_set_tunnel {
+	unsigned short sagd;
+	unsigned char rsvd;
+	unsigned char proto_family;
+	union {
+		struct iphdr ipv4h;
+		struct ipv6hdr ipv6h;
+	} h;
+};
+
+struct nlkey_sa_set_natt {
+	unsigned short sagd;
+	unsigned short sport;
+	unsigned short dport;
+	unsigned short rsvd;
+};
+
+struct nlkey_sa_set_state {
+	unsigned short sagd;
+	unsigned short parent_sa_sagd;
+	unsigned short state;
+	unsigned short rsvd2;
+};
+
+struct nlkey_key_desc {
+	unsigned short key_bits;
+	unsigned char key_alg;
+	unsigned char key_type;
+	unsigned char key[NLKEY_MAX_KEY_LEN];
+};
+
+struct nlkey_sa_set_keys {
+	unsigned short sagd;
+	unsigned short rsvd;
+	unsigned short num_keys;
+	unsigned short rsvd2;
+	struct nlkey_key_desc keys[NLKEY_MAX_NUM_KEYS];
+};
+
+struct nlkey_lifetime_desc {
+	unsigned int allocations;
+	unsigned int bytes[2];
+};
+
+struct nlkey_sa_set_lifetime {
+	unsigned short sagd;
+	unsigned short rsvd;
+	struct nlkey_lifetime_desc hard_time;
+	struct nlkey_lifetime_desc soft_time;
+	struct nlkey_lifetime_desc current_time;
+};
+
+struct nlkey_sa_notify {
+	unsigned short sagd;
+	unsigned short rsvd;
+	unsigned int action;
+};
+
+struct nlkey_sa_info {
+	unsigned short sagd;
+	unsigned short rsvd;
+	unsigned long long bytes;
+	unsigned long long packets;
+};
+
+static struct sock *nlkey_socket;
+static int ipsec_nlkey_send(struct net *net, struct xfrm_state *x,
+			    const struct km_event *c);
+static void ipsec_nlkey_rcv(struct sk_buff *skb);
+#endif
+
 #define _X2KEY(x) ((x) == XFRM_INF ? 0 : (x))
 #define _KEY2X(x) ((x) == 0 ? XFRM_INF : (x))
 
@@ -3076,6 +3207,10 @@
 	struct net *net = x ? xs_net(x) : c->net;
 	struct netns_pfkey *net_pfkey = net_generic(net, pfkey_net_id);
 
+#ifdef NLKEY_SUPPORT
+	ipsec_nlkey_send(net, x, c);
+#endif
+
 	if (atomic_read(&net_pfkey->socks_nr) == 0)
 		return 0;
 
@@ -3857,6 +3993,429 @@
 }
 #endif
 
+#ifdef NLKEY_SUPPORT
+static unsigned short ipsec_sacode_to_nlkeycode(unsigned short sa_code)
+{
+	switch (sa_code) {
+	case XFRM_MSG_DELSA:
+		return NLKEY_SA_DELETE;
+	case XFRM_MSG_NEWSA:
+	case XFRM_MSG_UPDSA:
+		return NLKEY_SA_CREATE;
+	case XFRM_MSG_FLUSHSA:
+		return NLKEY_SA_FLUSH;
+	case XFRM_MSG_EXPIRE:
+		return NLKEY_SA_SET_STATE;
+	default:
+		return NLKEY_NULL_MSG;
+	}
+}
+
+static int ipsec_nlkey_fill_mtu(struct net *net, struct xfrm_state *x,
+				struct nlkey_sa_id *said)
+{
+	struct xfrm_dst_lookup_params params = {};
+	xfrm_address_t saddr = x->props.saddr;
+	xfrm_address_t daddr = x->id.daddr;
+	struct dst_entry *dst;
+	unsigned int dev_mtu;
+	unsigned int mtu;
+
+	if (x->props.family != AF_INET && x->props.family != AF_INET6)
+		return -EAFNOSUPPORT;
+
+	params.net = net;
+	if (x->dir == XFRM_SA_DIR_IN) {
+		saddr = x->id.daddr;
+		daddr = x->props.saddr;
+	}
+
+	params.saddr = &saddr;
+	params.daddr = &daddr;
+	params.mark = xfrm_smark_get(0, x);
+	params.ipproto = x->id.proto;
+	if (x->encap) {
+		switch (x->encap->encap_type) {
+		case UDP_ENCAP_ESPINUDP:
+			params.ipproto = IPPROTO_UDP;
+			params.uli.ports.sport = x->encap->encap_sport;
+			params.uli.ports.dport = x->encap->encap_dport;
+			break;
+		case TCP_ENCAP_ESPINTCP:
+			params.ipproto = IPPROTO_TCP;
+			params.uli.ports.sport = x->encap->encap_sport;
+			params.uli.ports.dport = x->encap->encap_dport;
+			break;
+		}
+	}
+
+	dst = __xfrm_dst_lookup(x->props.family, &params);
+	if (IS_ERR(dst))
+		return PTR_ERR(dst);
+
+	dev_mtu = dst_mtu(dst);
+	mtu = xfrm_state_mtu(x, dev_mtu);
+	dst_release(dst);
+
+	if (!dev_mtu || !mtu || dev_mtu > 0xffff || mtu > 0xffff)
+		return -EINVAL;
+
+	said->dev_mtu = dev_mtu;
+	said->mtu = mtu;
+	return 0;
+}
+
+static int ipsec_nlkey_set_said(struct net *net, struct xfrm_state *x,
+				struct nlkey_sa_id *said)
+{
+	memset(said, 0, sizeof(*said));
+	said->spi = x->id.spi;
+	said->sa_type = x->id.proto;
+	said->proto_family = x->props.family;
+	said->replay_window = x->props.replay_window;
+
+	if (x->props.flags & XFRM_STATE_ESN)
+		said->flags |= NLKEY_SAFLAGS_ESN;
+	if (x->dir == XFRM_SA_DIR_IN)
+		said->flags |= NLKEY_SAFLAGS_INBOUND;
+
+	if (x->props.family == AF_INET6) {
+		memcpy(said->dst_ip, x->id.daddr.a6, sizeof(struct in6_addr));
+		memcpy(said->src_ip, x->props.saddr.a6, sizeof(struct in6_addr));
+	} else {
+		said->dst_ip[0] = x->id.daddr.a4;
+		said->src_ip[0] = x->props.saddr.a4;
+	}
+
+	return ipsec_nlkey_fill_mtu(net, x, said);
+}
+
+static void ipsec_nlkey_put_msg(struct nlkey_msg *msg, unsigned short fcode,
+				const void *payload, unsigned short len)
+{
+	memset(msg, 0, sizeof(*msg));
+	msg->fcode = fcode;
+	msg->length = min_t(unsigned short, len, NLKEY_MSG_LEN);
+	memcpy(msg->payload, payload, msg->length);
+}
+
+static struct sk_buff *ipsec_nlkey_msg_to_skb(const struct nlkey_msg *msg)
+{
+	struct nlmsghdr *nlh;
+	struct sk_buff *skb;
+	unsigned int len;
+
+	if (msg->length > NLKEY_MSG_LEN)
+		return NULL;
+
+	len = NLKEY_HDR_LEN + msg->length;
+	skb = alloc_skb(NLMSG_SPACE(len), GFP_ATOMIC);
+	if (!skb)
+		return NULL;
+
+	nlh = nlmsg_put(skb, 0, 0, 0, len, 0);
+	if (!nlh) {
+		kfree_skb(skb);
+		return NULL;
+	}
+
+	memcpy(nlmsg_data(nlh), msg, len);
+	NETLINK_CB(skb).portid = 0;
+	NETLINK_CB(skb).dst_group = 1;
+
+	return skb;
+}
+
+static void ipsec_nlkey_add_keys(struct xfrm_state *x,
+				 struct nlkey_sa_set_keys *keys)
+{
+	struct nlkey_key_desc *desc;
+	unsigned int key_len;
+
+	memset(keys, 0, sizeof(*keys));
+	keys->sagd = x->handle;
+
+	if (x->aalg && x->aalg->alg_key_len &&
+	    keys->num_keys < NLKEY_MAX_NUM_KEYS) {
+		desc = &keys->keys[keys->num_keys++];
+		key_len = min_t(unsigned int, x->aalg->alg_key_len / 8,
+				NLKEY_MAX_KEY_LEN);
+		desc->key_bits = x->aalg->alg_key_len;
+		desc->key_alg = x->props.aalgo;
+		desc->key_type = 0;
+		memcpy(desc->key, x->aalg->alg_key, key_len);
+	}
+
+	if (x->ealg && x->ealg->alg_key_len &&
+	    keys->num_keys < NLKEY_MAX_NUM_KEYS) {
+		desc = &keys->keys[keys->num_keys++];
+		key_len = min_t(unsigned int, x->ealg->alg_key_len / 8,
+				NLKEY_MAX_KEY_LEN);
+		desc->key_bits = x->ealg->alg_key_len;
+		desc->key_alg = x->props.ealgo;
+		desc->key_type = 1;
+		memcpy(desc->key, x->ealg->alg_key, key_len);
+	}
+
+	if (x->aead && x->aead->alg_key_len &&
+	    keys->num_keys < NLKEY_MAX_NUM_KEYS) {
+		desc = &keys->keys[keys->num_keys++];
+		key_len = min_t(unsigned int, x->aead->alg_key_len / 8,
+				NLKEY_MAX_KEY_LEN);
+		desc->key_bits = x->aead->alg_key_len;
+		if (strstr(x->aead->alg_name, "rfc4106(gcm")) {
+			if (x->aead->alg_icv_len == 64)
+				desc->key_alg = SADB_X_EALG_AES_GCM_ICV8;
+			else if (x->aead->alg_icv_len == 96)
+				desc->key_alg = SADB_X_EALG_AES_GCM_ICV12;
+			else if (x->aead->alg_icv_len == 128)
+				desc->key_alg = SADB_X_EALG_AES_GCM_ICV16;
+		} else if (strstr(x->aead->alg_name, "ccm")) {
+			if (x->aead->alg_icv_len == 64)
+				desc->key_alg = SADB_X_EALG_AES_CCM_ICV8;
+			else if (x->aead->alg_icv_len == 96)
+				desc->key_alg = SADB_X_EALG_AES_CCM_ICV12;
+			else if (x->aead->alg_icv_len == 128)
+				desc->key_alg = SADB_X_EALG_AES_CCM_ICV16;
+		} else if (strstr(x->aead->alg_name, "rfc4543(gcm")) {
+			desc->key_alg = SADB_X_EALG_NULL_AES_GMAC;
+		}
+		desc->key_type = 1;
+		memcpy(desc->key, x->aead->alg_key, key_len);
+	}
+}
+
+static struct sk_buff *ipsec_xfrm2nlkey(struct net *net, struct xfrm_state *x,
+					unsigned short *msg_id)
+{
+	struct nlkey_sa_set_lifetime lifetime;
+	struct nlkey_sa_set_tunnel tunnel;
+	struct nlkey_sa_create create;
+	struct nlkey_sa_delete del;
+	struct nlkey_sa_set_state state;
+	struct nlkey_sa_set_natt natt;
+	struct nlkey_sa_set_keys keys;
+	struct nlkey_msg msg;
+
+	if (!x && *msg_id != NLKEY_SA_FLUSH) {
+		*msg_id = NLKEY_NULL_MSG;
+		return NULL;
+	}
+
+	switch (*msg_id) {
+	case NLKEY_SA_CREATE:
+		if (x->id.proto != IPPROTO_ESP) {
+			*msg_id = NLKEY_NULL_MSG;
+			return NULL;
+		}
+		memset(&create, 0, sizeof(create));
+		create.sagd = x->handle;
+		create.parent_sa_sagd = x->parent_sa_handle;
+		if (ipsec_nlkey_set_said(net, x, &create.said)) {
+			*msg_id = NLKEY_NULL_MSG;
+			return NULL;
+		}
+		ipsec_nlkey_put_msg(&msg, *msg_id, &create, sizeof(create));
+		*msg_id = NLKEY_SA_SET_KEYS;
+		break;
+	case NLKEY_SA_SET_KEYS:
+		ipsec_nlkey_add_keys(x, &keys);
+		if (!keys.num_keys) {
+			*msg_id = NLKEY_SA_SET_TUNNEL;
+			return NULL;
+		}
+		ipsec_nlkey_put_msg(&msg, *msg_id, &keys, sizeof(keys));
+		*msg_id = NLKEY_SA_SET_TUNNEL;
+		break;
+	case NLKEY_SA_SET_TUNNEL:
+		if (x->props.mode != XFRM_MODE_TUNNEL) {
+			*msg_id = NLKEY_SA_SET_NATT;
+			return NULL;
+		}
+		memset(&tunnel, 0, sizeof(tunnel));
+		tunnel.sagd = x->handle;
+		tunnel.proto_family = x->props.family;
+		if (x->props.family == AF_INET6) {
+			tunnel.h.ipv6h.version = 6;
+			tunnel.h.ipv6h.nexthdr = IPPROTO_IPIP;
+			tunnel.h.ipv6h.hop_limit = 64;
+			memcpy(&tunnel.h.ipv6h.daddr, x->id.daddr.a6,
+			       sizeof(struct in6_addr));
+			memcpy(&tunnel.h.ipv6h.saddr, x->props.saddr.a6,
+			       sizeof(struct in6_addr));
+		} else {
+			tunnel.h.ipv4h.ihl = 5;
+			tunnel.h.ipv4h.version = 4;
+			tunnel.h.ipv4h.ttl = 64;
+			tunnel.h.ipv4h.saddr = x->props.saddr.a4;
+			tunnel.h.ipv4h.daddr = x->id.daddr.a4;
+		}
+		ipsec_nlkey_put_msg(&msg, *msg_id, &tunnel, sizeof(tunnel));
+		*msg_id = NLKEY_SA_SET_NATT;
+		break;
+	case NLKEY_SA_SET_NATT:
+		if (!x->encap) {
+			*msg_id = NLKEY_SA_SET_LIFETIME;
+			return NULL;
+		}
+		memset(&natt, 0, sizeof(natt));
+		natt.sagd = x->handle;
+		natt.sport = x->encap->encap_sport;
+		natt.dport = x->encap->encap_dport;
+		ipsec_nlkey_put_msg(&msg, *msg_id, &natt, sizeof(natt));
+		*msg_id = NLKEY_SA_SET_LIFETIME;
+		break;
+	case NLKEY_SA_SET_LIFETIME:
+		memset(&lifetime, 0, sizeof(lifetime));
+		lifetime.sagd = x->handle;
+		lifetime.hard_time.allocations = _X2KEY(x->lft.hard_packet_limit);
+		memcpy(lifetime.hard_time.bytes, &x->lft.hard_byte_limit,
+		       sizeof(lifetime.hard_time.bytes));
+		lifetime.soft_time.allocations = _X2KEY(x->lft.soft_packet_limit);
+		memcpy(lifetime.soft_time.bytes, &x->lft.soft_byte_limit,
+		       sizeof(lifetime.soft_time.bytes));
+		lifetime.current_time.allocations = x->curlft.packets;
+		memcpy(lifetime.current_time.bytes, &x->curlft.bytes,
+		       sizeof(lifetime.current_time.bytes));
+		ipsec_nlkey_put_msg(&msg, *msg_id, &lifetime, sizeof(lifetime));
+		*msg_id = NLKEY_SA_SET_STATE;
+		break;
+	case NLKEY_SA_SET_STATE:
+		memset(&state, 0, sizeof(state));
+		state.sagd = x->handle;
+		state.parent_sa_sagd = x->parent_sa_handle;
+		state.state = x->km.state;
+		ipsec_nlkey_put_msg(&msg, *msg_id, &state, sizeof(state));
+		*msg_id = NLKEY_NULL_MSG;
+		break;
+	case NLKEY_SA_DELETE:
+		memset(&del, 0, sizeof(del));
+		del.sagd = x->handle;
+		ipsec_nlkey_put_msg(&msg, *msg_id, &del, sizeof(del));
+		*msg_id = NLKEY_NULL_MSG;
+		break;
+	case NLKEY_SA_FLUSH:
+		memset(&msg, 0, sizeof(msg));
+		msg.fcode = *msg_id;
+		*msg_id = NLKEY_NULL_MSG;
+		break;
+	default:
+		*msg_id = NLKEY_NULL_MSG;
+		return NULL;
+	}
+
+	return ipsec_nlkey_msg_to_skb(&msg);
+}
+
+static int ipsec_nlkey_send(struct net *net, struct xfrm_state *x,
+			    const struct km_event *c)
+{
+	unsigned short msg_type;
+	int rc = 0;
+
+	if (!nlkey_socket)
+		return 0;
+
+	msg_type = ipsec_sacode_to_nlkeycode((unsigned short)c->event);
+	while (msg_type != NLKEY_NULL_MSG) {
+		struct sk_buff *skb = ipsec_xfrm2nlkey(net, x, &msg_type);
+
+		if (!skb)
+			continue;
+
+		rc = netlink_broadcast(nlkey_socket, skb, 0, 1, GFP_ATOMIC);
+		if (rc && rc != -ESRCH)
+			return rc;
+	}
+
+	return 0;
+}
+
+static void ipsec_nlkey_rcv(struct sk_buff *skb)
+{
+	struct nlkey_sa_notify notify;
+	struct nlkey_sa_info info;
+	struct xfrm_state *x;
+	struct nlkey_msg *msg;
+	struct nlmsghdr *nlh;
+	unsigned int len;
+
+	nlh = nlmsg_hdr(skb);
+	len = nlmsg_len(nlh);
+	if (len < NLKEY_HDR_LEN)
+		return;
+
+	msg = nlmsg_data(nlh);
+	if (msg->length > NLKEY_MSG_LEN ||
+	    len < NLKEY_HDR_LEN + msg->length)
+		return;
+
+	switch (msg->fcode) {
+	case NLKEY_SA_NOTIFY:
+		if (msg->length < sizeof(notify))
+			break;
+		memcpy(&notify, msg->payload, sizeof(notify));
+		x = xfrm_state_lookup_byhandle(&init_net, notify.sagd);
+		if (!x)
+			break;
+		spin_lock(&x->lock);
+		if (notify.action) {
+			x->km.state = XFRM_STATE_EXPIRED;
+			hrtimer_start(&x->mtimer, 0, HRTIMER_MODE_REL_SOFT);
+		} else if (!x->km.dying) {
+			x->km.dying = 1;
+			km_state_expired(x, 0, 0);
+		}
+		spin_unlock(&x->lock);
+		xfrm_state_put(x);
+		break;
+	case NLKEY_SA_INFO_UPDATE:
+		if (msg->length < sizeof(info))
+			break;
+		memcpy(&info, msg->payload, sizeof(info));
+		x = xfrm_state_lookup_byhandle(&init_net, info.sagd);
+		if (!x)
+			break;
+		spin_lock(&x->lock);
+		if (x->curlft.bytes != info.bytes)
+			x->curr_time = ktime_get_real_seconds();
+		x->curlft.bytes = info.bytes;
+		x->curlft.packets = info.packets;
+		spin_unlock(&x->lock);
+		xfrm_state_put(x);
+		break;
+	case NLKEY_SA_SET_OFFLOAD:
+		if (msg->length < sizeof(notify))
+			break;
+		memcpy(&notify, msg->payload, sizeof(notify));
+		x = xfrm_state_lookup_byhandle(&init_net, notify.sagd);
+		if (!x) {
+			pr_info_ratelimited("ASK-IPSEC: nlkey set-offload sagd=0x%x action=%u lookup=miss\n",
+					    notify.sagd, notify.action);
+			break;
+		}
+		spin_lock(&x->lock);
+		x->offloaded = notify.action ? 1 : 0;
+		spin_unlock(&x->lock);
+		xfrm_state_put(x);
+		break;
+	default:
+		break;
+	}
+}
+
+static int ipsec_nlkey_init(void)
+{
+	struct netlink_kernel_cfg cfg = {
+		.groups = 1,
+		.input = ipsec_nlkey_rcv,
+	};
+
+	nlkey_socket = netlink_kernel_create(&init_net, NETLINK_KEY, &cfg);
+	return nlkey_socket ? 0 : -ENOMEM;
+}
