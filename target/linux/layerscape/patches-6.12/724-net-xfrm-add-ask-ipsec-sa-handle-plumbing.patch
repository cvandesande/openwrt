diff --git a/net/ipv4/esp4_offload.c b/net/ipv4/esp4_offload.c
--- a/net/ipv4/esp4_offload.c
+++ b/net/ipv4/esp4_offload.c
@@ -272,6 +272,9 @@ static int esp_xmit(struct xfrm_state *x
 	struct crypto_aead *aead;
 	struct esp_info esp;
 	bool hw_offload = true;
+#if defined(CONFIG_INET_IPSEC_OFFLOAD) || defined(CONFIG_INET6_IPSEC_OFFLOAD)
+	bool hw_offload_native;
+#endif
 	__u32 seq;
 	int encap_type = 0;
 
@@ -291,6 +294,26 @@ static int esp_xmit(struct xfrm_state *x
 
 	esp.proto = xo->proto;
 
+#if defined(CONFIG_INET_IPSEC_OFFLOAD) || defined(CONFIG_INET6_IPSEC_OFFLOAD)
+	/*
+	 * Native ASK hardware offload can hand ESP encapsulation to hardware
+	 * without the upstream xfrm device packet-offload callbacks.
+	 */
+	hw_offload_native = x->offloaded && skb->ipsec_offload &&
+			    (hw_offload || !x->xso.dev);
+	if (hw_offload_native) {
+		if (!skb_ext_add(skb, SKB_EXT_SEC_PATH))
+			return -ENOMEM;
+
+		xo = xfrm_offload(skb);
+		if (!xo)
+			return -EINVAL;
+
+		xo->flags |= XFRM_XMIT;
+		return 0;
+	}
+#endif
+
 	/* skb is pure payload to encrypt */
 
 	aead = x->data;
