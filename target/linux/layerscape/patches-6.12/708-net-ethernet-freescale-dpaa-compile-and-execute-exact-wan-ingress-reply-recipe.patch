+static bool dpaa_ft_packet_matches_ingress(const struct dpaa_ft_entry *entry,
+					   const struct dpaa_ft_parse_info *parse)
+{
+	const struct dpaa_ft_ingress_recipe *ingress = &entry->ingress;
+
+	if (dpaa_ft_ingress_recipe_has_plain_vlan_match(entry)) {
+		if (parse->pppoe.present || !parse->vlan.present)
+			return false;
+
+		return parse->vlan.proto == ingress->vlan_match.proto &&
+		       parse->vlan.vid == ingress->vlan_match.vid;
+	}
+
+	if (!dpaa_ft_ingress_recipe_needs_decap(entry))
+		return !parse->vlan.present && !parse->pppoe.present;
+
+	if (!ingress->vlan_match.present || !ingress->vlan_pop ||
+	    !ingress->pppoe_decap)
+		return false;
+
+	if (!parse->vlan.present || !parse->pppoe.present)
+		return false;
+
+	if (parse->vlan.proto != ingress->vlan_match.proto ||
+	    parse->vlan.vid != ingress->vlan_match.vid)
+		return false;
+
+	return parse->pppoe.ppp_proto == ingress->ppp_proto;
+}
