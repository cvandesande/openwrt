+static void dpaa_ft_strip_ingress_encap(struct sk_buff *skb,
+					unsigned int decap_len,
+					unsigned int *l4_off)
+{
+	unsigned int network_len;
+
+	if (!decap_len) {
+		skb_reset_mac_header(skb);
+		skb_set_network_header(skb, ETH_HLEN);
+		skb_set_transport_header(skb, *l4_off);
+		skb->mac_len = ETH_HLEN;
+		return;
+	}
+
+	network_len = skb->len - ETH_HLEN - decap_len;
+	memmove(skb->data + ETH_HLEN, skb->data + ETH_HLEN + decap_len,
+		network_len);
+	skb_trim(skb, skb->len - decap_len);
+	*l4_off -= decap_len;
+
+	skb_reset_mac_header(skb);
+	skb_set_network_header(skb, ETH_HLEN);
+	skb_set_transport_header(skb, *l4_off);
+	skb->mac_len = ETH_HLEN;
+}
