+			   snapshot->hm.src);
+	bytes += scnprintf(buf + bytes, size - bytes, "%s.hm.dst %pM\n", prefix,
+			   snapshot->hm.dst);
+	bytes += scnprintf(buf + bytes, size - bytes, "%s.hm.vlan_vid %u\n",
+			   prefix, snapshot->hm.vlan_vid);
+	bytes += scnprintf(buf + bytes, size - bytes,
+			   "%s.hm.vlan_proto 0x%04x\n", prefix,
+			   ntohs(snapshot->hm.vlan_proto));
