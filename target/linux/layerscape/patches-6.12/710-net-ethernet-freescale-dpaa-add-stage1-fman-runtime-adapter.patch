+			   "%s.hm.snat_port_valid %u\n", prefix,
+			   snapshot->hm.snat_port_valid ? 1 : 0);
+	bytes += scnprintf(buf + bytes, size - bytes, "%s.hm.snat_port %u\n",
+			   prefix, ntohs(snapshot->hm.snat_port));
