+		return "primary_outbound_eth2_pppoe_wan";
+	case FMAN_OFFLOAD_EXACT_CLASS_NONE:
+	default:
+		return "none";
+	}
+}
+
+static const char *
+dpaa_ft_hw_fman_lifecycle_name(enum fman_offload_lifecycle state)
+{
+	switch (state) {
+	case FMAN_OFFLOAD_LIFECYCLE_PREPARED:
+		return "prepared";
+	case FMAN_OFFLOAD_LIFECYCLE_OBJECTS_STAGED:
+		return "objects_staged";
+	case FMAN_OFFLOAD_LIFECYCLE_ACTIVATE_UNAVAILABLE:
+		return "activate_unavailable";
+	case FMAN_OFFLOAD_LIFECYCLE_REMOVED:
+		return "removed";
+	case FMAN_OFFLOAD_LIFECYCLE_FAILED:
+		return "failed";
+	case FMAN_OFFLOAD_LIFECYCLE_NONE:
+	default:
+		return "none";
+	}
+}
