+			   snapshot->enqueue.logical_out_ifindex);
+	bytes += scnprintf(buf + bytes, size - bytes,
+			   "%s.enqueue.binding_ifindex %u\n", prefix,
+			   snapshot->enqueue.binding_ifindex);
+	bytes += scnprintf(buf + bytes, size - bytes, "%s.stats.valid %u\n",
+			   prefix, snapshot->stats.valid ? 1 : 0);
+	bytes += scnprintf(buf + bytes, size - bytes,
+			   "%s.stats.hardware_counters_available %u\n",
+			   prefix,
+			   snapshot->stats.hardware_counters_available ? 1 : 0);
+	bytes += scnprintf(buf + bytes, size - bytes,
+			   "%s.stats.last_packets %llu\n", prefix,
+			   snapshot->stats.last_packets);
+	bytes += scnprintf(buf + bytes, size - bytes,
+			   "%s.stats.last_bytes %llu\n", prefix,
+			   snapshot->stats.last_bytes);
+	bytes += scnprintf(buf + bytes, size - bytes, "%s.stats.reads %llu\n",
+			   prefix, snapshot->stats.reads);
+
+	return bytes;
+}
