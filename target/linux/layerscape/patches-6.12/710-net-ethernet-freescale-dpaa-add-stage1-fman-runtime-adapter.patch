+struct dpaa_ft_hw_result {
+	enum dpaa_ft_hw_backend_state state;
+	enum dpaa_ft_hw_lifecycle_state lifecycle;
+	enum dpaa_ft_hw_dry_run_result dry_run;
+	enum dpaa_ft_hw_degrade_reason degrade;
+	enum dpaa_ft_reject_reason reject_reason;
+	int err;
+	const char *message;
+};
+
+struct dpaa_ft_hw_backend_ops {
+	void (*prepare)(struct dpaa_priv *priv, struct dpaa_ft_hw_backend *hw);
+	int (*dry_run)(struct dpaa_priv *priv,
+		       const struct dpaa_ft_entry *entry,
+		       struct dpaa_ft_hw_backend *hw,
+		       struct dpaa_ft_hw_result *result);
+	int (*install)(struct dpaa_priv *priv, struct dpaa_ft_entry *entry);
+	int (*remove)(struct dpaa_priv *priv, struct dpaa_ft_entry *entry);
+	int (*stats)(struct dpaa_priv *priv, struct dpaa_ft_entry *entry);
+};
+
+struct dpaa_ft_hw_exact_egress_path {
+	struct net_device *binding_dev;
+	struct dpaa_priv *binding_priv;
+	u32 compiled_out_ifindex;
+	u32 logical_out_ifindex;
+};
+
+static const char *dpaa_ft_fman_hw_disabled_reason(const struct dpaa_priv *priv)
+{
+	if (!priv->fman.ports_bound)
+		return "hardware flow offloading requested, but the FMAN backend is disabled because FMAN port state is unavailable; flows stay on the normal Linux path";
+
+	if (!priv->fman.rx.kg_hash_enabled)
+		return "hardware flow offloading requested, but the FMAN backend is disabled because RX KeyGen hashing is off; flows stay on the normal Linux path";
+
+	if (!priv->fman.rx.kg_scheme_api_available)
+		return "hardware flow offloading requested, but the FMAN backend is disabled because the RX KeyGen scheme API is unavailable; flows stay on the normal Linux path";
+
+	if (!priv->fman.rx_pcd_fq_count)
+		return "hardware flow offloading requested, but the FMAN backend is disabled because the RX PCD queue span is unavailable; flows stay on the normal Linux path";
+
+	return "hardware flow offloading requested, but the FMAN backend is disabled because backend prerequisites are incomplete; flows stay on the normal Linux path";
+}
+
+static const char *dpaa_ft_fman_hw_live_commit_unavailable_reason(void)
+{
+	return "hardware flow offloading requested, and the FMAN Stage 1 backend staged the exact eth2 outbound FMAN object surface, but live FMAN commit is still unavailable because the in-tree seam does not expose header-manipulation and enqueue object commit APIs; flows stay on the normal Linux path";
+}
+
+static bool
+dpaa_ft_fman_hw_find_exact_primary_vlan_upper(struct net_device *lower_dev,
+					      __be16 vlan_proto, u16 vlan_vid,
+					      u32 *logical_out_ifindex,
+					      const char **reason)
+{
+	struct net_device *upper_dev;
+	struct list_head *iter;
+	u32 match_ifindex = 0;
+
+	rcu_read_lock();
+	netdev_for_each_upper_dev_rcu(lower_dev, upper_dev, iter) {
+		if (!is_vlan_dev(upper_dev))
+			continue;
+
+		if (vlan_dev_real_dev(upper_dev) != lower_dev)
+			continue;
+
+		if (strcmp(netdev_name(upper_dev), "eth0.10") != 0)
+			continue;
+
+		if (vlan_dev_vlan_proto(upper_dev) != vlan_proto ||
+		    vlan_dev_vlan_id(upper_dev) != vlan_vid)
+			continue;
+
+		if (match_ifindex) {
+			match_ifindex = 0;
+			break;
+		}
+
+		match_ifindex = upper_dev->ifindex;
+	}
+	rcu_read_unlock();
+
+	if (!match_ifindex) {
+		*reason = "hardware flow offloading requested, but the exact first supported class requires the exact eth0.10 VLAN upper on the validated WAN path; flows stay on the normal Linux path";
+		return false;
+	}
+
+	*logical_out_ifindex = match_ifindex;
+
+	return true;
+}
+
+/*
+ * The validated Stage 1 exact class is represented in-tree as an exact lower
+ * Ethernet redirect plus one exact VLAN 10 push and one exact PPPoE push.
+ * Keep the logical eth0.10 path private to the backend and derive the FMAN TX
+ * identity from the resolved lower DPAA device that owns that path.
+ */
+static bool
+dpaa_ft_fman_hw_resolve_exact_primary_egress(
+	struct dpaa_priv *priv, const struct dpaa_ft_entry *entry,
+	struct dpaa_ft_hw_exact_egress_path *path, const char **reason)
+{
+	struct net_device *out_dev = entry->egress.out_dev;
+	struct dpaa_priv *out_priv;
+	u32 logical_out_ifindex;
+
+	if (!out_dev || out_dev->type != ARPHRD_ETHER) {
+		*reason = "hardware flow offloading requested, but the exact first supported class requires exact Ethernet redirect; flows stay on the normal Linux path";
+		return false;
+	}
+
+	if (is_vlan_dev(out_dev) || strcmp(netdev_name(out_dev), "eth0") != 0) {
+		*reason = "hardware flow offloading requested, but the exact first supported class only covers the exact eth0 lower redirect for the validated eth0.10 PPPoE WAN path; flows stay on the normal Linux path";
+		return false;
+	}
+
+	if (!dpaa_ft_fman_hw_find_exact_primary_vlan_upper(
+		    out_dev, entry->egress.vlan_push.proto,
+		    entry->egress.vlan_push.vid, &logical_out_ifindex,
+		    reason))
+		return false;
+
+	if (out_dev->netdev_ops != priv->net_dev->netdev_ops) {
+		*reason = "hardware flow offloading requested, but the exact first supported class could not map the validated WAN lower device to a DPAA FMAN binding; flows stay on the normal Linux path";
+		return false;
+	}
+
+	out_priv = netdev_priv(out_dev);
+	if (!out_priv->mac_dev || !out_priv->fman.ports_bound ||
+	    !out_priv->mac_dev->port[TX]) {
+		*reason = "hardware flow offloading requested, but the exact first supported class could not resolve the FMAN TX binding for the validated WAN lower device; flows stay on the normal Linux path";
+		return false;
+	}
+
+	if (!path)
+		return true;
+
+	path->binding_dev = out_dev;
+	path->binding_priv = out_priv;
+	path->compiled_out_ifindex = entry->egress.out_ifindex;
+	path->logical_out_ifindex = logical_out_ifindex;
+
+	return true;
+}
+
+static enum dpaa_ft_hw_lifecycle_state
+dpaa_ft_hw_map_lifecycle(enum fman_offload_lifecycle state)
+{
+	switch (state) {
+	case FMAN_OFFLOAD_LIFECYCLE_PREPARED:
+		return DPAA_FT_HW_LIFECYCLE_PREPARED;
+	case FMAN_OFFLOAD_LIFECYCLE_OBJECTS_STAGED:
+		return DPAA_FT_HW_LIFECYCLE_OBJECTS_STAGED;
+	case FMAN_OFFLOAD_LIFECYCLE_ACTIVATE_UNAVAILABLE:
+		return DPAA_FT_HW_LIFECYCLE_ACTIVATE_UNAVAILABLE;
+	case FMAN_OFFLOAD_LIFECYCLE_REMOVED:
+		return DPAA_FT_HW_LIFECYCLE_REMOVED;
+	case FMAN_OFFLOAD_LIFECYCLE_FAILED:
+		return DPAA_FT_HW_LIFECYCLE_FAILED;
+	case FMAN_OFFLOAD_LIFECYCLE_NONE:
+	default:
+		return DPAA_FT_HW_LIFECYCLE_NONE;
+	}
+}
+
+static void dpaa_ft_hw_clear_staged_snapshot(struct dpaa_ft_hw_backend *hw)
+{
+	memset(&hw->staged, 0, sizeof(hw->staged));
+}
+
+static void dpaa_ft_hw_cache_snapshot(struct dpaa_ft_hw_backend *hw,
+				      const struct fman_offload_snapshot *snapshot)
+{
+	if (!snapshot)
+		return;
+
+	hw->staged = *snapshot;
+	hw->last_staged = *snapshot;
+	hw->last_error = snapshot->last_error;
+	hw->last_lifecycle = dpaa_ft_hw_map_lifecycle(snapshot->lifecycle);
+}
+
+static void
+dpaa_ft_hw_set_lifecycle(struct dpaa_ft_hw_backend *hw,
+			 enum dpaa_ft_hw_lifecycle_state state)
+{
+	if (state <= DPAA_FT_HW_LIFECYCLE_NONE ||
+	    state >= DPAA_FT_HW_LIFECYCLE_MAX)
+		return;
+
+	hw->last_lifecycle = state;
+}
+
+static void dpaa_ft_hw_update_runtime_state(struct dpaa_priv *priv,
+					    struct dpaa_ft_hw_backend *hw)
+{
+	int err;
+
+	memset(&hw->runtime, 0, sizeof(hw->runtime));
+	if (!priv->mac_dev || !priv->mac_dev->port[RX])
+		return;
+
+	err = fman_port_offload_get_runtime_state(priv->mac_dev->port[RX],
+						  &hw->runtime);
+	if (err)
+		memset(&hw->runtime, 0, sizeof(hw->runtime));
+}
+
+static void dpaa_ft_hw_reset_observation(struct dpaa_ft_hw_backend *hw)
+{
+	hw->last_dry_run = DPAA_FT_HW_DRY_RUN_NONE;
+	hw->last_degrade = DPAA_FT_HW_DEGRADE_NONE;
+	hw->last_lifecycle = DPAA_FT_HW_LIFECYCLE_NONE;
+	hw->last_error = 0;
+	memset(&hw->runtime, 0, sizeof(hw->runtime));
+	memset(&hw->staged, 0, sizeof(hw->staged));
+	memset(&hw->last_staged, 0, sizeof(hw->last_staged));
+}
+
+static void dpaa_ft_hw_note_degrade(struct dpaa_priv *priv,
+				    struct dpaa_ft_hw_backend *hw,
+				    enum dpaa_ft_hw_degrade_reason reason,
+				    const char *message)
+{
+	if (reason <= DPAA_FT_HW_DEGRADE_NONE ||
+	    reason >= DPAA_FT_HW_DEGRADE_MAX)
+		return;
+
+	hw->degrade_events[reason]++;
+	if (hw->last_degrade == reason)
+		return;
+
+	hw->last_degrade = reason;
+	if (message)
+		net_warn_ratelimited("%s: %s\n", netdev_name(priv->net_dev),
+				     message);
+}
+
+static bool
+dpaa_ft_fman_hw_backend_ready(const struct dpaa_priv *priv,
+			      const struct dpaa_ft_hw_backend *hw)
+{
+	return priv->mac_dev && priv->mac_dev->port[RX] &&
+	       priv->fman.ports_bound && priv->fman.rx.kg_hash_enabled &&
+	       priv->fman.rx.kg_scheme_api_available &&
+	       priv->fman.rx_pcd_fq_count && hw->runtime.ready;
+}
+
+static void dpaa_ft_fman_hw_prepare(struct dpaa_priv *priv,
+				    struct dpaa_ft_hw_backend *hw)
+{
+	dpaa_ft_hw_reset_observation(hw);
+	hw->state = DPAA_FT_HW_BACKEND_NOT_IMPLEMENTED;
+
+	if (!priv->mac_dev || !priv->mac_dev->port[RX])
+		return;
+
+	dpaa_ft_hw_update_runtime_state(priv, hw);
+	if (!dpaa_ft_fman_hw_backend_ready(priv, hw)) {
+		hw->state = DPAA_FT_HW_BACKEND_DISABLED;
+		hw->last_error = -EOPNOTSUPP;
+		return;
+	}
+
+	hw->state = DPAA_FT_HW_BACKEND_READY;
+}
+
+static bool
+dpaa_ft_fman_hw_is_exact_primary_outbound(struct dpaa_priv *priv,
+					  const struct dpaa_ft_entry *entry,
+					  const char **reason)
+{
+	if (strcmp(netdev_name(priv->net_dev), "eth2") != 0) {
+		*reason = "hardware flow offloading requested, but the exact first supported class only covers eth2 ingress; flows stay on the normal Linux path";
+		return false;
+	}
+
+	if (entry->tuple.is_ipv6) {
+		*reason = "hardware flow offloading requested, but the exact first supported class only covers exact outbound IPv4 flows for now; flows stay on the normal Linux path";
+		return false;
+	}
+
+	if (entry->tuple.ingress_ifindex != priv->net_dev->ifindex) {
+		*reason = "hardware flow offloading requested, but the exact first supported class only covers direct lower-device ingress on eth2 for now; flows stay on the normal Linux path";
+		return false;
+	}
+
+	if (entry->ingress.vlan_match.present || entry->ingress.vlan_pop ||
+	    entry->ingress.pppoe_decap) {
+		*reason = "hardware flow offloading requested, but the exact first supported class does not cover reply-half or recovered ingress recipes yet; flows stay on the normal Linux path";
+		return false;
+	}
+
+	if (!entry->egress.out_dev || entry->egress.out_dev->type != ARPHRD_ETHER) {
+		*reason = "hardware flow offloading requested, but the exact first supported class requires exact Ethernet redirect; flows stay on the normal Linux path";
+		return false;
+	}
+
+	if (entry->egress.nat.type != DPAA_FT_NAT_SNAT ||
+	    !entry->egress.nat.addr_valid) {
+		*reason = "hardware flow offloading requested, but the exact first supported class requires exact IPv4 SNAT; flows stay on the normal Linux path";
+		return false;
+	}
+
+	if (!dpaa_ft_egress_recipe_supports_outbound_encap(entry)) {
+		*reason = "hardware flow offloading requested, but the exact first supported class requires exact VLAN and PPPoE outbound encapsulation; flows stay on the normal Linux path";
+		return false;
+	}
+
+	if (entry->egress.vlan_push.vid != 10) {
+		*reason = "hardware flow offloading requested, but the exact first supported class only covers VLAN 10 push on the outbound primary path; flows stay on the normal Linux path";
+		return false;
+	}
+
+	if (!entry->egress.pppoe_push.sid) {
+		*reason = "hardware flow offloading requested, but the exact first supported class requires a non-zero PPPoE session on the outbound primary path; flows stay on the normal Linux path";
+		return false;
+	}
+
+	if (!dpaa_ft_fman_hw_resolve_exact_primary_egress(priv, entry, NULL,
+							  reason))
+		return false;
+
+	if (!priv->fman.rx.kg_scheme_free) {
+		*reason = "hardware flow offloading requested, but the exact first supported class found no free RX KeyGen scheme slots; flows stay on the normal Linux path";
+		return false;
+	}
+
+	return true;
+}
+
+static int
+dpaa_ft_fman_hw_build_request(struct dpaa_priv *priv,
+			      const struct dpaa_ft_entry *entry,
+			      struct dpaa_ft_hw_exact_egress_path *egress_path,
+			      struct fman_offload_request *req,
+			      const char **reason)
+{
+	memset(req, 0, sizeof(*req));
+	if (!dpaa_ft_fman_hw_resolve_exact_primary_egress(priv, entry,
+							  egress_path, reason))
+		return -EOPNOTSUPP;
+
+	req->cookie = entry->cookie;
+	req->exact_class =
+		FMAN_OFFLOAD_EXACT_CLASS_PRIMARY_OUTBOUND_ETH2_PPPOE_WAN;
+	req->binding.rx_port_id = priv->fman.rx.port_id;
+	req->binding.tx_port_id = egress_path->binding_priv->fman.tx.port_id;
+	req->binding.rx_pcd_base_fqid = priv->fman.rx_pcd_base_fqid;
+	req->binding.rx_pcd_fq_count = priv->fman.rx_pcd_fq_count;
+	req->network_proto = htons(entry->tuple.n_proto);
+	req->ip_proto = entry->tuple.ip_proto;
+	ether_addr_copy(req->src, entry->egress.l2.src);
+	ether_addr_copy(req->dst, entry->egress.l2.dst);
+	req->vlan_vid = entry->egress.vlan_push.vid;
+	req->vlan_proto = entry->egress.vlan_push.proto;
+	req->vlan_prio = entry->egress.vlan_push.prio;
+	req->pppoe_sid = entry->egress.pppoe_push.sid;
+	req->ppp_proto = dpaa_ft_egress_ppp_proto(entry);
+	req->snat_addr = entry->egress.nat.addr;
+	req->snat_port_valid = entry->egress.nat.port_valid;
+	req->snat_port = entry->egress.nat.port;
+	req->compiled_out_ifindex = egress_path->compiled_out_ifindex;
+	req->logical_out_ifindex = egress_path->logical_out_ifindex;
+	req->binding_ifindex = egress_path->binding_dev->ifindex;
+
+	return 0;
+}
+
+static int dpaa_ft_fman_hw_fail_install(struct dpaa_priv *priv,
+					struct dpaa_ft_hw_backend *hw,
+					struct dpaa_ft_hw_result *result,
+					int err, const char *message)
+{
+	hw->install_failures++;
+	hw->state = DPAA_FT_HW_BACKEND_INSTALL_FAILED;
+	hw->last_error = err;
+	dpaa_ft_hw_set_lifecycle(hw, DPAA_FT_HW_LIFECYCLE_FAILED);
+	result->state = hw->state;
+	result->lifecycle = hw->last_lifecycle;
+	result->degrade = DPAA_FT_HW_DEGRADE_INSTALL_FAILED;
+	result->reject_reason = DPAA_FT_REJECT_HW_INSTALL_FAILED;
+	result->err = err;
+	result->message = message;
+
+	return err;
+}
+
+static int dpaa_ft_fman_hw_run_exact_attempt(struct dpaa_priv *priv,
+					     const struct dpaa_ft_entry *entry,
+					     struct dpaa_ft_hw_backend *hw,
+					     struct dpaa_ft_hw_result *result)
+{
+	struct fman_offload_snapshot snapshot = {};
+	struct fman_offload_flow *flow = NULL;
+	struct dpaa_ft_hw_exact_egress_path egress_path = {};
+	struct fman_offload_request req;
+	const char *reason = NULL;
+	int err, remove_err;
+
+	dpaa_ft_hw_clear_staged_snapshot(hw);
+	hw->install_attempts++;
+	hw->state = DPAA_FT_HW_BACKEND_INSTALL_PENDING;
+	result->state = hw->state;
+
+	err = dpaa_ft_fman_hw_build_request(priv, entry, &egress_path, &req,
+					    &reason);
+	if (err)
+		return dpaa_ft_fman_hw_fail_install(
+			priv, hw, result, err,
+			reason ? reason :
+				 "hardware flow offloading requested, but the FMAN Stage 1 backend could not derive the exact-class FMAN binding request; flows stay on the normal Linux path");
+
+	err = fman_port_offload_prepare_exact(priv->mac_dev->port[RX],
+					      egress_path.binding_priv->mac_dev
+						      ->port[TX],
+					      &req, &flow, &snapshot);
+	if (err)
+		return dpaa_ft_fman_hw_fail_install(
+			priv, hw, result, err,
+			"hardware flow offloading requested, but the FMAN Stage 1 backend could not materialize the exact-class FMAN runtime objects; flows stay on the normal Linux path");
+
+	dpaa_ft_hw_cache_snapshot(hw, &snapshot);
+	dpaa_ft_hw_update_runtime_state(priv, hw);
+	result->lifecycle = hw->last_lifecycle;
+
+	err = fman_port_offload_activate(flow, &snapshot);
+	if (err == -EOPNOTSUPP) {
+		dpaa_ft_hw_cache_snapshot(hw, &snapshot);
+		result->lifecycle = hw->last_lifecycle;
+		result->degrade = DPAA_FT_HW_DEGRADE_LIVE_COMMIT_UNAVAILABLE;
+		result->reject_reason = DPAA_FT_REJECT_HW_LIVE_COMMIT_UNAVAILABLE;
+		result->err = err;
+		result->message = dpaa_ft_fman_hw_live_commit_unavailable_reason();
+		hw->last_error = err;
+	} else if (err) {
+		dpaa_ft_hw_cache_snapshot(hw, &snapshot);
+		dpaa_ft_fman_hw_fail_install(
+			priv, hw, result, err,
+			"hardware flow offloading requested, but the FMAN Stage 1 backend could not activate the exact-class FMAN runtime objects; flows stay on the normal Linux path");
+	} else {
+		dpaa_ft_hw_cache_snapshot(hw, &snapshot);
+		result->lifecycle = hw->last_lifecycle;
+		result->degrade = DPAA_FT_HW_DEGRADE_LIVE_COMMIT_UNAVAILABLE;
+		result->reject_reason = DPAA_FT_REJECT_HW_LIVE_COMMIT_UNAVAILABLE;
+		result->err = -EOPNOTSUPP;
+		result->message = "hardware flow offloading requested, but Stage 1 must not report live hardware residency until a resident forwarding path exists; flows stay on the normal Linux path";
+		hw->last_error = result->err;
+	}
+
+	remove_err = fman_port_offload_remove(flow, NULL);
+	dpaa_ft_hw_clear_staged_snapshot(hw);
+	dpaa_ft_hw_update_runtime_state(priv, hw);
+	if (remove_err)
+		return dpaa_ft_fman_hw_fail_install(
+			priv, hw, result, remove_err,
+			"hardware flow offloading requested, but the FMAN Stage 1 backend could not unwind the exact-class FMAN runtime objects after the install attempt; flows stay on the normal Linux path");
+
+	if (result->degrade == DPAA_FT_HW_DEGRADE_LIVE_COMMIT_UNAVAILABLE) {
+		hw->state = dpaa_ft_fman_hw_backend_ready(priv, hw) ?
+				    DPAA_FT_HW_BACKEND_READY :
+				    DPAA_FT_HW_BACKEND_DISABLED;
+		result->state = hw->state;
+		return result->err;
+	}
+
+	return result->err ? result->err : err;
+}
+
+static int dpaa_ft_fman_hw_dry_run(struct dpaa_priv *priv,
+				   const struct dpaa_ft_entry *entry,
+				   struct dpaa_ft_hw_backend *hw,
+				   struct dpaa_ft_hw_result *result)
+{
+	const char *reason = NULL;
+
+	memset(result, 0, sizeof(*result));
+	result->state = hw->state;
+	result->lifecycle = hw->last_lifecycle;
+	result->err = hw->last_error;
+	hw->dry_run_attempts++;
+
+	switch (hw->state) {
+	case DPAA_FT_HW_BACKEND_NOT_IMPLEMENTED:
+		result->degrade = DPAA_FT_HW_DEGRADE_NOT_IMPLEMENTED;
+		result->reject_reason = DPAA_FT_REJECT_HW_MODE_UNAVAILABLE;
+		result->err = -EOPNOTSUPP;
+		result->message = "hardware flow offloading requested, but the FMAN backend is not implemented in this build; flows stay on the normal Linux path";
+		return result->err;
+	case DPAA_FT_HW_BACKEND_DISABLED:
+		result->degrade = DPAA_FT_HW_DEGRADE_DISABLED;
+		result->reject_reason = DPAA_FT_REJECT_HW_BACKEND_DISABLED;
+		result->err = hw->last_error ? hw->last_error : -EOPNOTSUPP;
+		result->message = dpaa_ft_fman_hw_disabled_reason(priv);
+		return result->err;
+	default:
+		break;
+	}
+
+	if (!dpaa_ft_fman_hw_is_exact_primary_outbound(priv, entry, &reason)) {
+		hw->dry_run_not_lowerable++;
+		hw->last_dry_run = DPAA_FT_HW_DRY_RUN_NOT_LOWERABLE;
+		result->dry_run = DPAA_FT_HW_DRY_RUN_NOT_LOWERABLE;
+		result->degrade = DPAA_FT_HW_DEGRADE_EXACT_UNSUPPORTED;
+		result->reject_reason = DPAA_FT_REJECT_HW_NOT_LOWERABLE;
+		result->err = -EOPNOTSUPP;
+		result->message = reason;
+		hw->last_error = result->err;
+		return result->err;
+	}
+
+	hw->dry_run_lowerable++;
+	hw->last_dry_run = DPAA_FT_HW_DRY_RUN_LOWERABLE;
+	result->dry_run = DPAA_FT_HW_DRY_RUN_LOWERABLE;
+
+	return dpaa_ft_fman_hw_run_exact_attempt(priv, entry, hw, result);
+}
+
+static int dpaa_ft_fman_hw_install_exact(struct dpaa_priv *priv,
+					 struct dpaa_ft_entry *entry)
+{
+	struct dpaa_ft_hw_result result = {
+		.state = priv->ft.hw.state,
+		.lifecycle = priv->ft.hw.last_lifecycle,
+		.err = priv->ft.hw.last_error,
+	};
+	int err = dpaa_ft_fman_hw_dry_run(priv, entry, &priv->ft.hw, &result);
+
+	entry->hw.state = result.lifecycle;
+	entry->hw.last_error = result.err ? result.err : err;
+	entry->hw.generation = priv->ft.hw.last_staged.generation;
+	entry->hw.handle = NULL;
+
+	return result.err ? result.err : err;
+}
+
+static int dpaa_ft_fman_hw_remove_exact(struct dpaa_priv *priv,
+					struct dpaa_ft_entry *entry)
+{
+	struct dpaa_ft_hw_backend *hw = &priv->ft.hw;
+	struct fman_offload_snapshot snapshot = {};
+	int err;
+
+	hw->remove_attempts++;
+	if (!entry->hw.handle) {
+		hw->remove_failures++;
+		hw->last_error = -ENOENT;
+		dpaa_ft_hw_set_lifecycle(hw, DPAA_FT_HW_LIFECYCLE_FAILED);
+		entry->hw.state = hw->last_lifecycle;
+		entry->hw.last_error = -ENOENT;
+		return -ENOENT;
+	}
+
+	err = fman_port_offload_remove(entry->hw.handle, &snapshot);
+	if (err) {
+		hw->remove_failures++;
+		hw->last_error = err;
+		dpaa_ft_hw_set_lifecycle(hw, DPAA_FT_HW_LIFECYCLE_FAILED);
+		entry->hw.state = hw->last_lifecycle;
+		entry->hw.last_error = err;
+		return err;
+	}
+
+	entry->hw.handle = NULL;
+	dpaa_ft_hw_cache_snapshot(hw, &snapshot);
+	dpaa_ft_hw_clear_staged_snapshot(hw);
+	dpaa_ft_hw_update_runtime_state(priv, hw);
+	hw->state = dpaa_ft_fman_hw_backend_ready(priv, hw) ?
+			    DPAA_FT_HW_BACKEND_READY :
+			    DPAA_FT_HW_BACKEND_DISABLED;
+	hw->last_error = 0;
+	entry->hw.state = hw->last_lifecycle;
+	entry->hw.last_error = 0;
+	entry->hw.generation = snapshot.generation;
+
+	return 0;
+}
+
+static int dpaa_ft_fman_hw_stats_exact(struct dpaa_priv *priv,
+				       struct dpaa_ft_entry *entry)
+{
+	struct fman_offload_snapshot snapshot = {};
+	struct fman_offload_stats stats = {};
+	int err;
+
+	priv->ft.hw.stats_queries++;
+	if (!entry->hw.handle) {
+		priv->ft.hw.last_error = -ENOENT;
+		entry->hw.last_error = -ENOENT;
+		return -ENOENT;
+	}
+
+	err = fman_port_offload_get_stats(entry->hw.handle, &stats);
+	if (!fman_port_offload_get_snapshot(entry->hw.handle, &snapshot))
+		dpaa_ft_hw_cache_snapshot(&priv->ft.hw, &snapshot);
+	dpaa_ft_hw_update_runtime_state(priv, &priv->ft.hw);
+	priv->ft.hw.last_error = err;
+	entry->hw.last_error = err;
+
+	return err;
+}
