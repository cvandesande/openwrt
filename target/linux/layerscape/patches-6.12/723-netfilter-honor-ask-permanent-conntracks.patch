+/*
+ * ASK only needs to pin or unpin an already-existing installed conntrack.
+ * Handle that as a dedicated status-bit update instead of a broader state
+ * change so the control plane can make the entry permanent by id.
+ */
+static int ctnetlink_change_permanent(struct nf_conn *ct,
+				      const struct nlattr * const cda[])
+{
+	unsigned int status;
+	u32 id;
+	__be32 conntrack_id = ntohl((__force __be32)nf_ct_get_id(ct));
+
+	if (!cda[CTA_STATUS] || !cda[CTA_ID])
+		return -1;
+
+	status = ntohl(nla_get_be32(cda[CTA_STATUS]));
+	id = ntohl(nla_get_be32(cda[CTA_ID]));
+
+	if (conntrack_id != id)
+		return -ENOENT;
+
+	if (status & IPS_PERMANENT) {
+		ct->status |= IPS_PERMANENT;
+		return 0;
+	}
+
+	if (nf_ct_is_permanent(ct)) {
+		clear_bit(IPS_PERMANENT_BIT, &ct->status);
+		return 0;
+	}
+
+	return -1;
+}
