+struct dpaa_ft_tuple {
+	int ingress_ifindex;
+	u16 n_proto;
+	u8 ip_proto;
+	bool is_ipv6;
+	union {
+		struct {
+			__be32 src;
+			__be32 dst;
+		} v4;
+		struct {
+			struct in6_addr src;
+			struct in6_addr dst;
+		} v6;
+	};
+	__be16 src_port;
+	__be16 dst_port;
+};
+
+struct dpaa_ft_l2 {
