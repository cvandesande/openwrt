+					struct device_attribute *attr,
+					char *buf)
+{
+	struct dpaa_priv *priv = netdev_priv(to_net_dev(dev));
+	ssize_t bytes = 0;
+	int i;
+
+	mutex_lock(&priv->ft.lock);
+	bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes, "active %lu\n",
+			   priv->ft.active);
+	bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes, "installs %llu\n",
+			   priv->ft.installs);
+	bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes, "destroys %llu\n",
+			   priv->ft.destroys);
+	bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes, "stats %llu\n",
+			   priv->ft.stats_queries);
+	bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes, "hits %lld\n",
+			   atomic64_read(&priv->ft.hits));
+
+	for (i = 0; i < DPAA_FT_REJECT_MAX && bytes < PAGE_SIZE; i++) {
+		if (!priv->ft.rejects[i] || !dpaa_ft_reject_names[i])
+			continue;
+
+		bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes,
+				   "reject.%s %llu\n",
+				   dpaa_ft_reject_names[i],
+				   priv->ft.rejects[i]);
+	}
+
+	for (i = 0; i < DPAA_FT_FALLBACK_MAX && bytes < PAGE_SIZE; i++) {
+		s64 count;
+
+		if (!dpaa_ft_fallback_names[i])
+			continue;
+
+		count = atomic64_read(&priv->ft.fallbacks[i]);
+		if (!count)
+			continue;
+
+		bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes,
+				   "fallback.%s %lld\n",
+				   dpaa_ft_fallback_names[i], count);
+	}
+	mutex_unlock(&priv->ft.lock);
+
+	return bytes;
+}
+
 static struct device_attribute dpaa_eth_attrs[] = {
 	__ATTR(device_addr, 0444, dpaa_eth_show_addr, NULL),
 	__ATTR(fqids, 0444, dpaa_eth_show_fqids, NULL),
 	__ATTR(bpids, 0444, dpaa_eth_show_bpids, NULL),
+	__ATTR(ft_offload, 0444, dpaa_eth_show_ft_offload, NULL),
 };
 
