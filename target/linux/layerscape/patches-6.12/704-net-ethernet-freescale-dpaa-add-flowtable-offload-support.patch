+static LIST_HEAD(dpaa_ft_block_cb_list);
+
+static u16 dpaa_ft_tcp_flags_mask(void)
+{
+	return cpu_to_be16(TCPHDR_FIN | TCPHDR_RST);
+}
+
+static u32 dpaa_ft_tuple_hash(const struct dpaa_ft_tuple *tuple)
+{
+	struct {
+		int ingress_ifindex;
+		u16 n_proto;
+		u8 ip_proto;
+		u8 is_ipv6;
+		__be16 src_port;
+		__be16 dst_port;
+	} key = {
+		.ingress_ifindex = tuple->ingress_ifindex,
+		.n_proto = tuple->n_proto,
+		.ip_proto = tuple->ip_proto,
+		.is_ipv6 = tuple->is_ipv6,
+		.src_port = tuple->src_port,
+		.dst_port = tuple->dst_port,
+	};
+	u32 hash;
+
+	hash = jhash(&key, sizeof(key), 0);
+
+	if (tuple->is_ipv6)
+		return jhash(&tuple->v6, sizeof(tuple->v6), hash);
+
+	return jhash(&tuple->v4, sizeof(tuple->v4), hash);
+}
+
+static bool dpaa_ft_tuple_equal(const struct dpaa_ft_tuple *a,
+				const struct dpaa_ft_tuple *b)
+{
+	if (a->ingress_ifindex != b->ingress_ifindex ||
+	    a->n_proto != b->n_proto ||
+	    a->ip_proto != b->ip_proto ||
+	    a->is_ipv6 != b->is_ipv6 ||
+	    a->src_port != b->src_port ||
+	    a->dst_port != b->dst_port)
+		return false;
+
+	if (a->is_ipv6)
+		return !memcmp(&a->v6, &b->v6, sizeof(a->v6));
+
+	return a->v4.src == b->v4.src && a->v4.dst == b->v4.dst;
+}
+
+static struct dpaa_ft_entry *dpaa_ft_lookup_locked(struct dpaa_priv *priv,
+						   unsigned long cookie)
+{
+	struct dpaa_ft_entry *entry;
+
+	hash_for_each_possible(priv->ft.flows, entry, node, cookie) {
+		if (entry->cookie == cookie)
+			return entry;
+	}
+
+	return NULL;
+}
+
+static struct dpaa_ft_entry *
+dpaa_ft_lookup_tuple_locked(struct dpaa_priv *priv,
+			    const struct dpaa_ft_tuple *tuple, u32 tuple_hash)
+{
+	struct dpaa_ft_entry *entry;
+
+	hash_for_each_possible(priv->ft.tuple_flows, entry, tuple_node,
+			       tuple_hash) {
+		if (entry->tuple_hash == tuple_hash &&
+		    dpaa_ft_tuple_equal(&entry->tuple, tuple))
+			return entry;
+	}
+
+	return NULL;
+}
+
+static struct dpaa_ft_entry *
+dpaa_ft_lookup_tuple_rcu(struct dpaa_priv *priv,
+			 const struct dpaa_ft_tuple *tuple, u32 tuple_hash)
+{
+	struct dpaa_ft_entry *entry;
+
+	hash_for_each_possible_rcu(priv->ft.tuple_flows, entry, tuple_node,
+				   tuple_hash) {
+		if (entry->tuple_hash == tuple_hash &&
+		    dpaa_ft_tuple_equal(&entry->tuple, tuple))
+			return entry;
+	}
+
+	return NULL;
+}
+
+static int dpaa_ft_reject_locked(struct dpaa_priv *priv,
+				 struct flow_cls_offload *cls,
+				 enum dpaa_ft_reject_reason reason,
+				 int err, const char *msg)
+{
+	if (reason < DPAA_FT_REJECT_MAX)
+		priv->ft.rejects[reason]++;
+
+	if (msg)
+		NL_SET_ERR_MSG_FMT_MOD(cls->common.extack, "%s", msg);
+
+	return err;
+}
+
+static int dpaa_ft_mangle_eth(struct dpaa_ft_entry *entry,
+			      const struct flow_action_entry *act)
+{
+	if (act->mangle.offset == 0 &&
+	    act->mangle.mask == ~htonl(0xffffffff)) {
+		memcpy(entry->l2.dst, &act->mangle.val, 4);
+		entry->l2.dst_mask |= 0x0f;
+		return 0;
+	}
+
+	if (act->mangle.offset == 4 &&
+	    act->mangle.mask == ~htonl(0x0000ffff)) {
+		memcpy(entry->l2.dst + 4, &act->mangle.val, 2);
+		entry->l2.dst_mask |= 0x30;
+		return 0;
+	}
+
+	if (act->mangle.offset == 4 &&
+	    act->mangle.mask == ~htonl(0xffff0000)) {
+		memcpy(entry->l2.src, (u8 *)&act->mangle.val + 2, 2);
+		entry->l2.src_mask |= 0x03;
+		return 0;
+	}
+
+	if (act->mangle.offset == 8 &&
+	    act->mangle.mask == ~htonl(0xffffffff)) {
+		memcpy(entry->l2.src + 2, &act->mangle.val, 4);
+		entry->l2.src_mask |= 0x3c;
+		return 0;
+	}
+
+	return -EOPNOTSUPP;
+}
+
+static int dpaa_ft_mangle_ip4(struct dpaa_ft_entry *entry,
+			      const struct flow_action_entry *act)
+{
+	if (entry->tuple.is_ipv6 ||
+	    act->mangle.mask != ~htonl(0xffffffff))
+		return -EOPNOTSUPP;
+
+	switch (act->mangle.offset) {
+	case offsetof(struct iphdr, saddr):
+		if (entry->nat.type == DPAA_FT_NAT_DNAT)
+			return -EOPNOTSUPP;
+		entry->nat.type = DPAA_FT_NAT_SNAT;
+		entry->nat.addr = (__force __be32)act->mangle.val;
+		entry->nat.addr_valid = true;
+		return 0;
+	case offsetof(struct iphdr, daddr):
+		if (entry->nat.type == DPAA_FT_NAT_SNAT)
+			return -EOPNOTSUPP;
+		entry->nat.type = DPAA_FT_NAT_DNAT;
+		entry->nat.addr = (__force __be32)act->mangle.val;
+		entry->nat.addr_valid = true;
+		return 0;
+	default:
+		return -EOPNOTSUPP;
+	}
+}
+
+static int dpaa_ft_mangle_l4_port(struct dpaa_ft_entry *entry,
+				  const struct flow_action_entry *act)
+{
+	u32 val;
+
+	if (act->mangle.offset != 0)
+		return -EOPNOTSUPP;
+
+	val = ntohl(act->mangle.val);
+
+	switch (act->mangle.mask) {
+	case ~htonl(0xffff0000):
+		if (entry->nat.type == DPAA_FT_NAT_DNAT)
+			return -EOPNOTSUPP;
+		entry->nat.type = DPAA_FT_NAT_SNAT;
+		entry->nat.port = cpu_to_be16(val >> 16);
+		entry->nat.port_valid = true;
+		return 0;
+	case ~htonl(0xffff):
+		if (entry->nat.type == DPAA_FT_NAT_SNAT)
+			return -EOPNOTSUPP;
+		entry->nat.type = DPAA_FT_NAT_DNAT;
+		entry->nat.port = cpu_to_be16(val);
+		entry->nat.port_valid = true;
+		return 0;
+	default:
+		return -EOPNOTSUPP;
+	}
+}
+
+static u32 dpaa_ft_expected_csum_flags(const struct dpaa_ft_entry *entry)
+{
+	u32 flags = 0;
+
+	if (entry->nat.type == DPAA_FT_NAT_NONE || entry->tuple.is_ipv6)
+		return 0;
+
+	flags |= TCA_CSUM_UPDATE_FLAG_IPV4HDR;
+
+	switch (entry->tuple.ip_proto) {
+	case IPPROTO_TCP:
+		flags |= TCA_CSUM_UPDATE_FLAG_TCP;
+		break;
+	case IPPROTO_UDP:
+		flags |= TCA_CSUM_UPDATE_FLAG_UDP;
+		break;
+	default:
+		break;
+	}
+
+	return flags;
+}
+
+static int dpaa_ft_compile_match(struct dpaa_priv *priv,
+				 struct flow_cls_offload *cls,
+				 struct dpaa_ft_entry *entry)
+{
+	struct flow_rule *rule = flow_cls_offload_flow_rule(cls);
+
+	if (!flow_rule_match_key(rule, FLOW_DISSECTOR_KEY_META))
+		return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_MISSING_META,
+					     -EOPNOTSUPP,
+					     "Missing ingress metadata");
+
+	if (!flow_rule_match_key(rule, FLOW_DISSECTOR_KEY_CONTROL) ||
+	    !flow_rule_match_key(rule, FLOW_DISSECTOR_KEY_BASIC) ||
+	    !flow_rule_match_key(rule, FLOW_DISSECTOR_KEY_PORTS))
+		return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_MISSING_MATCH,
+					     -EOPNOTSUPP,
+					     "Missing stock flowtable match keys");
+
+	if (flow_rule_match_key(rule, FLOW_DISSECTOR_KEY_VLAN) ||
+	    flow_rule_match_key(rule, FLOW_DISSECTOR_KEY_CVLAN) ||
+	    flow_rule_match_key(rule, FLOW_DISSECTOR_KEY_PPPOE) ||
+	    flow_rule_match_key(rule, FLOW_DISSECTOR_KEY_ENC_CONTROL) ||
+	    flow_rule_match_key(rule, FLOW_DISSECTOR_KEY_ENC_KEYID) ||
+	    flow_rule_match_key(rule, FLOW_DISSECTOR_KEY_ENC_IPV4_ADDRS) ||
+	    flow_rule_match_key(rule, FLOW_DISSECTOR_KEY_ENC_IPV6_ADDRS) ||
+	    flow_rule_match_key(rule, FLOW_DISSECTOR_KEY_ENC_PORTS))
+		return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_UNSUPPORTED_ENCAP_MATCH,
+					     -EOPNOTSUPP,
+					     "VLAN, PPPoE, and tunnel match keys are not supported");
+
+	{
+		struct flow_match_meta match;
+
+		flow_rule_match_meta(rule, &match);
+		entry->tuple.ingress_ifindex = match.key->ingress_ifindex;
+	}
+
+	{
+		struct flow_match_control match;
+
+		flow_rule_match_control(rule, &match);
+		if (flow_rule_has_control_flags(match.mask->flags,
+						cls->common.extack))
+			return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_UNSUPPORTED_ACTION,
+					     -EOPNOTSUPP, NULL);
+
+		switch (match.key->addr_type) {
+		case FLOW_DISSECTOR_KEY_IPV4_ADDRS:
+			if (!flow_rule_match_key(rule,
+						 FLOW_DISSECTOR_KEY_IPV4_ADDRS))
+				return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_MISSING_MATCH,
+					     -EOPNOTSUPP,
+					     "Missing IPv4 addresses");
+			entry->tuple.is_ipv6 = false;
+			break;
+		case FLOW_DISSECTOR_KEY_IPV6_ADDRS:
+			if (!flow_rule_match_key(rule,
+						 FLOW_DISSECTOR_KEY_IPV6_ADDRS))
+				return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_MISSING_MATCH,
+					     -EOPNOTSUPP,
+					     "Missing IPv6 addresses");
+			entry->tuple.is_ipv6 = true;
+			break;
+		default:
+			return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_UNSUPPORTED_FAMILY,
+					     -EOPNOTSUPP,
+					     "Only routed IPv4 and IPv6 flows are supported");
+		}
+	}
+
+	{
+		struct flow_match_basic match;
+
+		flow_rule_match_basic(rule, &match);
+		entry->tuple.n_proto = ntohs(match.key->n_proto);
+		entry->tuple.ip_proto = match.key->ip_proto;
+
+		if (!entry->tuple.is_ipv6 &&
+		    match.key->n_proto != htons(ETH_P_IP))
+			return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_UNSUPPORTED_FAMILY,
+					     -EOPNOTSUPP,
+					     "Unexpected L3 protocol for IPv4 flow");
+		if (entry->tuple.is_ipv6 &&
+		    match.key->n_proto != htons(ETH_P_IPV6))
+			return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_UNSUPPORTED_FAMILY,
+					     -EOPNOTSUPP,
+					     "Unexpected L3 protocol for IPv6 flow");
+
+		if (match.key->ip_proto != IPPROTO_TCP &&
+		    match.key->ip_proto != IPPROTO_UDP)
+			return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_UNSUPPORTED_L4PROTO,
+					     -EOPNOTSUPP,
+					     "Only TCP and UDP flows are supported");
+	}
+
+	{
+		struct flow_match_ports match;
+
+		flow_rule_match_ports(rule, &match);
+		entry->tuple.src_port = match.key->src;
+		entry->tuple.dst_port = match.key->dst;
+	}
+
+	if (flow_rule_match_key(rule, FLOW_DISSECTOR_KEY_TCP)) {
+		struct flow_match_tcp match;
+
+		flow_rule_match_tcp(rule, &match);
+		if (match.key->flags != 0 ||
+		    match.mask->flags != dpaa_ft_tcp_flags_mask())
+			return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_UNSUPPORTED_TCP_FLAGS,
+					     -EOPNOTSUPP,
+					     "Unexpected TCP flag match");
+	}
+
+	if (entry->tuple.is_ipv6) {
+		struct flow_match_ipv6_addrs match;
+
+		flow_rule_match_ipv6_addrs(rule, &match);
+		entry->tuple.v6.src = match.key->src;
+		entry->tuple.v6.dst = match.key->dst;
+	} else {
+		struct flow_match_ipv4_addrs match;
+
+		flow_rule_match_ipv4_addrs(rule, &match);
+		entry->tuple.v4.src = match.key->src;
+		entry->tuple.v4.dst = match.key->dst;
+	}
+
+	return 0;
+}
+
+static int dpaa_ft_compile_actions(struct dpaa_priv *priv,
+				   struct flow_cls_offload *cls,
+				   struct dpaa_ft_entry *entry)
+{
+	struct flow_rule *rule = flow_cls_offload_flow_rule(cls);
+	bool have_redirect = false, have_csum = false;
+	const struct flow_action_entry *act;
+	int i, err;
+
+	flow_action_for_each(i, act, &rule->action) {
+		switch (act->id) {
+		case FLOW_ACTION_MANGLE:
+			switch (act->mangle.htype) {
+			case FLOW_ACT_MANGLE_HDR_TYPE_ETH:
+				err = dpaa_ft_mangle_eth(entry, act);
+				if (err)
+					return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_UNSUPPORTED_ACTION,
+					     err,
+					     "Unsupported Ethernet rewrite");
+				break;
+			case FLOW_ACT_MANGLE_HDR_TYPE_IP4:
+				err = dpaa_ft_mangle_ip4(entry, act);
+				if (err)
+					return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_UNSUPPORTED_NAT,
+					     err,
+					     "Only exact IPv4 NAT is supported");
+				break;
+			case FLOW_ACT_MANGLE_HDR_TYPE_TCP:
+			case FLOW_ACT_MANGLE_HDR_TYPE_UDP:
+				err = dpaa_ft_mangle_l4_port(entry, act);
+				if (err)
+					return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_UNSUPPORTED_NAT,
+					     err,
+					     "Unsupported TCP/UDP port rewrite");
+				break;
+			default:
+				return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_UNSUPPORTED_ACTION,
+					     -EOPNOTSUPP,
+					     "Unsupported action mangle type");
+			}
+			break;
+		case FLOW_ACTION_CSUM:
+			entry->nat.csum_flags = act->csum_flags;
+			have_csum = true;
+			break;
+		case FLOW_ACTION_REDIRECT:
+			if (have_redirect)
+				return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_UNSUPPORTED_ACTION,
+					     -EOPNOTSUPP,
+					     "Multiple redirect actions are not supported");
+			entry->out_dev = act->dev;
+			entry->out_ifindex = act->dev->ifindex;
+			have_redirect = true;
+			break;
+		case FLOW_ACTION_VLAN_POP:
+		case FLOW_ACTION_VLAN_PUSH:
+		case FLOW_ACTION_PPPOE_PUSH:
+			return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_UNSUPPORTED_ENCAP_ACTION,
+					     -EOPNOTSUPP,
+					     "VLAN and PPPoE actions are not supported");
+		default:
+			return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_UNSUPPORTED_ACTION,
+					     -EOPNOTSUPP,
+					     "Unsupported flowtable action");
+		}
+	}
+
+	if (!have_redirect || !entry->out_dev)
+		return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_MISSING_REDIRECT,
+					     -EOPNOTSUPP,
+					     "Missing egress redirect");
+
+	if (entry->l2.src_mask != 0x3f || entry->l2.dst_mask != 0x3f)
+		return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_MISSING_MATCH,
+					     -EOPNOTSUPP,
+					     "Missing exact L2 rewrite");
+
+	if (entry->nat.type != DPAA_FT_NAT_NONE) {
+		u32 expected_csum;
+
+		if (entry->tuple.is_ipv6)
+			return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_UNSUPPORTED_NAT,
+					     -EOPNOTSUPP,
+					     "IPv6 NAT is not supported");
+
+		expected_csum = dpaa_ft_expected_csum_flags(entry);
+		if (!have_csum || entry->nat.csum_flags != expected_csum)
+			return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_UNSUPPORTED_CSUM,
+					     -EOPNOTSUPP,
+					     "Unexpected checksum action for NAT flow");
+	} else if (have_csum) {
+		return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_UNSUPPORTED_CSUM,
+					     -EOPNOTSUPP,
+					     "Checksum action without NAT is not supported");
+	}
+
+	dev_hold(entry->out_dev);
+	entry->stats.used_hw_stats = FLOW_ACTION_HW_STATS_DELAYED;
+	entry->stats.used_hw_stats_valid = true;
+
+	return 0;
+}
+
+static int dpaa_ft_compile_flow(struct dpaa_priv *priv,
+				struct flow_cls_offload *cls,
+				struct dpaa_ft_entry *entry)
+{
+	int err;
+
+	err = dpaa_ft_compile_match(priv, cls, entry);
+	if (err)
+		return err;
+
+	return dpaa_ft_compile_actions(priv, cls, entry);
+}
+
+static void dpaa_ft_put_entry(struct dpaa_ft_entry *entry)
+{
+	if (entry->out_dev)
+		dev_put(entry->out_dev);
+	kfree(entry);
+}
+
+static void dpaa_ft_put_entry_rcu(struct rcu_head *rcu)
+{
+	struct dpaa_ft_entry *entry;
+
+	entry = container_of(rcu, struct dpaa_ft_entry, rcu);
+	dpaa_ft_put_entry(entry);
+}
+
+static void dpaa_ft_count_fallback(struct dpaa_priv *priv,
+				   enum dpaa_ft_fallback_reason reason)
+{
+	if (reason < DPAA_FT_FALLBACK_MAX)
+		atomic64_inc(&priv->ft.fallbacks[reason]);
+}
+
+static void dpaa_ft_count_hit(struct dpaa_priv *priv,
+			      struct dpaa_ft_entry *entry,
+			      unsigned int len)
+{
+	atomic64_inc(&priv->ft.hits);
+	atomic64_inc(&entry->packets);
+	atomic64_add(len, &entry->bytes);
+	atomic64_set(&entry->lastused, jiffies);
+}
+
+static int dpaa_ft_parse_packet(struct sk_buff *skb, int ingress_ifindex,
+				struct dpaa_ft_tuple *tuple,
+				unsigned int *l4_off)
+{
+	const struct ipv6hdr *ip6h;
+	const struct tcphdr *tcph;
+	const struct ethhdr *eth;
+	const struct udphdr *udph;
+	const struct iphdr *iph;
+
+	memset(tuple, 0, sizeof(*tuple));
+	tuple->ingress_ifindex = ingress_ifindex;
+
+	if (!pskb_may_pull(skb, ETH_HLEN))
+		return -ENOENT;
+
+	skb_reset_mac_header(skb);
+	eth = eth_hdr(skb);
+
+	if (skb_vlan_tag_present(skb))
+		return -ENOENT;
+
+	switch (eth->h_proto) {
+	case htons(ETH_P_8021Q):
+	case htons(ETH_P_8021AD):
+	case htons(ETH_P_PPP_SES):
+		return -ENOENT;
+	case htons(ETH_P_IP):
+		if (!pskb_may_pull(skb, ETH_HLEN + sizeof(*iph)))
+			return -ENOENT;
+
+		iph = (struct iphdr *)(skb->data + ETH_HLEN);
+		if (iph->ihl < sizeof(*iph) / 4)
+			return -ENOENT;
+		if (iph->protocol != IPPROTO_TCP &&
+		    iph->protocol != IPPROTO_UDP)
+			return -ENOENT;
+
+		tuple->n_proto = ETH_P_IP;
+		tuple->ip_proto = iph->protocol;
+		tuple->v4.src = iph->saddr;
+		tuple->v4.dst = iph->daddr;
+		*l4_off = ETH_HLEN + iph->ihl * 4;
+		if (!pskb_may_pull(skb, *l4_off +
+				   (tuple->ip_proto == IPPROTO_TCP ?
+				    sizeof(*tcph) : sizeof(*udph))))
+			return -ENOENT;
+		break;
+	case htons(ETH_P_IPV6):
+		if (!pskb_may_pull(skb, ETH_HLEN + sizeof(*ip6h)))
+			return -ENOENT;
+
+		ip6h = (struct ipv6hdr *)(skb->data + ETH_HLEN);
+		if (ip6h->nexthdr != IPPROTO_TCP &&
+		    ip6h->nexthdr != IPPROTO_UDP)
+			return -ENOENT;
+
+		tuple->n_proto = ETH_P_IPV6;
+		tuple->ip_proto = ip6h->nexthdr;
+		tuple->is_ipv6 = true;
+		tuple->v6.src = ip6h->saddr;
+		tuple->v6.dst = ip6h->daddr;
+		*l4_off = ETH_HLEN + sizeof(*ip6h);
+		if (!pskb_may_pull(skb, *l4_off +
+				   (tuple->ip_proto == IPPROTO_TCP ?
+				    sizeof(*tcph) : sizeof(*udph))))
+			return -ENOENT;
+		break;
+	default:
+		return -ENOENT;
+	}
+
+	if (tuple->ip_proto == IPPROTO_TCP) {
+		tcph = (struct tcphdr *)(skb->data + *l4_off);
+		tuple->src_port = tcph->source;
+		tuple->dst_port = tcph->dest;
+	} else {
+		udph = (struct udphdr *)(skb->data + *l4_off);
+		tuple->src_port = udph->source;
+		tuple->dst_port = udph->dest;
+	}
+
+	return 0;
+}
+
+static bool dpaa_ft_skb_supported(const struct dpaa_ft_entry *entry,
+				  const struct sk_buff *skb,
+				  unsigned int l4_off)
+{
+	if (entry->tuple.ip_proto == IPPROTO_TCP) {
+		const struct tcphdr *tcph;
+
+		tcph = (const struct tcphdr *)(skb->data + l4_off);
+		if (tcph->fin || tcph->rst)
+			return false;
+	}
+
+	if (entry->tuple.is_ipv6) {
+		const struct ipv6hdr *ip6h;
+
+		if (l4_off != ETH_HLEN + sizeof(*ip6h))
+			return false;
+
+		ip6h = (const struct ipv6hdr *)(skb->data + ETH_HLEN);
+		return ip6h->hop_limit > 1;
+	}
+
+	{
+		const struct iphdr *iph;
+
+		iph = (const struct iphdr *)(skb->data + ETH_HLEN);
+		if (iph->ihl != sizeof(*iph) / 4 || ip_is_fragment(iph))
+			return false;
+
+		return iph->ttl > 1;
+	}
+}
+
+static void dpaa_ft_maybe_update_l4_addr(struct sk_buff *skb,
+					 const struct dpaa_ft_entry *entry,
+					 __be32 old_addr, __be32 new_addr,
+					 unsigned int l4_off)
+{
+	if (entry->tuple.ip_proto == IPPROTO_TCP) {
+		struct tcphdr *tcph = (struct tcphdr *)(skb->data + l4_off);
+
+		inet_proto_csum_replace4(&tcph->check, skb, old_addr, new_addr,
+					 false);
+		return;
+	}
+
+	{
+		struct udphdr *udph = (struct udphdr *)(skb->data + l4_off);
+
+		if (udph->check)
+			inet_proto_csum_replace4(&udph->check, skb, old_addr,
+						 new_addr, false);
+	}
+}
+
+static void dpaa_ft_maybe_update_l4_port(struct sk_buff *skb,
+					 const struct dpaa_ft_entry *entry,
+					 __be16 old_port, __be16 new_port,
+					 unsigned int l4_off)
+{
+	if (entry->tuple.ip_proto == IPPROTO_TCP) {
+		struct tcphdr *tcph = (struct tcphdr *)(skb->data + l4_off);
+
+		inet_proto_csum_replace2(&tcph->check, skb, old_port, new_port,
+					 false);
+		return;
+	}
+
+	{
+		struct udphdr *udph = (struct udphdr *)(skb->data + l4_off);
+
+		if (udph->check)
+			inet_proto_csum_replace2(&udph->check, skb, old_port,
+						 new_port, false);
+	}
+}
+
+static bool dpaa_ft_try_forward(struct dpaa_priv *priv,
+				struct rtnl_link_stats64 *percpu_stats,
+				struct sk_buff *skb)
+{
+	struct dpaa_ft_tuple tuple;
+	struct dpaa_ft_entry *entry;
+	unsigned int l4_off;
+	struct sk_buff *fwd_skb;
+	struct ethhdr *eth;
+	u32 tuple_hash;
+	int err;
+
+	if (!READ_ONCE(priv->ft.active))
+		return false;
+
+	err = dpaa_ft_parse_packet(skb, priv->net_dev->ifindex, &tuple, &l4_off);
+	if (err)
+		return false;
+
+	tuple_hash = dpaa_ft_tuple_hash(&tuple);
+
+	rcu_read_lock();
+	entry = dpaa_ft_lookup_tuple_rcu(priv, &tuple, tuple_hash);
+	if (!entry) {
+		rcu_read_unlock();
+		return false;
+	}
+
+	if (!dpaa_ft_skb_supported(entry, skb, l4_off)) {
+		dpaa_ft_count_fallback(priv, DPAA_FT_FALLBACK_PACKET);
+		rcu_read_unlock();
+		return false;
+	}
+
+	fwd_skb = skb_copy_expand(skb, LL_RESERVED_SPACE(entry->out_dev),
+				  entry->out_dev->needed_tailroom,
+				  GFP_ATOMIC);
+	if (!fwd_skb) {
+		dpaa_ft_count_fallback(priv, DPAA_FT_FALLBACK_NO_MEMORY);
+		rcu_read_unlock();
+		return false;
+	}
+
+	skb_scrub_packet(fwd_skb,
+			 !net_eq(dev_net(entry->out_dev), dev_net(priv->net_dev)));
+	skb_orphan(fwd_skb);
+	skb_set_queue_mapping(fwd_skb, 0);
+	skb_reset_mac_header(fwd_skb);
+	skb_set_network_header(fwd_skb, ETH_HLEN);
+	skb_set_transport_header(fwd_skb, l4_off);
+	fwd_skb->mac_len = ETH_HLEN;
+	fwd_skb->dev = entry->out_dev;
+	fwd_skb->priority = 0;
+	fwd_skb->ip_summed = CHECKSUM_NONE;
+
+	eth = eth_hdr(fwd_skb);
+	memcpy(eth->h_source, entry->l2.src, ETH_ALEN);
+	memcpy(eth->h_dest, entry->l2.dst, ETH_ALEN);
+
+	if (entry->tuple.is_ipv6) {
+		struct ipv6hdr *ip6h = ipv6_hdr(fwd_skb);
+
+		ip6h->hop_limit--;
+	} else {
+		struct iphdr *iph = ip_hdr(fwd_skb);
+
+		ip_decrease_ttl(iph);
+
+		if (entry->nat.addr_valid) {
+			__be32 old_addr;
+
+			if (entry->nat.type == DPAA_FT_NAT_SNAT) {
+				old_addr = iph->saddr;
+				iph->saddr = entry->nat.addr;
+			} else {
+				old_addr = iph->daddr;
+				iph->daddr = entry->nat.addr;
+			}
+
+			csum_replace4(&iph->check, old_addr, entry->nat.addr);
+			dpaa_ft_maybe_update_l4_addr(fwd_skb, entry, old_addr,
+						     entry->nat.addr, l4_off);
+		}
+
+		if (entry->nat.port_valid) {
+			__be16 old_port;
+
+			if (entry->tuple.ip_proto == IPPROTO_TCP) {
+				struct tcphdr *tcph = tcp_hdr(fwd_skb);
+
+				if (entry->nat.type == DPAA_FT_NAT_SNAT) {
+					old_port = tcph->source;
+					tcph->source = entry->nat.port;
+				} else {
+					old_port = tcph->dest;
+					tcph->dest = entry->nat.port;
+				}
+			} else {
+				struct udphdr *udph = udp_hdr(fwd_skb);
+
+				if (entry->nat.type == DPAA_FT_NAT_SNAT) {
+					old_port = udph->source;
+					udph->source = entry->nat.port;
+				} else {
+					old_port = udph->dest;
+					udph->dest = entry->nat.port;
+				}
+			}
+
+			dpaa_ft_maybe_update_l4_port(fwd_skb, entry, old_port,
+						     entry->nat.port, l4_off);
+		}
+	}
+
+	fwd_skb->protocol = htons(entry->tuple.n_proto);
+
+	err = dev_queue_xmit(fwd_skb);
+	if (unlikely(net_xmit_eval(err))) {
+		/* Preserve the original skb for the normal slow path. */
+		dpaa_ft_count_fallback(priv, DPAA_FT_FALLBACK_TX_ERROR);
+		rcu_read_unlock();
+		return false;
+	}
+
+	dpaa_ft_count_hit(priv, entry, skb->len);
+	percpu_stats->rx_packets++;
+	percpu_stats->rx_bytes += skb->len;
+	rcu_read_unlock();
+
+	consume_skb(skb);
+	return true;
+}
+
+static void dpaa_ft_destroy_all(struct dpaa_priv *priv)
+{
+	struct dpaa_ft_entry *entry;
+	struct hlist_node *tmp;
+	int bkt;
+
+	mutex_lock(&priv->ft.lock);
+	hash_for_each_safe(priv->ft.flows, bkt, tmp, entry, node) {
+		hash_del(&entry->node);
+		hash_del_rcu(&entry->tuple_node);
+		call_rcu(&entry->rcu, dpaa_ft_put_entry_rcu);
+	}
+	priv->ft.active = 0;
+	mutex_unlock(&priv->ft.lock);
+}
+
+static int dpaa_ft_replace(struct dpaa_priv *priv, struct flow_cls_offload *cls)
+{
+	struct dpaa_ft_entry *entry;
+	int err;
+
+	if (dpaa_ft_lookup_locked(priv, cls->cookie))
+		return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_DUPLICATE_COOKIE,
+					     -EEXIST,
+					     "Flow cookie is already installed");
+
+	entry = kzalloc(sizeof(*entry), GFP_KERNEL);
+	if (!entry)
+		return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_NO_MEMORY,
+					     -ENOMEM,
+					     "Unable to allocate compiled flow");
+
+	entry->cookie = cls->cookie;
+
+	err = dpaa_ft_compile_flow(priv, cls, entry);
+	if (err) {
+		dpaa_ft_put_entry(entry);
+		return err;
+	}
+
+	entry->tuple_hash = dpaa_ft_tuple_hash(&entry->tuple);
+	if (dpaa_ft_lookup_tuple_locked(priv, &entry->tuple, entry->tuple_hash)) {
+		dpaa_ft_put_entry(entry);
+		return dpaa_ft_reject_locked(priv, cls,
+					     DPAA_FT_REJECT_DUPLICATE_TUPLE,
+					     -EEXIST,
+					     "Flow tuple is already installed");
+	}
+
+	hash_add(priv->ft.flows, &entry->node, entry->cookie);
+	hash_add_rcu(priv->ft.tuple_flows, &entry->tuple_node,
+		     entry->tuple_hash);
+	priv->ft.installs++;
+	priv->ft.active++;
+
+	return 0;
+}
+
+static int dpaa_ft_destroy(struct dpaa_priv *priv, struct flow_cls_offload *cls)
+{
+	struct dpaa_ft_entry *entry;
+
+	entry = dpaa_ft_lookup_locked(priv, cls->cookie);
+	if (!entry)
+		return -ENOENT;
+
+	hash_del(&entry->node);
+	hash_del_rcu(&entry->tuple_node);
+	if (priv->ft.active)
+		priv->ft.active--;
+	priv->ft.destroys++;
+	call_rcu(&entry->rcu, dpaa_ft_put_entry_rcu);
+
+	return 0;
+}
+
+static int dpaa_ft_stats(struct dpaa_priv *priv, struct flow_cls_offload *cls)
+{
+	struct dpaa_ft_entry *entry;
+
+	entry = dpaa_ft_lookup_locked(priv, cls->cookie);
+	if (!entry)
+		return -ENOENT;
+
+	cls->stats = entry->stats;
+	cls->stats.pkts = atomic64_read(&entry->packets);
+	cls->stats.bytes = atomic64_read(&entry->bytes);
+	cls->stats.lastused = atomic64_read(&entry->lastused);
+	/* TX errors fall back to the slow path and are not packet drops. */
+	cls->stats.drops = 0;
+	priv->ft.stats_queries++;
+
+	return 0;
+}
+
+static int dpaa_ft_offload_cmd(struct dpaa_priv *priv,
+			       struct flow_cls_offload *cls)
+{
+	int err;
+
+	mutex_lock(&priv->ft.lock);
+	switch (cls->command) {
+	case FLOW_CLS_REPLACE:
+		err = dpaa_ft_replace(priv, cls);
+		break;
+	case FLOW_CLS_DESTROY:
+		err = dpaa_ft_destroy(priv, cls);
+		break;
+	case FLOW_CLS_STATS:
+		err = dpaa_ft_stats(priv, cls);
+		break;
+	default:
+		err = -EOPNOTSUPP;
+		break;
+	}
+	mutex_unlock(&priv->ft.lock);
+
+	return err;
+}
+
+static int dpaa_setup_ft_cb(enum tc_setup_type type, void *type_data,
+			    void *cb_priv)
+{
+	struct dpaa_priv *priv = cb_priv;
+
+	if (type != TC_SETUP_CLSFLOWER)
+		return -EOPNOTSUPP;
+
+	return dpaa_ft_offload_cmd(priv, type_data);
+}
