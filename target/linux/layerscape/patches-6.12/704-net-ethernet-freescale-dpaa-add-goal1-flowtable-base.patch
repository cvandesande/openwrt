+enum dpaa_ft_nat_type {
+	DPAA_FT_NAT_NONE = 0,
+	DPAA_FT_NAT_SNAT,
+	DPAA_FT_NAT_DNAT,
+};
+
+enum dpaa_ft_reject_reason {
+	DPAA_FT_REJECT_UNSPEC = 0,
+	DPAA_FT_REJECT_MISSING_META,
+	DPAA_FT_REJECT_MISSING_MATCH,
+	DPAA_FT_REJECT_UNSUPPORTED_FAMILY,
+	DPAA_FT_REJECT_UNSUPPORTED_L4PROTO,
+	DPAA_FT_REJECT_UNSUPPORTED_TCP_FLAGS,
+	DPAA_FT_REJECT_UNSUPPORTED_ENCAP_MATCH,
+	DPAA_FT_REJECT_UNSUPPORTED_ENCAP_ACTION,
+	DPAA_FT_REJECT_UNSUPPORTED_ACTION,
+	DPAA_FT_REJECT_UNSUPPORTED_NAT,
+	DPAA_FT_REJECT_UNSUPPORTED_CSUM,
+	DPAA_FT_REJECT_MISSING_REDIRECT,
+	DPAA_FT_REJECT_DUPLICATE_COOKIE,
+	DPAA_FT_REJECT_NO_MEMORY,
+	DPAA_FT_REJECT_MAX,
+};
+
+struct dpaa_ft_tuple {
+	int ingress_ifindex;
+	u16 n_proto;
+	u8 ip_proto;
+	bool is_ipv6;
+	union {
+		struct {
+			__be32 src;
+			__be32 dst;
+		} v4;
+		struct {
+			struct in6_addr src;
+			struct in6_addr dst;
+		} v6;
+	};
+	__be16 src_port;
+	__be16 dst_port;
+};
+
+struct dpaa_ft_l2 {
+	bool src_valid;
+	bool dst_valid;
+	u8 src_mask;
+	u8 dst_mask;
+	unsigned char src[ETH_ALEN];
+	unsigned char dst[ETH_ALEN];
+};
+
+struct dpaa_ft_nat {
+	enum dpaa_ft_nat_type type;
+	bool addr_valid;
+	bool port_valid;
+	__be32 addr;
+	__be16 port;
+	u32 csum_flags;
+};
+
+struct dpaa_ft_entry {
+	struct hlist_node node;
+	unsigned long cookie;
+	struct flow_stats stats;
+	struct dpaa_ft_tuple tuple;
+	struct dpaa_ft_l2 l2;
+	struct dpaa_ft_nat nat;
+	struct net_device *out_dev;
+	u32 out_ifindex;
+};
+
+struct dpaa_ft_state {
+	struct mutex lock;
+	DECLARE_HASHTABLE(flows, DPAA_FT_FLOW_HASH_BITS);
+	unsigned long active;
+	u64 installs;
+	u64 destroys;
+	u64 stats_queries;
+	u64 rejects[DPAA_FT_REJECT_MAX];
+};
+
 struct dpaa_priv {
 	struct dpaa_percpu_priv __percpu *percpu_priv;
 	struct dpaa_bp *dpaa_bp;
@@ -173,10 +259,12 @@
 	bool rx_tstamp; /* Rx timestamping enabled */
 
 	struct bpf_prog *xdp_prog;
+	struct dpaa_ft_state ft;
 };
 
 /* from dpaa_ethtool.c */
 extern const struct ethtool_ops dpaa_ethtool_ops;
