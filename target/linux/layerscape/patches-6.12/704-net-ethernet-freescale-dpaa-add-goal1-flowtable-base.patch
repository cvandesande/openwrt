+const char * const dpaa_ft_reject_names[DPAA_FT_REJECT_MAX] = {
+	[DPAA_FT_REJECT_UNSPEC] = "unspec",
+	[DPAA_FT_REJECT_MISSING_META] = "missing_meta",
+	[DPAA_FT_REJECT_MISSING_MATCH] = "missing_match",
+	[DPAA_FT_REJECT_UNSUPPORTED_FAMILY] = "unsupported_family",
+	[DPAA_FT_REJECT_UNSUPPORTED_L4PROTO] = "unsupported_l4proto",
+	[DPAA_FT_REJECT_UNSUPPORTED_TCP_FLAGS] = "unsupported_tcp_flags",
+	[DPAA_FT_REJECT_UNSUPPORTED_ENCAP_MATCH] = "unsupported_encap_match",
+	[DPAA_FT_REJECT_UNSUPPORTED_ENCAP_ACTION] = "unsupported_encap_action",
+	[DPAA_FT_REJECT_UNSUPPORTED_ACTION] = "unsupported_action",
+	[DPAA_FT_REJECT_UNSUPPORTED_NAT] = "unsupported_nat",
+	[DPAA_FT_REJECT_UNSUPPORTED_CSUM] = "unsupported_csum",
+	[DPAA_FT_REJECT_MISSING_REDIRECT] = "missing_redirect",
+	[DPAA_FT_REJECT_DUPLICATE_COOKIE] = "duplicate_cookie",
+	[DPAA_FT_REJECT_NO_MEMORY] = "no_memory",
+};
