+static ssize_t dpaa_eth_show_ft_offload(struct device *dev,
+					struct device_attribute *attr,
+					char *buf)
+{
+	struct dpaa_priv *priv = netdev_priv(to_net_dev(dev));
+	ssize_t bytes = 0;
+	int i;
+
+	mutex_lock(&priv->ft.lock);
+	bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes, "active %lu\n",
+			   priv->ft.active);
+	bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes, "installs %llu\n",
+			   priv->ft.installs);
+	bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes, "destroys %llu\n",
+			   priv->ft.destroys);
+	bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes, "stats %llu\n",
+			   priv->ft.stats_queries);
+
+	for (i = 0; i < DPAA_FT_REJECT_MAX && bytes < PAGE_SIZE; i++) {
+		if (!priv->ft.rejects[i] || !dpaa_ft_reject_names[i])
+			continue;
+
+		bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes,
+				   "reject.%s %llu\n",
+				   dpaa_ft_reject_names[i],
+				   priv->ft.rejects[i]);
+	}
+	mutex_unlock(&priv->ft.lock);
+
+	return bytes;
+}
