+static int dpaa_ft_set_out_dev(struct dpaa_ft_egress_recipe *egress,
+			       struct net_device *dev)
+{
+	if (WARN_ON_ONCE(!dev))
+		return -EINVAL;
+
+	/* Error unwind still releases this via dpaa_ft_put_entry(). */
+	dev_hold(dev);
+	egress->out_dev = dev;
+	egress->out_ifindex = dev->ifindex;
+
+	return 0;
+}
+
+static int dpaa_ft_compile_vlan_push(struct dpaa_ft_egress_recipe *egress,
+				     const struct flow_action_entry *act)
+{
+	if (egress->vlan_push.present)
+		return -EEXIST;
+
+	if (act->vlan.proto != htons(ETH_P_8021Q))
+		return -EOPNOTSUPP;
+
+	egress->vlan_push.present = true;
+	egress->vlan_push.vid = act->vlan.vid;
+	egress->vlan_push.proto = act->vlan.proto;
+	egress->vlan_push.prio = act->vlan.prio;
+
+	return 0;
+}
+
+static int dpaa_ft_compile_pppoe_push(struct dpaa_ft_egress_recipe *egress,
+				      const struct flow_action_entry *act)
+{
+	if (egress->pppoe_push.present)
+		return -EEXIST;
+
+	egress->pppoe_push.present = true;
+	egress->pppoe_push.sid = act->pppoe.sid;
+
+	return 0;
+}
+
+static bool dpaa_ft_egress_recipe_needs_encap(
+	const struct dpaa_ft_egress_recipe *egress)
+{
+	return egress->vlan_push.present || egress->pppoe_push.present;
+}
+
+static unsigned int
+dpaa_ft_egress_recipe_encap_len(const struct dpaa_ft_egress_recipe *egress)
+{
+	unsigned int len = 0;
+
+	if (egress->vlan_push.present)
+		len += VLAN_HLEN;
+	if (egress->pppoe_push.present)
+		len += PPPOE_SES_HLEN;
+
+	return len;
+}
+
+static bool dpaa_ft_egress_recipe_supports_outbound_encap(
+	const struct dpaa_ft_entry *entry)
+{
+	const struct dpaa_ft_egress_recipe *egress = &entry->egress;
+
+	if (!dpaa_ft_egress_recipe_needs_encap(egress))
+		return true;
+
+	if (entry->tuple.is_ipv6)
+		return false;
+
+	if (!egress->out_dev || egress->out_dev->type != ARPHRD_ETHER)
+		return false;
+
+	/* Keep the first shaped executor path exact and reviewable. */
+	if (!egress->vlan_push.present || !egress->pppoe_push.present)
+		return false;
+
+	if (egress->nat.type != DPAA_FT_NAT_SNAT || !egress->nat.addr_valid)
+		return false;
+
+	return egress->vlan_push.proto == htons(ETH_P_8021Q);
+}
+
+static __be16 dpaa_ft_egress_outer_proto(const struct dpaa_ft_entry *entry)
+{
+	if (entry->egress.vlan_push.present)
+		return entry->egress.vlan_push.proto;
+
+	if (entry->egress.pppoe_push.present)
+		return htons(ETH_P_PPP_SES);
+
+	return htons(entry->tuple.n_proto);
+}
+
+static __be16 dpaa_ft_egress_ppp_proto(const struct dpaa_ft_entry *entry)
+{
+	return htons(entry->tuple.is_ipv6 ? PPP_IPV6 : PPP_IP);
+}
+
+static void dpaa_ft_build_egress_encap(struct sk_buff *skb,
+				       const struct dpaa_ft_entry *entry,
+				       unsigned int *l4_off)
+{
+	unsigned int encap_len = dpaa_ft_egress_recipe_encap_len(&entry->egress);
+	unsigned int network_len;
+	u8 *encap;
+
+	if (!encap_len) {
+		skb_reset_mac_header(skb);
+		skb_set_network_header(skb, ETH_HLEN);
+		skb_set_transport_header(skb, *l4_off);
+		skb->mac_len = ETH_HLEN;
+		return;
+	}
+
+	skb_pull(skb, ETH_HLEN);
+	network_len = skb->len;
+
+	skb_push(skb, ETH_HLEN + encap_len);
+	skb_reset_mac_header(skb);
+	skb_set_network_header(skb, ETH_HLEN + encap_len);
+	skb_set_transport_header(skb, *l4_off + encap_len);
+	skb->mac_len = ETH_HLEN + encap_len;
+
+	encap = skb_mac_header(skb) + ETH_HLEN;
+
+	if (entry->egress.vlan_push.present) {
+		struct vlan_hdr *vhdr = (struct vlan_hdr *)encap;
+		u16 vlan_tci;
+
+		vlan_tci = entry->egress.vlan_push.vid & VLAN_VID_MASK;
+		vlan_tci |= (u16)(entry->egress.vlan_push.prio & 0x7) <<
+			    VLAN_PRIO_SHIFT;
+
+		vhdr->h_vlan_TCI = htons(vlan_tci);
+		vhdr->h_vlan_encapsulated_proto =
+			entry->egress.pppoe_push.present ?
+			htons(ETH_P_PPP_SES) :
+			htons(entry->tuple.n_proto);
+		encap += VLAN_HLEN;
+	}
+
+	if (entry->egress.pppoe_push.present) {
+		struct pppoe_hdr *phdr = (struct pppoe_hdr *)encap;
+		__be16 *ppp_proto = (__be16 *)(phdr + 1);
+
+		phdr->ver = 1;
+		phdr->type = 1;
+		phdr->code = 0;
+		phdr->sid = htons(entry->egress.pppoe_push.sid);
+		phdr->length = htons(network_len + sizeof(*ppp_proto));
+		*ppp_proto = dpaa_ft_egress_ppp_proto(entry);
+	}
+
+	*l4_off += encap_len;
+}
