From: OpenAI Codex <codex@openai.com>
Subject: [PATCH] net: ethernet: freescale: dpaa: expose FMAN port state

Export FMAN RX and TX port identity plus RX KeyGen hash state through
fman_port_get_offload_info(), cache that state in DPAA after FQ
allocation and port init,
derive the RX PCD FQ span from DPAA allocated RX PCD queues, and
report the combined state through ft_offload.

This makes the live FMAN port state and RX PCD queue span visible to
the DPAA flow offload code and to user-visible ft_offload reporting.

---
diff --git a/drivers/net/ethernet/freescale/dpaa/dpaa_eth.c b/drivers/net/ethernet/freescale/dpaa/dpaa_eth.c
index 5dfcf6f..91e96c3 100644
--- a/drivers/net/ethernet/freescale/dpaa/dpaa_eth.c
+++ b/drivers/net/ethernet/freescale/dpaa/dpaa_eth.c
@@ -925,6 +925,53 @@ static void dpaa_ft_count_hit(struct dpaa_priv *priv,
 	atomic64_set(&entry->lastused, jiffies);
 }
 
+static void dpaa_ft_bind_fman_ports(struct dpaa_priv *priv)
+{
+	struct dpaa_fman_port_state *fman = &priv->fman;
+	struct fman_port *rx_port, *tx_port;
+	struct dpaa_fq *fq;
+	int err;
+
+	memset(fman, 0, sizeof(*fman));
+
+	if (!priv->mac_dev)
+		return;
+
+	rx_port = priv->mac_dev->port[RX];
+	tx_port = priv->mac_dev->port[TX];
+	if (!rx_port || !tx_port)
+		return;
+
+	err = fman_port_get_offload_info(rx_port, &fman->rx);
+	if (err) {
+		netdev_dbg(priv->net_dev,
+			   "failed to query RX FMAN offload state: %d\n",
+			   err);
+		return;
+	}
+
+	err = fman_port_get_offload_info(tx_port, &fman->tx);
+	if (err) {
+		netdev_dbg(priv->net_dev,
+			   "failed to query TX FMAN offload state: %d\n",
+			   err);
+		return;
+	}
+
+	list_for_each_entry(fq, &priv->dpaa_fq_list, list) {
+		if (fq->fq_type != FQ_TYPE_RX_PCD)
+			continue;
+
+		if (!fman->rx_pcd_fq_count ||
+		    fq->fqid < fman->rx_pcd_base_fqid)
+			fman->rx_pcd_base_fqid = fq->fqid;
+
+		fman->rx_pcd_fq_count++;
+	}
+
+	fman->ports_bound = true;
+}
+
 static int dpaa_ft_parse_packet(struct sk_buff *skb, int ingress_ifindex,
 				struct dpaa_ft_tuple *tuple,
 				unsigned int *l4_off)
@@ -4477,6 +4516,8 @@ static int dpaa_eth_probe(struct platform_device *pdev)
 
 	/* Rx traffic distribution based on keygen hashing defaults to on */
 	priv->keygen_in_use = true;
+	/* Cache FMAN state after FQs exist and Rx port init enables KeyGen. */
+	dpaa_ft_bind_fman_ports(priv);
 
 	priv->percpu_priv = devm_alloc_percpu(dev, *priv->percpu_priv);
 	if (!priv->percpu_priv) {
diff --git a/drivers/net/ethernet/freescale/dpaa/dpaa_eth.h b/drivers/net/ethernet/freescale/dpaa/dpaa_eth.h
index 1ab3feb..9e155cd 100644
--- a/drivers/net/ethernet/freescale/dpaa/dpaa_eth.h
+++ b/drivers/net/ethernet/freescale/dpaa/dpaa_eth.h
@@ -17,6 +17,7 @@
 #include <soc/fsl/bman.h>
 
 #include "fman.h"
+#include "fman_port.h"
 #include "mac.h"
 #include "dpaa_eth_trace.h"
 
@@ -229,6 +230,14 @@ struct dpaa_ft_state {
 	u64 rejects[DPAA_FT_REJECT_MAX];
 };
 
+struct dpaa_fman_port_state {
+	bool ports_bound;
+	struct fman_port_offload_info rx;
+	struct fman_port_offload_info tx;
+	u32 rx_pcd_base_fqid;
+	u32 rx_pcd_fq_count;
+};
+
 struct dpaa_priv {
 	struct dpaa_percpu_priv __percpu *percpu_priv;
 	struct dpaa_bp *dpaa_bp;
@@ -276,6 +285,7 @@ struct dpaa_priv {
 
 	struct bpf_prog *xdp_prog;
 	struct dpaa_ft_state ft;
+	struct dpaa_fman_port_state fman;
 };
 
 /* from dpaa_ethtool.c */
diff --git a/drivers/net/ethernet/freescale/dpaa/dpaa_eth_sysfs.c b/drivers/net/ethernet/freescale/dpaa/dpaa_eth_sysfs.c
index 8c1a21e..d0deb06 100644
--- a/drivers/net/ethernet/freescale/dpaa/dpaa_eth_sysfs.c
+++ b/drivers/net/ethernet/freescale/dpaa/dpaa_eth_sysfs.c
@@ -129,6 +129,46 @@ static ssize_t dpaa_eth_show_ft_offload(struct device *dev,
 			   priv->ft.stats_queries);
 	bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes, "hits %lld\n",
 			   atomic64_read(&priv->ft.hits));
+	bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes,
+			   "mode.requested %s\n",
+			   priv->ft.requested_mode ==
+			   DPAA_FT_REQUESTED_MODE_HARDWARE ? "hardware" :
+			   priv->ft.requested_mode ==
+			   DPAA_FT_REQUESTED_MODE_SOFTWARE ? "software" :
+			   "unknown");
+	bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes,
+			   "mode.active %s\n",
+			   priv->ft.active_mode ==
+			   DPAA_FT_ACTIVE_MODE_HARDWARE ? "hardware" :
+			   priv->ft.active_mode ==
+			   DPAA_FT_ACTIVE_MODE_SOFTWARE ? "software" :
+			   "none");
+	bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes,
+			   "hw.backend_state %s\n",
+			   priv->ft.hw_backend_state ==
+			   DPAA_FT_HW_BACKEND_READY ? "ready" :
+			   priv->ft.hw_backend_state ==
+			   DPAA_FT_HW_BACKEND_DISABLED ? "disabled" :
+			   "not_implemented");
+	bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes,
+			   "fman.ports_bound %u\n",
+			   priv->fman.ports_bound ? 1 : 0);
+
+	if (priv->fman.ports_bound && bytes < PAGE_SIZE) {
+		bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes,
+				   "fman.rx_port_id %u\n", priv->fman.rx.port_id);
+		bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes,
+				   "fman.tx_port_id %u\n", priv->fman.tx.port_id);
+		bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes,
+				   "fman.rx_keygen_hash %u\n",
+				   priv->fman.rx.kg_hash_enabled ? 1 : 0);
+		bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes,
+				   "fman.rx_pcd_base_fqid %u\n",
+				   priv->fman.rx_pcd_base_fqid);
+		bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes,
+				   "fman.rx_pcd_fq_count %u\n",
+				   priv->fman.rx_pcd_fq_count);
+	}
 
 	for (i = 0; i < DPAA_FT_REJECT_MAX && bytes < PAGE_SIZE; i++) {
 		if (!priv->ft.rejects[i] || !dpaa_ft_reject_names[i])
diff --git a/drivers/net/ethernet/freescale/fman/fman_port.c b/drivers/net/ethernet/freescale/fman/fman_port.c
index f17a4e5..0f864fd 100644
--- a/drivers/net/ethernet/freescale/fman/fman_port.c
+++ b/drivers/net/ethernet/freescale/fman/fman_port.c
@@ -446,6 +446,7 @@ struct fman_port {
 
 	struct fman_port_cfg *cfg;
 	struct fman_port_dts_params dts_params;
+	bool kg_hash_enabled;
 
 	u8 ext_pools_num;
 	u32 max_port_fifo_size;
@@ -1394,6 +1395,8 @@ EXPORT_SYMBOL(fman_port_config);
  */
 void fman_port_use_kg_hash(struct fman_port *port, bool enable)
 {
+	port->kg_hash_enabled = enable;
+
 	if (enable)
 		/* After the Parser frames go to KeyGen */
 		iowrite32be(NIA_ENG_HWK, &port->bmi_regs->rx.fmbm_rfpne);
@@ -1702,6 +1705,19 @@ u32 fman_port_get_qman_channel_id(struct fman_port *port)
 }
 EXPORT_SYMBOL(fman_port_get_qman_channel_id);
 
+int fman_port_get_offload_info(struct fman_port *port,
+			       struct fman_port_offload_info *info)
+{
+	if (!port || !info)
+		return -EINVAL;
+
+	info->port_id = port->port_id;
+	info->kg_hash_enabled = port->kg_hash_enabled;
+
+	return 0;
+}
+EXPORT_SYMBOL(fman_port_get_offload_info);
+
 /**
  * fman_port_get_device
  * @port:	Pointer to the FMan port device
diff --git a/drivers/net/ethernet/freescale/fman/fman_port.h b/drivers/net/ethernet/freescale/fman/fman_port.h
index 4917fe8..ebe28ff 100644
--- a/drivers/net/ethernet/freescale/fman/fman_port.h
+++ b/drivers/net/ethernet/freescale/fman/fman_port.h
@@ -69,6 +69,11 @@
 
 struct fman_port;
 
+struct fman_port_offload_info {
+	u8 port_id;
+	bool kg_hash_enabled;
+};
+
 /* A structure for additional Rx port parameters */
 struct fman_port_rx_params {
 	u32 err_fqid;			/* Error Queue Id. */
@@ -124,6 +130,9 @@ int fman_port_enable(struct fman_port *port);
 
 u32 fman_port_get_qman_channel_id(struct fman_port *port);
 
+int fman_port_get_offload_info(struct fman_port *port,
+			       struct fman_port_offload_info *info);
+
 int fman_port_get_hash_result_offset(struct fman_port *port, u32 *offset);
 
 int fman_port_get_tstamp(struct fman_port *port, const void *data, u64 *tstamp);
