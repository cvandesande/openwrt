+			   "hw.resources.release_failures %llu\n",
+			   priv->ft.hw.resource_release_failures);
+	bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes,
+			   "hw.teardown.completes %llu\n",
+			   priv->ft.hw.teardown_completes);
+	bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes,
+			   "hw.resources.keygen_reserved %u\n",
+			   priv->ft.hw.res.keygen_reserved ? 1 : 0);
 	bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes,
