+int keygen_port_scheme_reserve(struct fman_keygen *keygen, u8 hw_port_id,
+			       u8 *scheme_id)
+{
+	struct keygen_scheme *scheme;
+	u8 id;
+	int err;
+
+	if (!keygen || !scheme_id)
+		return -EINVAL;
+
+	if (hw_port_id >= FMAN_MAX_NUM_OF_HW_PORTS)
+		return -EINVAL;
+
+	err = get_free_scheme_id(keygen, &id);
+	if (err)
+		return -ENOSPC;
+
+	scheme = get_scheme(keygen, id);
+	if (!scheme)
+		return -EINVAL;
+
+	memset(scheme, 0, sizeof(*scheme));
+	scheme->reserved = true;
+	scheme->hw_port_id = hw_port_id;
+	*scheme_id = id;
+
+	return 0;
+}
+EXPORT_SYMBOL(keygen_port_scheme_reserve);
+
+int keygen_port_scheme_release(struct fman_keygen *keygen, u8 scheme_id)
+{
+	struct keygen_scheme *scheme;
+
+	if (!keygen)
+		return -EINVAL;
+
+	scheme = get_scheme(keygen, scheme_id);
+	if (!scheme || !scheme->reserved || scheme->used)
+		return -ENOENT;
+
+	memset(scheme, 0, sizeof(*scheme));
+
+	return 0;
+}
+EXPORT_SYMBOL(keygen_port_scheme_release);
