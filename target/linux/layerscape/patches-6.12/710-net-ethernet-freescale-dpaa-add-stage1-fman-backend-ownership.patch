From: OpenAI Codex <codex@openai.com>
Subject: [PATCH] net: ethernet: freescale: dpaa: add Stage 1 FMAN backend ownership

Add the Stage 1 FMAN backend ownership boundary without enabling live
FMAN steering:

- build explicit backend-owned install-plan state keyed by private FMAN
  binding metadata, including backend-local port binding identity
- reserve and unwind RX KeyGen scheme ownership to prove resource
  ordering and teardown without binding live steering state
- track backend lifecycle transitions and resource counters through
  ft_offload
- keep hardware-requested mode in the backend path with explicit
  degradation and unchanged packet forwarding

Keep software flow offloading on the current DPAA executor path.
Keep hardware flow offloading honest: no live FMAN forwarding yet, but
real backend plan and resource ownership now exists and unwinds
explicitly.

---
diff --git a/drivers/net/ethernet/freescale/dpaa/dpaa_eth.h b/drivers/net/ethernet/freescale/dpaa/dpaa_eth.h
index e99cf06..05b7c86 100644
--- a/drivers/net/ethernet/freescale/dpaa/dpaa_eth.h
+++ b/drivers/net/ethernet/freescale/dpaa/dpaa_eth.h
@@ -201,6 +201,17 @@ enum dpaa_ft_hw_degrade_reason {
 	DPAA_FT_HW_DEGRADE_MAX,
 };
 
+enum dpaa_ft_hw_lifecycle_state {
+	DPAA_FT_HW_LIFECYCLE_NONE = 0,
+	DPAA_FT_HW_LIFECYCLE_PLAN_BUILT,
+	DPAA_FT_HW_LIFECYCLE_RESOURCES_ALLOCATED,
+	DPAA_FT_HW_LIFECYCLE_INSTALL_PENDING,
+	DPAA_FT_HW_LIFECYCLE_INSTALL_FAILED,
+	DPAA_FT_HW_LIFECYCLE_TEARDOWN_PENDING,
+	DPAA_FT_HW_LIFECYCLE_TEARDOWN_COMPLETE,
+	DPAA_FT_HW_LIFECYCLE_MAX,
+};
+
 enum dpaa_ft_fallback_reason {
 	DPAA_FT_FALLBACK_PACKET = 0,
 	DPAA_FT_FALLBACK_NO_MEMORY,
@@ -278,23 +289,48 @@ struct dpaa_ft_egress_recipe {
 	struct dpaa_ft_pppoe_push pppoe_push;
 };
 
+struct dpaa_ft_hw_binding {
+	u8 rx_port_id;
+	u8 tx_port_id;
+	u32 rx_pcd_base_fqid;
+	u32 rx_pcd_fq_count;
+};
+
+struct dpaa_ft_hw_install_plan {
+	bool valid;
+	unsigned long cookie;
+	u32 generation;
+	struct dpaa_ft_hw_binding binding;
+};
+
 struct dpaa_ft_hw_resources {
 	struct fman_port *rx_port;
 	struct fman_port *tx_port;
 	bool rx_bound;
 	bool tx_bound;
 	bool keygen_api_available;
-	bool dry_run_scheme_allocated;
-	u8 dry_run_scheme_id;
+	bool keygen_reserved;
+	u8 keygen_scheme_id;
+	u32 generation;
+	struct dpaa_ft_hw_binding binding;
 };
 
 struct dpaa_ft_hw_backend {
 	enum dpaa_ft_hw_backend_state state;
 	enum dpaa_ft_hw_dry_run_result last_dry_run;
 	enum dpaa_ft_hw_degrade_reason last_degrade;
+	enum dpaa_ft_hw_lifecycle_state last_lifecycle;
+	u32 generation;
 	u64 dry_run_attempts;
 	u64 dry_run_lowerable;
 	u64 dry_run_not_lowerable;
+	u64 plan_builds;
+	u64 plan_failures;
+	u64 resource_allocations;
+	u64 resource_allocation_failures;
+	u64 resource_releases;
+	u64 resource_release_failures;
+	u64 teardown_completes;
 	u64 install_attempts;
 	u64 install_failures;
 	u64 remove_attempts;
@@ -302,12 +338,14 @@ struct dpaa_ft_hw_backend {
 	u64 stats_queries;
 	int last_error;
 	u64 degrade_events[DPAA_FT_HW_DEGRADE_MAX];
+	struct dpaa_ft_hw_install_plan plan;
 	struct dpaa_ft_hw_resources res;
 };
 
 struct dpaa_ft_hw_flow {
-	enum dpaa_ft_hw_backend_state state;
+	enum dpaa_ft_hw_lifecycle_state state;
 	int last_error;
+	u32 generation;
 };
 
 struct dpaa_ft_entry {
diff --git a/drivers/net/ethernet/freescale/dpaa/dpaa_eth.c b/drivers/net/ethernet/freescale/dpaa/dpaa_eth.c
index f86727d..92f5082 100644
--- a/drivers/net/ethernet/freescale/dpaa/dpaa_eth.c
+++ b/drivers/net/ethernet/freescale/dpaa/dpaa_eth.c
@@ -1653,6 +1653,7 @@ static void dpaa_ft_bind_fman_ports(struct dpaa_priv *priv)
 
 struct dpaa_ft_hw_result {
 	enum dpaa_ft_hw_backend_state state;
+	enum dpaa_ft_hw_lifecycle_state lifecycle;
 	enum dpaa_ft_hw_dry_run_result dry_run;
 	enum dpaa_ft_hw_degrade_reason degrade;
 	enum dpaa_ft_reject_reason reject_reason;
@@ -1687,18 +1688,47 @@ static const char *dpaa_ft_fman_hw_disabled_reason(const struct dpaa_priv *priv)
 	return "hardware flow offloading requested, but the FMAN backend is disabled because backend prerequisites are incomplete; flows stay on the normal Linux path";
 }
 
+static void dpaa_ft_hw_clear_plan(struct dpaa_ft_hw_backend *hw)
+{
+	memset(&hw->plan, 0, sizeof(hw->plan));
+}
+
+static void dpaa_ft_hw_clear_resources(struct dpaa_ft_hw_backend *hw)
+{
+	memset(&hw->res, 0, sizeof(hw->res));
+}
+
+static void
+dpaa_ft_hw_set_lifecycle(struct dpaa_ft_hw_backend *hw,
+			 enum dpaa_ft_hw_lifecycle_state state)
+{
+	if (state <= DPAA_FT_HW_LIFECYCLE_NONE ||
+	    state >= DPAA_FT_HW_LIFECYCLE_MAX)
+		return;
+
+	hw->last_lifecycle = state;
+}
+
+static void dpaa_ft_fman_hw_reset_owned_state(struct dpaa_priv *priv)
+{
+	struct dpaa_ft_hw_backend *hw = &priv->ft.hw;
+
+	if (hw->res.keygen_reserved && hw->res.rx_port)
+		fman_port_release_kg_scheme(hw->res.rx_port,
+					    hw->res.keygen_scheme_id);
+
+	dpaa_ft_hw_clear_plan(hw);
+	dpaa_ft_hw_clear_resources(hw);
+}
+
 static void dpaa_ft_hw_reset_observation(struct dpaa_ft_hw_backend *hw)
 {
 	hw->last_dry_run = DPAA_FT_HW_DRY_RUN_NONE;
 	hw->last_degrade = DPAA_FT_HW_DEGRADE_NONE;
+	hw->last_lifecycle = DPAA_FT_HW_LIFECYCLE_NONE;
 	hw->last_error = 0;
-	hw->res.rx_port = NULL;
-	hw->res.tx_port = NULL;
-	hw->res.rx_bound = false;
-	hw->res.tx_bound = false;
-	hw->res.keygen_api_available = false;
-	hw->res.dry_run_scheme_allocated = false;
-	hw->res.dry_run_scheme_id = 0;
+	dpaa_ft_hw_clear_plan(hw);
+	dpaa_ft_hw_clear_resources(hw);
 }
 
 static void dpaa_ft_hw_note_degrade(struct dpaa_priv *priv,
@@ -1725,6 +1755,7 @@ static void dpaa_ft_fman_hw_prepare(struct dpaa_priv *priv)
 {
 	struct dpaa_ft_hw_backend *hw = &priv->ft.hw;
 
+	dpaa_ft_fman_hw_reset_owned_state(priv);
 	dpaa_ft_hw_reset_observation(hw);
 	hw->state = DPAA_FT_HW_BACKEND_NOT_IMPLEMENTED;
 
@@ -1749,6 +1780,152 @@ static void dpaa_ft_fman_hw_prepare(struct dpaa_priv *priv)
 	hw->state = DPAA_FT_HW_BACKEND_READY;
 }
 
+static int dpaa_ft_fman_hw_build_plan(struct dpaa_priv *priv,
+				      const struct dpaa_ft_entry *entry,
+				      struct dpaa_ft_hw_result *result)
+{
+	struct dpaa_ft_hw_backend *hw = &priv->ft.hw;
+
+	if (!priv->fman.rx_pcd_fq_count) {
+		hw->plan_failures++;
+		hw->install_failures++;
+		hw->last_error = -EOPNOTSUPP;
+		dpaa_ft_hw_set_lifecycle(hw, DPAA_FT_HW_LIFECYCLE_INSTALL_FAILED);
+		result->lifecycle = hw->last_lifecycle;
+		result->degrade = DPAA_FT_HW_DEGRADE_INSTALL_FAILED;
+		result->reject_reason = DPAA_FT_REJECT_HW_INSTALL_FAILED;
+		result->err = -EOPNOTSUPP;
+		result->message = "hardware flow offloading requested, but the FMAN backend could not derive a stable local port binding for the staged install plan; flows stay on the normal Linux path";
+		return result->err;
+	}
+
+	dpaa_ft_hw_clear_plan(hw);
+	hw->generation++;
+	hw->plan.valid = true;
+	hw->plan.cookie = entry->cookie;
+	hw->plan.generation = hw->generation;
+	hw->plan.binding.rx_port_id = priv->fman.rx.port_id;
+	hw->plan.binding.tx_port_id = priv->fman.tx.port_id;
+	hw->plan.binding.rx_pcd_base_fqid = priv->fman.rx_pcd_base_fqid;
+	hw->plan.binding.rx_pcd_fq_count = priv->fman.rx_pcd_fq_count;
+	hw->plan_builds++;
+	dpaa_ft_hw_set_lifecycle(hw, DPAA_FT_HW_LIFECYCLE_PLAN_BUILT);
+	result->lifecycle = hw->last_lifecycle;
+
+	return 0;
+}
+
+static int dpaa_ft_fman_hw_alloc_resources(struct dpaa_priv *priv,
+					   struct dpaa_ft_hw_result *result)
+{
+	struct dpaa_ft_hw_backend *hw = &priv->ft.hw;
+	u8 scheme_id;
+	int err;
+
+	if (!hw->plan.valid) {
+		hw->resource_allocation_failures++;
+		hw->install_failures++;
+		hw->last_error = -EINVAL;
+		dpaa_ft_hw_set_lifecycle(hw, DPAA_FT_HW_LIFECYCLE_INSTALL_FAILED);
+		result->lifecycle = hw->last_lifecycle;
+		result->degrade = DPAA_FT_HW_DEGRADE_INSTALL_FAILED;
+		result->reject_reason = DPAA_FT_REJECT_HW_INSTALL_FAILED;
+		result->err = -EINVAL;
+		result->message = "hardware flow offloading requested, but the FMAN backend has no staged install plan to own resources for; flows stay on the normal Linux path";
+		return result->err;
+	}
+
+	dpaa_ft_hw_clear_resources(hw);
+	hw->res.rx_port = priv->mac_dev ? priv->mac_dev->port[RX] : NULL;
+	hw->res.tx_port = priv->mac_dev ? priv->mac_dev->port[TX] : NULL;
+	hw->res.rx_bound = !!hw->res.rx_port;
+	hw->res.tx_bound = !!hw->res.tx_port;
+	hw->res.keygen_api_available = priv->fman.rx.kg_scheme_api_available;
+	hw->res.generation = hw->plan.generation;
+	hw->res.binding = hw->plan.binding;
+
+	if (!hw->res.rx_port || !hw->res.tx_port) {
+		hw->resource_allocation_failures++;
+		hw->install_failures++;
+		hw->last_error = -EOPNOTSUPP;
+		dpaa_ft_hw_set_lifecycle(hw, DPAA_FT_HW_LIFECYCLE_INSTALL_FAILED);
+		result->lifecycle = hw->last_lifecycle;
+		result->degrade = DPAA_FT_HW_DEGRADE_INSTALL_FAILED;
+		result->reject_reason = DPAA_FT_REJECT_HW_INSTALL_FAILED;
+		result->err = -EOPNOTSUPP;
+		result->message = "hardware flow offloading requested, but the FMAN backend could not bind the staged install plan to RX and TX ports; flows stay on the normal Linux path";
+		dpaa_ft_hw_clear_plan(hw);
+		dpaa_ft_hw_clear_resources(hw);
+		return result->err;
+	}
+
+	err = fman_port_reserve_kg_scheme(hw->res.rx_port, &scheme_id);
+	if (err) {
+		hw->resource_allocation_failures++;
+		hw->install_failures++;
+		hw->last_error = err;
+		dpaa_ft_hw_set_lifecycle(hw, DPAA_FT_HW_LIFECYCLE_INSTALL_FAILED);
+		result->lifecycle = hw->last_lifecycle;
+		result->degrade = DPAA_FT_HW_DEGRADE_INSTALL_FAILED;
+		result->reject_reason = DPAA_FT_REJECT_HW_INSTALL_FAILED;
+		result->err = err;
+		result->message = "hardware flow offloading requested, but the FMAN backend could not reserve an RX KeyGen scheme for the staged install plan; flows stay on the normal Linux path";
+		dpaa_ft_hw_clear_plan(hw);
+		dpaa_ft_hw_clear_resources(hw);
+		return err;
+	}
+
+	hw->res.keygen_reserved = true;
+	hw->res.keygen_scheme_id = scheme_id;
+	hw->resource_allocations++;
+	dpaa_ft_hw_set_lifecycle(hw, DPAA_FT_HW_LIFECYCLE_RESOURCES_ALLOCATED);
+	result->lifecycle = hw->last_lifecycle;
+
+	return 0;
+}
+
+static int dpaa_ft_fman_hw_teardown_resources(struct dpaa_priv *priv,
+					      struct dpaa_ft_hw_result *result)
+{
+	struct dpaa_ft_hw_backend *hw = &priv->ft.hw;
+	int err = 0;
+
+	if (!hw->plan.valid && !hw->res.keygen_reserved) {
+		dpaa_ft_hw_clear_plan(hw);
+		dpaa_ft_hw_clear_resources(hw);
+		return 0;
+	}
+
+	dpaa_ft_hw_set_lifecycle(hw, DPAA_FT_HW_LIFECYCLE_TEARDOWN_PENDING);
+
+	if (hw->res.keygen_reserved && hw->res.rx_port) {
+		err = fman_port_release_kg_scheme(hw->res.rx_port,
+						  hw->res.keygen_scheme_id);
+		if (err) {
+			hw->resource_release_failures++;
+			hw->install_failures++;
+			hw->last_error = err;
+			result->lifecycle = DPAA_FT_HW_LIFECYCLE_INSTALL_FAILED;
+			result->degrade = DPAA_FT_HW_DEGRADE_INSTALL_FAILED;
+			result->reject_reason = DPAA_FT_REJECT_HW_INSTALL_FAILED;
+			result->err = err;
+			result->message = "hardware flow offloading requested, but the FMAN backend could not unwind a staged RX KeyGen reservation; flows stay on the normal Linux path";
+			dpaa_ft_hw_set_lifecycle(hw,
+					 DPAA_FT_HW_LIFECYCLE_INSTALL_FAILED);
+			return err;
+		}
+		hw->resource_releases++;
+	}
+
+	dpaa_ft_hw_clear_plan(hw);
+	dpaa_ft_hw_clear_resources(hw);
+	hw->teardown_completes++;
+	dpaa_ft_hw_set_lifecycle(hw, DPAA_FT_HW_LIFECYCLE_TEARDOWN_COMPLETE);
+	result->lifecycle = hw->last_lifecycle;
+
+	return 0;
+}
+
 static bool
 dpaa_ft_fman_hw_is_stage0_lowerable(struct dpaa_priv *priv,
 				    const struct dpaa_ft_entry *entry,
@@ -1800,9 +1977,11 @@ static int dpaa_ft_fman_hw_dry_run(struct dpaa_priv *priv,
 {
 	struct dpaa_ft_hw_backend *hw = &priv->ft.hw;
 	const char *reason = NULL;
+	int err;
 
 	memset(result, 0, sizeof(*result));
 	result->state = hw->state;
+	result->lifecycle = hw->last_lifecycle;
 	result->err = hw->last_error;
 	hw->dry_run_attempts++;
 
@@ -1837,10 +2016,24 @@ static int dpaa_ft_fman_hw_dry_run(struct dpaa_priv *priv,
 	hw->dry_run_lowerable++;
 	hw->last_dry_run = DPAA_FT_HW_DRY_RUN_LOWERABLE;
 	result->dry_run = DPAA_FT_HW_DRY_RUN_LOWERABLE;
+	err = dpaa_ft_fman_hw_build_plan(priv, entry, result);
+	if (err)
+		return err;
+
+	err = dpaa_ft_fman_hw_alloc_resources(priv, result);
+	if (err)
+		return err;
+
+	hw->install_attempts++;
+	dpaa_ft_hw_set_lifecycle(hw, DPAA_FT_HW_LIFECYCLE_INSTALL_PENDING);
+	result->lifecycle = hw->last_lifecycle;
 	result->degrade = DPAA_FT_HW_DEGRADE_DRY_RUN_ONLY;
 	result->reject_reason = DPAA_FT_REJECT_HW_DRY_RUN_ONLY;
 	result->err = -EOPNOTSUPP;
 	result->message = "hardware flow offloading requested, and the FMAN backend dry-run says this exact contract appears lowerable, but live FMAN install is not enabled yet; flows stay on the normal Linux path";
+	err = dpaa_ft_fman_hw_teardown_resources(priv, result);
+	if (err)
+		return err;
 
 	return result->err;
 }
@@ -1849,11 +2042,13 @@ static int dpaa_ft_fman_hw_install_stub(struct dpaa_priv *priv,
 					struct dpaa_ft_entry *entry)
 {
 	priv->ft.hw.install_attempts++;
-	priv->ft.hw.state = DPAA_FT_HW_BACKEND_INSTALL_FAILED;
 	priv->ft.hw.install_failures++;
 	priv->ft.hw.last_error = -EOPNOTSUPP;
-	entry->hw.state = DPAA_FT_HW_BACKEND_INSTALL_FAILED;
+	dpaa_ft_hw_set_lifecycle(&priv->ft.hw,
+				 DPAA_FT_HW_LIFECYCLE_INSTALL_FAILED);
+	entry->hw.state = DPAA_FT_HW_LIFECYCLE_INSTALL_FAILED;
 	entry->hw.last_error = -EOPNOTSUPP;
+	entry->hw.generation = priv->ft.hw.generation;
 
 	return -EOPNOTSUPP;
 }
@@ -1899,10 +2094,12 @@ static void dpaa_ft_hw_backend_prepare(struct dpaa_priv *priv)
 {
 	const struct dpaa_ft_hw_backend_ops *ops = dpaa_ft_hw_backend_ops(priv);
 
-	dpaa_ft_hw_reset_observation(&priv->ft.hw);
-	priv->ft.hw.state = DPAA_FT_HW_BACKEND_NOT_IMPLEMENTED;
-	if (!ops)
+	if (!ops) {
+		dpaa_ft_fman_hw_reset_owned_state(priv);
+		dpaa_ft_hw_reset_observation(&priv->ft.hw);
+		priv->ft.hw.state = DPAA_FT_HW_BACKEND_NOT_IMPLEMENTED;
 		return;
+	}
 
 	ops->prepare(priv);
 }
@@ -2336,6 +2533,7 @@ static int dpaa_ft_replace_hardware_locked(struct dpaa_priv *priv,
 	const struct dpaa_ft_hw_backend_ops *ops = dpaa_ft_hw_backend_ops(priv);
 	struct dpaa_ft_hw_result result = {
 		.state = DPAA_FT_HW_BACKEND_NOT_IMPLEMENTED,
+		.lifecycle = DPAA_FT_HW_LIFECYCLE_NONE,
 		.degrade = DPAA_FT_HW_DEGRADE_NOT_IMPLEMENTED,
 		.reject_reason = DPAA_FT_REJECT_HW_MODE_UNAVAILABLE,
 		.err = -EOPNOTSUPP,
@@ -2361,8 +2559,9 @@ static int dpaa_ft_replace_hardware_locked(struct dpaa_priv *priv,
 	if (ops)
 		err = ops->dry_run(priv, entry, &result);
 
-	entry->hw.state = result.state;
+	entry->hw.state = result.lifecycle;
 	entry->hw.last_error = result.err;
+	entry->hw.generation = priv->ft.hw.generation;
 	dpaa_ft_put_entry(entry);
 
 	dpaa_ft_hw_note_degrade(priv, result.degrade, result.message);
diff --git a/drivers/net/ethernet/freescale/dpaa/dpaa_eth_sysfs.c b/drivers/net/ethernet/freescale/dpaa/dpaa_eth_sysfs.c
index 694b1cb..e139fdd 100644
--- a/drivers/net/ethernet/freescale/dpaa/dpaa_eth_sysfs.c
+++ b/drivers/net/ethernet/freescale/dpaa/dpaa_eth_sysfs.c
@@ -159,6 +159,28 @@ static const char *dpaa_ft_hw_degrade_name(enum dpaa_ft_hw_degrade_reason reason
 	}
 }
 
+static const char *
+dpaa_ft_hw_lifecycle_name(enum dpaa_ft_hw_lifecycle_state state)
+{
+	switch (state) {
+	case DPAA_FT_HW_LIFECYCLE_PLAN_BUILT:
+		return "plan_built";
+	case DPAA_FT_HW_LIFECYCLE_RESOURCES_ALLOCATED:
+		return "resources_allocated";
+	case DPAA_FT_HW_LIFECYCLE_INSTALL_PENDING:
+		return "install_pending";
+	case DPAA_FT_HW_LIFECYCLE_INSTALL_FAILED:
+		return "install_failed";
+	case DPAA_FT_HW_LIFECYCLE_TEARDOWN_PENDING:
+		return "teardown_pending";
+	case DPAA_FT_HW_LIFECYCLE_TEARDOWN_COMPLETE:
+		return "teardown_complete";
+	case DPAA_FT_HW_LIFECYCLE_NONE:
+	default:
+		return "none";
+	}
+}
+
 static ssize_t dpaa_eth_show_ft_offload(struct device *dev,
 					struct device_attribute *attr,
 					char *buf)
@@ -201,6 +223,11 @@ static ssize_t dpaa_eth_show_ft_offload(struct device *dev,
