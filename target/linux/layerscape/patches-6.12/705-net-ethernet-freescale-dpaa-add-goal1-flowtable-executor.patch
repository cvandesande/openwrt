+static u32 dpaa_ft_tuple_hash(const struct dpaa_ft_tuple *tuple)
+{
+	struct {
+		int ingress_ifindex;
+		u16 n_proto;
+		u8 ip_proto;
+		u8 is_ipv6;
+		__be16 src_port;
+		__be16 dst_port;
+	} key = {
+		.ingress_ifindex = tuple->ingress_ifindex,
+		.n_proto = tuple->n_proto,
+		.ip_proto = tuple->ip_proto,
+		.is_ipv6 = tuple->is_ipv6,
+		.src_port = tuple->src_port,
+		.dst_port = tuple->dst_port,
+	};
+	u32 hash;
+
+	hash = jhash(&key, sizeof(key), 0);
+
+	if (tuple->is_ipv6)
+		return jhash(&tuple->v6, sizeof(tuple->v6), hash);
+
+	return jhash(&tuple->v4, sizeof(tuple->v4), hash);
+}
+
+static bool dpaa_ft_tuple_equal(const struct dpaa_ft_tuple *a,
+				const struct dpaa_ft_tuple *b)
+{
+	if (a->ingress_ifindex != b->ingress_ifindex ||
+	    a->n_proto != b->n_proto ||
+	    a->ip_proto != b->ip_proto ||
+	    a->is_ipv6 != b->is_ipv6 ||
+	    a->src_port != b->src_port ||
+	    a->dst_port != b->dst_port)
+		return false;
+
+	if (a->is_ipv6)
+		return !memcmp(&a->v6, &b->v6, sizeof(a->v6));
+
+	return a->v4.src == b->v4.src && a->v4.dst == b->v4.dst;
+}
