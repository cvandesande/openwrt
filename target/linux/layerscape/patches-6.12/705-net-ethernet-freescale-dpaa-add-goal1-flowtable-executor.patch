+static void dpaa_ft_put_entry_rcu(struct rcu_head *rcu)
+{
+	struct dpaa_ft_entry *entry;
+
+	entry = container_of(rcu, struct dpaa_ft_entry, rcu);
+	dpaa_ft_put_entry(entry);
+}
+
+static void dpaa_ft_count_fallback(struct dpaa_priv *priv,
+				   enum dpaa_ft_fallback_reason reason)
+{
+	if (reason < DPAA_FT_FALLBACK_MAX)
+		atomic64_inc(&priv->ft.fallbacks[reason]);
+}
+
+static void dpaa_ft_count_hit(struct dpaa_priv *priv,
+			      struct dpaa_ft_entry *entry,
+			      unsigned int len)
+{
+	atomic64_inc(&priv->ft.hits);
+	atomic64_inc(&entry->packets);
+	atomic64_add(len, &entry->bytes);
+	atomic64_set(&entry->lastused, jiffies);
+}
+
+static int dpaa_ft_parse_packet(struct sk_buff *skb, int ingress_ifindex,
+				struct dpaa_ft_tuple *tuple,
+				unsigned int *l4_off)
+{
+	const struct ipv6hdr *ip6h;
+	const struct tcphdr *tcph;
+	const struct ethhdr *eth;
+	const struct udphdr *udph;
+	const struct iphdr *iph;
+
+	memset(tuple, 0, sizeof(*tuple));
+	tuple->ingress_ifindex = ingress_ifindex;
+
+	if (!pskb_may_pull(skb, ETH_HLEN))
+		return -ENOENT;
+
+	skb_reset_mac_header(skb);
+	eth = eth_hdr(skb);
+
+	if (skb_vlan_tag_present(skb))
+		return -ENOENT;
+
+	switch (eth->h_proto) {
+	case htons(ETH_P_8021Q):
+	case htons(ETH_P_8021AD):
+	case htons(ETH_P_PPP_SES):
+		return -ENOENT;
+	case htons(ETH_P_IP):
+		if (!pskb_may_pull(skb, ETH_HLEN + sizeof(*iph)))
+			return -ENOENT;
+
+		iph = (struct iphdr *)(skb->data + ETH_HLEN);
+		if (iph->ihl < sizeof(*iph) / 4)
+			return -ENOENT;
+		if (iph->protocol != IPPROTO_TCP &&
+		    iph->protocol != IPPROTO_UDP)
+			return -ENOENT;
+
+		tuple->n_proto = ETH_P_IP;
+		tuple->ip_proto = iph->protocol;
+		tuple->v4.src = iph->saddr;
+		tuple->v4.dst = iph->daddr;
+		*l4_off = ETH_HLEN + iph->ihl * 4;
+		if (!pskb_may_pull(skb, *l4_off +
+				   (iph->protocol == IPPROTO_TCP ?
+				    sizeof(*tcph) : sizeof(*udph))))
+			return -ENOENT;
+		break;
+	case htons(ETH_P_IPV6):
+		if (!pskb_may_pull(skb, ETH_HLEN + sizeof(*ip6h)))
+			return -ENOENT;
+
+		ip6h = (struct ipv6hdr *)(skb->data + ETH_HLEN);
+		if (ip6h->nexthdr != IPPROTO_TCP &&
+		    ip6h->nexthdr != IPPROTO_UDP)
+			return -ENOENT;
+
+		tuple->n_proto = ETH_P_IPV6;
+		tuple->ip_proto = ip6h->nexthdr;
+		tuple->is_ipv6 = true;
+		tuple->v6.src = ip6h->saddr;
+		tuple->v6.dst = ip6h->daddr;
+		*l4_off = ETH_HLEN + sizeof(*ip6h);
+		if (!pskb_may_pull(skb, *l4_off +
+				   (ip6h->nexthdr == IPPROTO_TCP ?
+				    sizeof(*tcph) : sizeof(*udph))))
+			return -ENOENT;
+		break;
+	default:
+		return -ENOENT;
+	}
+
+	if (tuple->ip_proto == IPPROTO_TCP) {
+		tcph = (struct tcphdr *)(skb->data + *l4_off);
+		tuple->src_port = tcph->source;
+		tuple->dst_port = tcph->dest;
+	} else {
+		udph = (struct udphdr *)(skb->data + *l4_off);
+		tuple->src_port = udph->source;
+		tuple->dst_port = udph->dest;
+	}
+
+	return 0;
+}
+
+static bool dpaa_ft_skb_supported(const struct dpaa_ft_entry *entry,
+				  const struct sk_buff *skb,
+				  unsigned int l4_off)
+{
+	if (entry->tuple.ip_proto == IPPROTO_TCP) {
+		const struct tcphdr *tcph;
+
+		tcph = (const struct tcphdr *)(skb->data + l4_off);
+		if (tcph->fin || tcph->rst)
+			return false;
+	}
+
+	if (entry->tuple.is_ipv6) {
+		const struct ipv6hdr *ip6h;
+
+		if (l4_off != ETH_HLEN + sizeof(*ip6h))
+			return false;
+
+		ip6h = (const struct ipv6hdr *)(skb->data + ETH_HLEN);
+		return ip6h->hop_limit > 1;
+	}
+
+	{
+		const struct iphdr *iph;
+
+		iph = (const struct iphdr *)(skb->data + ETH_HLEN);
+		if (iph->ihl != sizeof(*iph) / 4 || ip_is_fragment(iph))
+			return false;
+
+		return iph->ttl > 1;
+	}
+}
+
+static void dpaa_ft_maybe_update_l4_addr(struct sk_buff *skb,
+					 const struct dpaa_ft_entry *entry,
+					 __be32 old_addr, __be32 new_addr,
+					 unsigned int l4_off)
+{
+	if (entry->tuple.ip_proto == IPPROTO_TCP) {
+		struct tcphdr *tcph = (struct tcphdr *)(skb->data + l4_off);
+
+		inet_proto_csum_replace4(&tcph->check, skb, old_addr, new_addr,
+					 false);
+		return;
+	}
+
+	{
+		struct udphdr *udph = (struct udphdr *)(skb->data + l4_off);
+
+		if (udph->check)
+			inet_proto_csum_replace4(&udph->check, skb, old_addr,
+						 new_addr, false);
+	}
+}
+
+static void dpaa_ft_maybe_update_l4_port(struct sk_buff *skb,
+					 const struct dpaa_ft_entry *entry,
+					 __be16 old_port, __be16 new_port,
+					 unsigned int l4_off)
+{
+	if (entry->tuple.ip_proto == IPPROTO_TCP) {
+		struct tcphdr *tcph = (struct tcphdr *)(skb->data + l4_off);
+
+		inet_proto_csum_replace2(&tcph->check, skb, old_port, new_port,
+					 false);
+		return;
+	}
+
+	{
+		struct udphdr *udph = (struct udphdr *)(skb->data + l4_off);
+
+		if (udph->check)
+			inet_proto_csum_replace2(&udph->check, skb, old_port,
+						 new_port, false);
+	}
+}
+
+static bool dpaa_ft_try_forward(struct dpaa_priv *priv,
+				struct rtnl_link_stats64 *percpu_stats,
+				struct sk_buff *skb)
+{
+	struct dpaa_ft_tuple tuple;
+	struct dpaa_ft_entry *entry;
+	unsigned int l4_off;
+	struct sk_buff *fwd_skb;
+	struct ethhdr *eth;
+	u32 tuple_hash;
+	int err;
+
+	if (!READ_ONCE(priv->ft.active))
+		return false;
+
+	err = dpaa_ft_parse_packet(skb, priv->net_dev->ifindex, &tuple, &l4_off);
+	if (err)
+		return false;
+
+	tuple_hash = dpaa_ft_tuple_hash(&tuple);
+
+	rcu_read_lock();
+	entry = dpaa_ft_lookup_tuple_rcu(priv, &tuple, tuple_hash);
+	if (!entry) {
+		rcu_read_unlock();
+		return false;
+	}
+
+	if (!dpaa_ft_skb_supported(entry, skb, l4_off)) {
+		dpaa_ft_count_fallback(priv, DPAA_FT_FALLBACK_PACKET);
+		rcu_read_unlock();
+		return false;
+	}
+
+	fwd_skb = skb_copy_expand(skb, LL_RESERVED_SPACE(entry->out_dev),
+				  entry->out_dev->needed_tailroom,
+				  GFP_ATOMIC);
+	if (!fwd_skb) {
+		dpaa_ft_count_fallback(priv, DPAA_FT_FALLBACK_NO_MEMORY);
+		rcu_read_unlock();
+		return false;
+	}
+
+	skb_scrub_packet(fwd_skb,
+			 !net_eq(dev_net(entry->out_dev), dev_net(priv->net_dev)));
+	skb_orphan(fwd_skb);
+	skb_set_queue_mapping(fwd_skb, 0);
+	skb_reset_mac_header(fwd_skb);
+	skb_set_network_header(fwd_skb, ETH_HLEN);
+	skb_set_transport_header(fwd_skb, l4_off);
+	fwd_skb->mac_len = ETH_HLEN;
+	fwd_skb->dev = entry->out_dev;
+	fwd_skb->priority = 0;
+	fwd_skb->ip_summed = CHECKSUM_NONE;
+
+	eth = eth_hdr(fwd_skb);
+	memcpy(eth->h_source, entry->l2.src, ETH_ALEN);
+	memcpy(eth->h_dest, entry->l2.dst, ETH_ALEN);
+
+	if (entry->tuple.is_ipv6) {
+		struct ipv6hdr *ip6h = ipv6_hdr(fwd_skb);
+
+		ip6h->hop_limit--;
+	} else {
+		struct iphdr *iph = ip_hdr(fwd_skb);
+
+		ip_decrease_ttl(iph);
+
+		if (entry->nat.addr_valid) {
+			__be32 old_addr;
+
+			if (entry->nat.type == DPAA_FT_NAT_SNAT) {
+				old_addr = iph->saddr;
+				iph->saddr = entry->nat.addr;
+			} else {
+				old_addr = iph->daddr;
+				iph->daddr = entry->nat.addr;
+			}
+
+			csum_replace4(&iph->check, old_addr, entry->nat.addr);
+			dpaa_ft_maybe_update_l4_addr(fwd_skb, entry, old_addr,
+						     entry->nat.addr, l4_off);
+		}
+
+		if (entry->nat.port_valid) {
+			__be16 old_port;
+
+			if (entry->tuple.ip_proto == IPPROTO_TCP) {
+				struct tcphdr *tcph = tcp_hdr(fwd_skb);
+
+				if (entry->nat.type == DPAA_FT_NAT_SNAT) {
+					old_port = tcph->source;
+					tcph->source = entry->nat.port;
+				} else {
+					old_port = tcph->dest;
+					tcph->dest = entry->nat.port;
+				}
+			} else {
+				struct udphdr *udph = udp_hdr(fwd_skb);
+
+				if (entry->nat.type == DPAA_FT_NAT_SNAT) {
+					old_port = udph->source;
+					udph->source = entry->nat.port;
+				} else {
+					old_port = udph->dest;
+					udph->dest = entry->nat.port;
+				}
+			}
+
+			dpaa_ft_maybe_update_l4_port(fwd_skb, entry, old_port,
+						     entry->nat.port, l4_off);
+		}
+	}
+
+	fwd_skb->protocol = htons(entry->tuple.n_proto);
+
+	err = dev_queue_xmit(fwd_skb);
+	if (unlikely(net_xmit_eval(err))) {
+		dpaa_ft_count_fallback(priv, DPAA_FT_FALLBACK_TX_ERROR);
+		rcu_read_unlock();
+		return false;
+	}
+
+	dpaa_ft_count_hit(priv, entry, skb->len);
+	percpu_stats->rx_packets++;
+	percpu_stats->rx_bytes += skb->len;
+	rcu_read_unlock();
+
+	consume_skb(skb);
+	return true;
+}
