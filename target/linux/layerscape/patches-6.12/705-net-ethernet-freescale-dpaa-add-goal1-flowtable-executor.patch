+	for (i = 0; i < DPAA_FT_FALLBACK_MAX && bytes < PAGE_SIZE; i++) {
+		s64 count;
+
+		if (!dpaa_ft_fallback_names[i])
+			continue;
+
+		count = atomic64_read(&priv->ft.fallbacks[i]);
+		if (!count)
+			continue;
+
+		bytes += scnprintf(buf + bytes, PAGE_SIZE - bytes,
+				   "fallback.%s %lld\n",
+				   dpaa_ft_fallback_names[i], count);
+	}
 	mutex_unlock(&priv->ft.lock);
 
 	return bytes;
