--- a/drivers/net/ethernet/freescale/fman/fman_hw_runtime.c
+++ b/drivers/net/ethernet/freescale/fman/fman_hw_runtime.c
@@ -0,0 +1,469 @@
+// SPDX-License-Identifier: BSD-3-Clause OR GPL-2.0-or-later
+/*
+ * Backend-private exact-class FMAN runtime staging.
+ *
+ * The live HC/PCD commit path remains later work. Stage 1 still owns the
+ * runtime object model, MURAM materialization, KeyGen reservation, rollback,
+ * and observability for the exact primary outbound class.
+ */
+
+#include <linux/err.h>
+#include <linux/etherdevice.h>
+#include <linux/if_pppox.h>
+#include <linux/ip.h>
+#include <linux/list.h>
+#include <linux/mutex.h>
+#include <linux/slab.h>
+#include <linux/tcp.h>
+#include <linux/udp.h>
+#include <linux/if_vlan.h>
+
+#include "fman_hw_runtime.h"
+#include "fman_muram.h"
+#include "fman_port.h"
+
+struct fman_hw_runtime {
+	struct fman *fman;
+	struct mutex lock;
+	struct list_head flows;
+	bool ready;
+	bool quiesced;
+	u32 next_generation;
+	u32 active_flows;
+	u64 prepare_count;
+	u64 prepare_failures;
+	u64 activate_count;
+	u64 activate_unavailable;
+	u64 activate_failures;
+	u64 remove_count;
+	u64 remove_failures;
+	u64 rollback_count;
+	u64 stats_queries;
+	int last_error;
+};
+
+struct fman_offload_flow {
+	struct list_head node;
+	struct fman_hw_runtime *runtime;
+	struct fman *fman;
+	struct fman_port *rx_port;
+	struct fman_port *tx_port;
+	struct fman_offload_snapshot snapshot;
+	size_t muram_size;
+};
+
+static struct fman_hw_runtime *fman_runtime(struct fman *fman)
+{
+	return fman ? fman->offload_runtime : NULL;
+}
+
+static void fman_hw_runtime_copy_bytes(u8 *dst, const u8 *src, size_t len)
+{
+	size_t i;
+
+	for (i = 0; i < len; i++)
+		dst[i] = src[i];
+}
+
+static void fman_hw_runtime_write_be16(u8 *dst, __be16 value)
+{
+	dst[0] = ((u8 *)&value)[0];
+	dst[1] = ((u8 *)&value)[1];
+}
+
+static int fman_hw_runtime_fill_template(struct fman_offload_flow *flow,
+					 const struct fman_offload_request *req)
+{
+	struct fman *fman = flow->fman;
+	struct fman_offload_snapshot *snapshot = &flow->snapshot;
+	__be16 vlan_tci;
+	__be16 pppoe_sid;
+	unsigned long vaddr;
+	unsigned long offset;
+	u8 *template;
+	size_t size;
+
+	size = ALIGN(ETH_HLEN + VLAN_HLEN + PPPOE_SES_HLEN, 16);
+	offset = fman_muram_alloc(fman->muram, size);
+	if (IS_ERR_VALUE(offset))
+		return -ENOMEM;
+
+	vaddr = fman_muram_offset_to_vbase(fman->muram, offset);
+	if (!vaddr) {
+		fman_muram_free_mem(fman->muram, offset, size);
+		return -ENOMEM;
+	}
+
+	template = (u8 *)vaddr;
+	vlan_tci = htons((u16)(req->vlan_vid & VLAN_VID_MASK) |
+			 ((u16)(req->vlan_prio & 0x7) << VLAN_PRIO_SHIFT));
+	pppoe_sid = htons(req->pppoe_sid);
+
+	/*
+	 * MURAM staging buffers may fault on widened unaligned stores. Build
+	 * the exact-class header template bytewise so the source MAC at +6 and
+	 * the PPPoE payload fields do not rely on packed-struct writes.
+	 */
+	fman_hw_runtime_copy_bytes(template, req->dst, ETH_ALEN);
+	fman_hw_runtime_copy_bytes(template + ETH_ALEN, req->src, ETH_ALEN);
+	fman_hw_runtime_write_be16(template + 2 * ETH_ALEN, req->vlan_proto);
+	fman_hw_runtime_write_be16(template + 2 * ETH_ALEN + 2, vlan_tci);
+	fman_hw_runtime_write_be16(template + 2 * ETH_ALEN + 4,
+				   htons(ETH_P_PPP_SES));
+	template[ETH_HLEN + VLAN_HLEN] = 0x11;
+	template[ETH_HLEN + VLAN_HLEN + 1] = 0x00;
+	fman_hw_runtime_write_be16(template + ETH_HLEN + VLAN_HLEN + 2,
+				   pppoe_sid);
+	fman_hw_runtime_write_be16(template + ETH_HLEN + VLAN_HLEN + 4, 0);
+	fman_hw_runtime_write_be16(template + ETH_HLEN + VLAN_HLEN + 6,
+				   req->ppp_proto);
+
+	flow->muram_size = size;
+	snapshot->hm.muram_offset = offset;
+	snapshot->hm.template_len = ETH_HLEN + VLAN_HLEN + PPPOE_SES_HLEN;
+	snapshot->hm.pppoe_len_offset =
+		ETH_HLEN + VLAN_HLEN + offsetof(struct pppoe_hdr, length);
+	snapshot->hm.snat_addr_offset =
+		snapshot->hm.template_len + offsetof(struct iphdr, saddr);
+	snapshot->hm.snat_port_offset =
+		snapshot->hm.template_len + sizeof(struct iphdr) +
+		offsetof(struct udphdr, source);
+
+	return 0;
+}
+
+static void fman_hw_runtime_snapshot(struct fman_offload_flow *flow,
+				     struct fman_offload_snapshot *snapshot)
+{
+	if (!snapshot)
+		return;
+
+	*snapshot = flow->snapshot;
+}
+
+static void fman_hw_runtime_rollback(struct fman_offload_flow *flow)
+{
+	struct fman_hw_runtime *runtime = flow->runtime;
+
+	if (flow->snapshot.ingress.keygen_reserved)
+		fman_port_release_kg_scheme(flow->rx_port,
+					    flow->snapshot.ingress
+						    .keygen_scheme_id);
+
+	if (flow->snapshot.hm.valid && flow->muram_size)
+		fman_muram_free_mem(flow->fman->muram,
+				    flow->snapshot.hm.muram_offset,
+				    flow->muram_size);
+
+	runtime->rollback_count++;
+}
+
+static int fman_hw_runtime_validate_request(struct fman *fman,
+					    struct fman_port *rx_port,
+					    struct fman_port *tx_port,
+					    const struct fman_offload_request *req)
+{
+	if (!fman || !rx_port || !tx_port || !req)
+		return -EINVAL;
+
+	if (req->exact_class !=
+	    FMAN_OFFLOAD_EXACT_CLASS_PRIMARY_OUTBOUND_ETH2_PPPOE_WAN)
+		return -EOPNOTSUPP;
+
+	if (req->network_proto != htons(ETH_P_IP))
+		return -EOPNOTSUPP;
+
+	if (req->ip_proto != IPPROTO_TCP && req->ip_proto != IPPROTO_UDP)
+		return -EOPNOTSUPP;
+
+	if (req->vlan_proto != htons(ETH_P_8021Q) || req->vlan_vid != 10 ||
+	    !req->pppoe_sid)
+		return -EOPNOTSUPP;
+
+	return 0;
+}
+
+int fman_hw_runtime_init(struct fman *fman)
+{
+	struct fman_hw_runtime *runtime;
+
+	if (!fman)
+		return -EINVAL;
+
+	runtime = kzalloc(sizeof(*runtime), GFP_KERNEL);
+	if (!runtime)
+		return -ENOMEM;
+
+	runtime->fman = fman;
+	runtime->ready = !!(fman->muram && fman->keygen);
+	INIT_LIST_HEAD(&runtime->flows);
+	mutex_init(&runtime->lock);
+	fman->offload_runtime = runtime;
+
+	return 0;
+}
+
+void fman_hw_runtime_destroy(struct fman *fman)
+{
+	struct fman_hw_runtime *runtime = fman_runtime(fman);
+	struct fman_offload_flow *flow, *tmp;
+
+	if (!runtime)
+		return;
+
+	mutex_lock(&runtime->lock);
+	list_for_each_entry_safe(flow, tmp, &runtime->flows, node) {
+		list_del(&flow->node);
+		fman_hw_runtime_rollback(flow);
+		kfree(flow);
+	}
+	mutex_unlock(&runtime->lock);
+
+	kfree(runtime);
+	fman->offload_runtime = NULL;
+}
+
+int fman_hw_runtime_get_state(struct fman *fman,
+			      struct fman_offload_runtime_state *state)
+{
+	struct fman_hw_runtime *runtime = fman_runtime(fman);
+
+	if (!runtime || !state)
+		return -EINVAL;
+
+	mutex_lock(&runtime->lock);
+	state->ready = runtime->ready;
+	state->quiesced = runtime->quiesced;
+	state->live_commit_available = false;
+	state->active_flows = runtime->active_flows;
+	state->prepare_count = runtime->prepare_count;
+	state->prepare_failures = runtime->prepare_failures;
+	state->activate_count = runtime->activate_count;
+	state->activate_unavailable = runtime->activate_unavailable;
+	state->activate_failures = runtime->activate_failures;
+	state->remove_count = runtime->remove_count;
+	state->remove_failures = runtime->remove_failures;
+	state->rollback_count = runtime->rollback_count;
+	state->stats_queries = runtime->stats_queries;
+	state->last_error = runtime->last_error;
+	mutex_unlock(&runtime->lock);
+
+	return 0;
+}
+
+int fman_hw_runtime_prepare_exact(struct fman *fman,
+				  struct fman_port *rx_port,
+				  struct fman_port *tx_port,
+				  const struct fman_offload_request *req,
+				  struct fman_offload_flow **flow_out,
+				  struct fman_offload_snapshot *snapshot)
+{
+	struct fman_hw_runtime *runtime = fman_runtime(fman);
+	struct fman_offload_flow *flow;
+	u8 scheme_id;
+	u32 hash_result_offset = 0;
+	int err;
+
+	if (!runtime || !flow_out)
+		return -EINVAL;
+
+	mutex_lock(&runtime->lock);
+	runtime->prepare_count++;
+	err = fman_hw_runtime_validate_request(fman, rx_port, tx_port, req);
+	if (err)
+		goto fail_locked;
+
+	if (!runtime->ready || runtime->quiesced) {
+		err = -EOPNOTSUPP;
+		goto fail_locked;
+	}
+
+	flow = kzalloc(sizeof(*flow), GFP_KERNEL);
+	if (!flow) {
+		err = -ENOMEM;
+		goto fail_locked;
+	}
+
+	flow->runtime = runtime;
+	flow->fman = fman;
+	flow->rx_port = rx_port;
+	flow->tx_port = tx_port;
+	flow->snapshot.valid = true;
+	flow->snapshot.cookie = req->cookie;
+	flow->snapshot.generation = ++runtime->next_generation;
+	flow->snapshot.exact_class = req->exact_class;
+	flow->snapshot.lifecycle = FMAN_OFFLOAD_LIFECYCLE_PREPARED;
+	flow->snapshot.binding = req->binding;
+	flow->snapshot.enqueue.valid = true;
+	flow->snapshot.enqueue.tx_port_id = req->binding.tx_port_id;
+	flow->snapshot.enqueue.qman_channel_id =
+		fman_port_get_qman_channel_id(tx_port);
+	flow->snapshot.enqueue.compiled_out_ifindex = req->compiled_out_ifindex;
+	flow->snapshot.enqueue.logical_out_ifindex = req->logical_out_ifindex;
+	flow->snapshot.enqueue.binding_ifindex = req->binding_ifindex;
+	flow->snapshot.hm.valid = true;
+	flow->snapshot.hm.header_len = ETH_HLEN + VLAN_HLEN + PPPOE_SES_HLEN;
+	ether_addr_copy(flow->snapshot.hm.src, req->src);
+	ether_addr_copy(flow->snapshot.hm.dst, req->dst);
+	flow->snapshot.hm.vlan_vid = req->vlan_vid;
+	flow->snapshot.hm.vlan_proto = req->vlan_proto;
+	flow->snapshot.hm.vlan_prio = req->vlan_prio;
+	flow->snapshot.hm.pppoe_sid = req->pppoe_sid;
+	flow->snapshot.hm.ppp_proto = req->ppp_proto;
+	flow->snapshot.hm.snat_addr = req->snat_addr;
+	flow->snapshot.hm.snat_port_valid = req->snat_port_valid;
+	flow->snapshot.hm.snat_port = req->snat_port;
+	flow->snapshot.ingress.valid = true;
+	flow->snapshot.ingress.uses_port_private_key = true;
+	flow->snapshot.stats.valid = true;
+
+	if (!fman_port_get_hash_result_offset(rx_port, &hash_result_offset))
+		flow->snapshot.ingress.hash_result_offset = hash_result_offset;
+
+	err = fman_port_reserve_kg_scheme(rx_port, &scheme_id);
+	if (err)
+		goto fail_flow;
+
+	flow->snapshot.ingress.keygen_reserved = true;
+	flow->snapshot.ingress.keygen_scheme_id = scheme_id;
+
+	err = fman_hw_runtime_fill_template(flow, req);
+	if (err)
+		goto fail_flow;
+
+	flow->snapshot.lifecycle = FMAN_OFFLOAD_LIFECYCLE_OBJECTS_STAGED;
+	flow->snapshot.live_commit_available = false;
+	list_add_tail(&flow->node, &runtime->flows);
+	runtime->active_flows++;
+	runtime->last_error = 0;
+	mutex_unlock(&runtime->lock);
+
+	*flow_out = flow;
+	fman_hw_runtime_snapshot(flow, snapshot);
+
+	return 0;
+
+fail_flow:
+	flow->snapshot.last_error = err;
+	fman_hw_runtime_rollback(flow);
+	kfree(flow);
+fail_locked:
+	runtime->prepare_failures++;
+	runtime->last_error = err;
+	mutex_unlock(&runtime->lock);
+
+	return err;
+}
+
+int fman_hw_runtime_activate(struct fman_offload_flow *flow,
+			     struct fman_offload_snapshot *snapshot)
+{
+	struct fman_hw_runtime *runtime;
+
+	if (!flow)
+		return -EINVAL;
+
+	runtime = flow->runtime;
+	mutex_lock(&runtime->lock);
+	runtime->activate_count++;
+	runtime->activate_unavailable++;
+	runtime->last_error = -EOPNOTSUPP;
+	flow->snapshot.last_error = -EOPNOTSUPP;
+	flow->snapshot.lifecycle = FMAN_OFFLOAD_LIFECYCLE_ACTIVATE_UNAVAILABLE;
+	fman_hw_runtime_snapshot(flow, snapshot);
+	mutex_unlock(&runtime->lock);
+
+	return -EOPNOTSUPP;
+}
+
+int fman_hw_runtime_remove(struct fman_offload_flow *flow,
+			   struct fman_offload_snapshot *snapshot)
+{
+	struct fman_hw_runtime *runtime;
+
+	if (!flow)
+		return -EINVAL;
+
+	runtime = flow->runtime;
+	mutex_lock(&runtime->lock);
+	runtime->remove_count++;
+	flow->snapshot.lifecycle = FMAN_OFFLOAD_LIFECYCLE_REMOVED;
+	flow->snapshot.last_error = 0;
+	fman_hw_runtime_snapshot(flow, snapshot);
+	list_del(&flow->node);
+	runtime->active_flows--;
+	fman_hw_runtime_rollback(flow);
+	runtime->last_error = 0;
+	mutex_unlock(&runtime->lock);
+
+	kfree(flow);
+
+	return 0;
+}
+
+int fman_hw_runtime_get_stats(struct fman_offload_flow *flow,
+			      struct fman_offload_stats *stats)
+{
+	struct fman_hw_runtime *runtime;
+
+	if (!flow || !stats)
+		return -EINVAL;
+
+	runtime = flow->runtime;
+	mutex_lock(&runtime->lock);
+	runtime->stats_queries++;
+	flow->snapshot.stats.reads++;
+	stats->hardware_counters_available = false;
+	stats->packets = flow->snapshot.stats.last_packets;
+	stats->bytes = flow->snapshot.stats.last_bytes;
+	stats->reads = flow->snapshot.stats.reads;
+	runtime->last_error = -EOPNOTSUPP;
+	flow->snapshot.last_error = -EOPNOTSUPP;
+	mutex_unlock(&runtime->lock);
+
+	return -EOPNOTSUPP;
+}
+
+int fman_hw_runtime_get_snapshot(struct fman_offload_flow *flow,
+				 struct fman_offload_snapshot *snapshot)
+{
+	struct fman_hw_runtime *runtime;
+
+	if (!flow || !snapshot)
+		return -EINVAL;
+
+	runtime = flow->runtime;
+	mutex_lock(&runtime->lock);
+	fman_hw_runtime_snapshot(flow, snapshot);
+	mutex_unlock(&runtime->lock);
+
+	return 0;
+}
+
+int fman_hw_runtime_quiesce(struct fman *fman)
+{
+	struct fman_hw_runtime *runtime = fman_runtime(fman);
+
+	if (!runtime)
+		return -EINVAL;
+
+	mutex_lock(&runtime->lock);
+	runtime->quiesced = true;
+	mutex_unlock(&runtime->lock);
+
+	return 0;
+}
+
+int fman_hw_runtime_resume(struct fman *fman)
+{
+	struct fman_hw_runtime *runtime = fman_runtime(fman);
+
+	if (!runtime)
+		return -EINVAL;
+
+	mutex_lock(&runtime->lock);
+	runtime->quiesced = false;
+	mutex_unlock(&runtime->lock);
+
+	return 0;
+}
