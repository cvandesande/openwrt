+static const char *dpaa_ft_fman_hw_live_commit_unavailable_reason(void)
+{
+	return "hardware flow offloading requested, and the FMAN backend staged the exact eth2 outbound object surface, but live FMAN commit is still unavailable because the in-tree seam does not expose header-manipulation and enqueue object commit APIs; flows stay on the normal Linux path";
+}
