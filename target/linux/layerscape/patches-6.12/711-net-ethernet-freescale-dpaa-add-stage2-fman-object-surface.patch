+static int dpaa_ft_fman_hw_build_stage2_surface(struct dpaa_priv *priv,
+						const struct dpaa_ft_entry *entry,
+						struct dpaa_ft_hw_result *result)
+{
+	struct dpaa_ft_hw_backend *hw = &priv->ft.hw;
+	struct dpaa_ft_hw_stage2_egress_path egress_path;
+	const char *reason = NULL;
+
+	if (!hw->plan.valid || !hw->res.keygen_reserved ||
+	    hw->res.generation != hw->plan.generation ||
+	    hw->plan.cookie != entry->cookie) {
+		hw->stage2_surface_failures++;
+		hw->install_failures++;
+		hw->last_error = -EINVAL;
+		dpaa_ft_hw_set_lifecycle(hw, DPAA_FT_HW_LIFECYCLE_INSTALL_FAILED);
+		result->lifecycle = hw->last_lifecycle;
+		result->degrade = DPAA_FT_HW_DEGRADE_INSTALL_FAILED;
+		result->reject_reason = DPAA_FT_REJECT_HW_INSTALL_FAILED;
+		result->err = -EINVAL;
+		result->message = "hardware flow offloading requested, but the FMAN backend could not bind Stage 2 objects to the staged install-plan generation; flows stay on the normal Linux path";
+		return result->err;
+	}
+
+	if (!dpaa_ft_fman_hw_resolve_stage2_primary_egress(priv, entry,
+							    &egress_path,
+							    &reason)) {
+		hw->stage2_surface_failures++;
+		hw->install_failures++;
+		hw->last_error = -EOPNOTSUPP;
+		dpaa_ft_hw_set_lifecycle(hw, DPAA_FT_HW_LIFECYCLE_INSTALL_FAILED);
+		result->lifecycle = hw->last_lifecycle;
+		result->degrade = DPAA_FT_HW_DEGRADE_INSTALL_FAILED;
+		result->reject_reason = DPAA_FT_REJECT_HW_INSTALL_FAILED;
+		result->err = -EOPNOTSUPP;
+		result->message = reason;
+		return result->err;
+	}
+
+	dpaa_ft_hw_clear_stage2_surface(hw);
+	hw->stage2.valid = true;
+	hw->stage2.cookie = entry->cookie;
+	hw->stage2.generation = hw->res.generation;
+	hw->stage2.exact_class =
+		DPAA_FT_HW_STAGE2_CLASS_PRIMARY_OUTBOUND_ETH2_PPPoE_WAN;
+	hw->stage2.binding = hw->res.binding;
+	hw->stage2.ingress.valid = true;
+	hw->stage2.ingress.rx_port_id = hw->res.binding.rx_port_id;
+	hw->stage2.ingress.keygen_scheme_id = hw->res.keygen_scheme_id;
+	hw->stage2.ingress.rx_pcd_base_fqid = hw->res.binding.rx_pcd_base_fqid;
+	hw->stage2.ingress.rx_pcd_fq_count = hw->res.binding.rx_pcd_fq_count;
