+	hw->stage2.ingress.ip_proto = entry->tuple.ip_proto;
+	hw->stage2.ingress.uses_port_private_key = true;
+	hw->stage2.hm.valid = true;
+	hw->stage2.hm.header_len =
+		ETH_HLEN + dpaa_ft_egress_recipe_encap_len(&entry->egress);
+	memcpy(hw->stage2.hm.src, entry->egress.l2.src, ETH_ALEN);
+	memcpy(hw->stage2.hm.dst, entry->egress.l2.dst, ETH_ALEN);
+	hw->stage2.hm.vlan_vid = entry->egress.vlan_push.vid;
+	hw->stage2.hm.vlan_proto = entry->egress.vlan_push.proto;
+	hw->stage2.hm.vlan_prio = entry->egress.vlan_push.prio;
+	hw->stage2.hm.pppoe_sid = entry->egress.pppoe_push.sid;
+	hw->stage2.hm.ppp_proto = dpaa_ft_egress_ppp_proto(entry);
+	hw->stage2.hm.snat_addr = entry->egress.nat.addr;
+	hw->stage2.hm.snat_port_valid = entry->egress.nat.port_valid;
+	hw->stage2.hm.snat_port = entry->egress.nat.port;
+	hw->stage2.enqueue.valid = true;
+	hw->stage2.enqueue.tx_port_id = hw->res.binding.tx_port_id;
+	hw->stage2.enqueue.compiled_out_ifindex =
+		egress_path.compiled_out_ifindex;
+	hw->stage2.enqueue.logical_out_ifindex =
