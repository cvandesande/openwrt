+static bool
+dpaa_ft_fman_hw_find_stage2_primary_vlan_upper(struct net_device *lower_dev,
+					       __be16 vlan_proto, u16 vlan_vid,
+					       u32 *logical_out_ifindex,
+					       const char **reason)
+{
+	struct net_device *upper_dev;
+	struct list_head *iter;
+	u32 match_ifindex = 0;
+
+	rcu_read_lock();
+	netdev_for_each_upper_dev_rcu(lower_dev, upper_dev, iter) {
+		if (!is_vlan_dev(upper_dev))
+			continue;
+
+		if (vlan_dev_real_dev(upper_dev) != lower_dev)
+			continue;
+
+		if (strcmp(netdev_name(upper_dev), "eth0.10") != 0)
+			continue;
+
+		if (vlan_dev_vlan_proto(upper_dev) != vlan_proto ||
+		    vlan_dev_vlan_id(upper_dev) != vlan_vid)
+			continue;
+
+		if (match_ifindex) {
+			match_ifindex = 0;
+			break;
+		}
+
+		match_ifindex = upper_dev->ifindex;
+	}
+	rcu_read_unlock();
+
+	if (!match_ifindex) {
+		*reason = "hardware flow offloading requested, but Stage 2 requires the exact eth0.10 VLAN upper on the validated WAN path; flows stay on the normal Linux path";
+		return false;
+	}
+
+	*logical_out_ifindex = match_ifindex;
+
+	return true;
+}
+
+/*
+ * The validated Stage 2 WAN class is represented in-tree as an exact lower
+ * Ethernet redirect plus one exact VLAN 10 push and one exact PPPoE push.
+ * Keep the logical eth0.10 path private to the backend and derive the FMAN TX
+ * identity from the resolved lower DPAA device that owns that path.
+ */
+static bool
+dpaa_ft_fman_hw_resolve_stage2_primary_egress(struct dpaa_priv *priv,
+					      const struct dpaa_ft_entry *entry,
+					      struct dpaa_ft_hw_stage2_egress_path *path,
+					      const char **reason)
+{
+	struct net_device *out_dev = entry->egress.out_dev;
+	struct dpaa_priv *out_priv;
+	u32 logical_out_ifindex;
+
+	if (!out_dev || out_dev->type != ARPHRD_ETHER) {
+		*reason = "hardware flow offloading requested, but Stage 2 requires exact Ethernet redirect; flows stay on the normal Linux path";
+		return false;
+	}
+
+	if (is_vlan_dev(out_dev) || strcmp(netdev_name(out_dev), "eth0") != 0) {
+		*reason = "hardware flow offloading requested, but Stage 2 only covers the exact eth0 lower redirect for the validated eth0.10 PPPoE WAN path; flows stay on the normal Linux path";
+		return false;
+	}
+
+	if (!dpaa_ft_fman_hw_find_stage2_primary_vlan_upper(
+		    out_dev, entry->egress.vlan_push.proto,
+		    entry->egress.vlan_push.vid, &logical_out_ifindex,
+		    reason))
+		return false;
+
+	if (out_dev->netdev_ops != priv->net_dev->netdev_ops) {
+		*reason = "hardware flow offloading requested, but Stage 2 could not map the validated WAN lower device to a DPAA FMAN binding; flows stay on the normal Linux path";
+		return false;
+	}
+
+	out_priv = netdev_priv(out_dev);
+	if (!out_priv->mac_dev || !out_priv->fman.ports_bound ||
+	    !out_priv->mac_dev->port[TX]) {
+		*reason = "hardware flow offloading requested, but Stage 2 could not resolve the FMAN TX binding for the validated WAN lower device; flows stay on the normal Linux path";
+		return false;
+	}
+
+	if (!path)
+		return true;
+
+	path->binding_dev = out_dev;
+	path->binding_priv = out_priv;
+	path->compiled_out_ifindex = entry->egress.out_ifindex;
+	path->logical_out_ifindex = logical_out_ifindex;
+
+	return true;
+}
