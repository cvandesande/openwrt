@@ -7,6 +7,7 @@
 #define __FMAN_PORT_H
 
 #include "fman.h"
+#include "fman_keygen.h"
 
 /* FM Port API
  * The FM uses a general module called "port" to represent a Tx port (MAC),
@@ -132,6 +133,12 @@
 int fman_port_get_offload_info(struct fman_port *port,
 			       struct fman_port_offload_info *info);
 
+int fman_port_add_kg_scheme(struct fman_port *port,
+			    const struct fman_kg_scheme_params *params,
+			    u8 *scheme_id);
+
+int fman_port_del_kg_scheme(struct fman_port *port, u8 scheme_id);
+
 int fman_port_get_hash_result_offset(struct fman_port *port, u32 *offset);
 
 int fman_port_get_tstamp(struct fman_port *port, const void *data, u64 *tstamp);
