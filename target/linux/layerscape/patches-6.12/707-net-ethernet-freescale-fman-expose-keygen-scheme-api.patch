From: OpenAI Codex <codex@openai.com>
Subject: [PATCH] net: ethernet: freescale: fman: expose narrow KeyGen
 scheme API

Expose a narrow FMAN KeyGen scheme programming API and surface it
through `fman_port` so later DPAA flowtable work can own an explicit
hardware object at install time without reaching into FMAN internals.

Keep the current port hashing behaviour unchanged by rewriting
`keygen_port_hashing_init()` on top of the new API. Do not yet steer
flowtable traffic with this patch; it establishes the first reviewable
FMAN programming seam for later Goal 2 work.

---
--- a/drivers/net/ethernet/freescale/fman/fman_keygen.c
+++ b/drivers/net/ethernet/freescale/fman/fman_keygen.c
@@ -222,6 +222,10 @@
 		 * 0 means using the 24 LSB's, otherwise
 		 * use the 24 LSB's after shifting right
 		 */
+	u32 extract_known_fields;	/* Known-field extraction mask */
+	u32 extract_known_default;	/* Default-value selection mask */
+	u32 default_value0;		/* KGSE_DV0 */
+	u32 default_value1;		/* KGSE_DV1 */
 	u32 match_vector;	/* Match Vector */
 };
 
@@ -551,20 +555,16 @@
 
 	if (scheme->use_hashing) {
 		/* configure kgse_ekfc */
-		scheme_regs.kgse_ekfc = DEFAULT_HASH_KEY_EXTRACT_FIELDS;
+		scheme_regs.kgse_ekfc = scheme->extract_known_fields;
 
 		/* configure kgse_ekdv */
-		tmp_reg = 0;
-		tmp_reg |= (KG_SCH_DEF_USE_KGSE_DV_0 <<
-				KG_SCH_DEF_IP_ADDR_SHIFT);
-		tmp_reg |= (KG_SCH_DEF_USE_KGSE_DV_1 <<
-				KG_SCH_DEF_L4_PORT_SHIFT);
+		tmp_reg = scheme->extract_known_default;
 		scheme_regs.kgse_ekdv = tmp_reg;
 
 		/* configure kgse_dv0 */
-		scheme_regs.kgse_dv0 = DEFAULT_HASH_KEY_IPv4_ADDR;
+		scheme_regs.kgse_dv0 = scheme->default_value0;
 		/* configure kgse_dv1 */
-		scheme_regs.kgse_dv1 = DEFAULT_HASH_KEY_L4_PORT;
+		scheme_regs.kgse_dv1 = scheme->default_value1;
 
 		/* configure kgse_hc  */
 		tmp_reg = 0;
@@ -674,44 +674,40 @@
 }
 EXPORT_SYMBOL(keygen_init);
 
-/* keygen_port_hashing_init
- *
- * Initializes a port for Rx Hashing with specified configuration parameters
- *
- * keygen: KeyGen handle
- * hw_port_id: HW Port ID
- * hash_base_fqid: Hashing Base FQID used for spreading
- * hash_size: Hashing size
- *
- * Return: Zero for success or error code in case of failure
- */
-int keygen_port_hashing_init(struct fman_keygen *keygen, u8 hw_port_id,
-			     u32 hash_base_fqid, u32 hash_size)
+int keygen_port_scheme_alloc(struct fman_keygen *keygen, u8 hw_port_id,
+			     const struct fman_kg_scheme_params *params,
+			     u8 *scheme_id)
 {
 	struct keygen_scheme *scheme;
-	u8 scheme_id;
+	u8 id;
 	int err;
 
-	/* Validate Scheme configuration parameters */
-	if (hash_base_fqid == 0 || (hash_base_fqid & ~0x00FFFFFF)) {
+	if (!keygen || !params || !scheme_id)
+		return -EINVAL;
+
+	if (hw_port_id >= FMAN_MAX_NUM_OF_HW_PORTS)
+		return -EINVAL;
+
+	if (params->base_fqid == 0 || (params->base_fqid & ~0x00FFFFFF)) {
 		pr_err("Base FQID must be between 1 and 2^24-1\n");
 		return -EINVAL;
 	}
-	if (hash_size == 0 || (hash_size & (hash_size - 1)) != 0) {
+
+	if (params->use_hashing &&
+	    (params->hash_fqid_count == 0 ||
+	     (params->hash_fqid_count &
+	      (params->hash_fqid_count - 1)) != 0)) {
 		pr_err("Hash size must be power of two\n");
 		return -EINVAL;
 	}
 
-	/* Find a free scheme */
-	err = get_free_scheme_id(keygen, &scheme_id);
+	err = get_free_scheme_id(keygen, &id);
 	if (err) {
 		pr_err("The maximum number of available Schemes has been exceeded\n");
 		return -EINVAL;
 	}
 
-	/* Create and configure Hard-Coded Scheme: */
-
-	scheme = get_scheme(keygen, scheme_id);
+	scheme = get_scheme(keygen, id);
 	if (!scheme) {
 		pr_err("Requested Scheme does not exist\n");
 		return -EINVAL;
@@ -721,37 +717,98 @@
 		return -EINVAL;
 	}
 
-	/* Clear all scheme fields because the scheme may have been
-	 * previously used
-	 */
-	memset(scheme, 0, sizeof(struct keygen_scheme));
+	memset(scheme, 0, sizeof(*scheme));
 
-	/* Setup scheme: */
 	scheme->hw_port_id = hw_port_id;
-	scheme->use_hashing = true;
-	scheme->base_fqid = hash_base_fqid;
-	scheme->hash_fqid_count = hash_size;
-	scheme->symmetric_hash = DEFAULT_SYMMETRIC_HASH;
-	scheme->hashShift = DEFAULT_HASH_SHIFT;
+	scheme->base_fqid = params->base_fqid;
+	scheme->hash_fqid_count = params->use_hashing ?
+				  params->hash_fqid_count : 1;
+	scheme->use_hashing = params->use_hashing;
+	scheme->symmetric_hash = params->symmetric_hash;
+	scheme->hashShift = params->hash_shift;
+	scheme->extract_known_fields = params->extract_known_fields;
+	scheme->extract_known_default = params->extract_known_default;
+	scheme->default_value0 = params->default_value0;
+	scheme->default_value1 = params->default_value1;
+	scheme->match_vector = params->match_vector;
 
-	/* All Schemes in hard-coded configuration
-	 * are Indirect Schemes
-	 */
-	scheme->match_vector = 0;
-
-	err = keygen_scheme_setup(keygen, scheme_id, true);
+	err = keygen_scheme_setup(keygen, id, true);
 	if (err != 0) {
 		pr_err("Scheme setup failed\n");
+		memset(scheme, 0, sizeof(*scheme));
 		return err;
 	}
 
-	/* Bind Rx port to Scheme */
-	err = keygen_bind_port_to_schemes(keygen, scheme_id, true);
+	err = keygen_bind_port_to_schemes(keygen, id, true);
 	if (err != 0) {
 		pr_err("Binding port to schemes failed\n");
+		keygen_scheme_setup(keygen, id, false);
+		memset(scheme, 0, sizeof(*scheme));
 		return err;
 	}
 
+	*scheme_id = id;
+
 	return 0;
 }
+EXPORT_SYMBOL(keygen_port_scheme_alloc);
+
+int keygen_port_scheme_free(struct fman_keygen *keygen, u8 scheme_id)
+{
+	struct keygen_scheme *scheme;
+	int err;
+
+	if (!keygen)
+		return -EINVAL;
+
+	scheme = get_scheme(keygen, scheme_id);
+	if (!scheme || !scheme->used)
+		return -ENOENT;
+
+	err = keygen_bind_port_to_schemes(keygen, scheme_id, false);
+	if (err != 0)
+		return err;
+
+	err = keygen_scheme_setup(keygen, scheme_id, false);
+	if (err != 0)
+		return err;
+
+	memset(scheme, 0, sizeof(*scheme));
+
+	return 0;
+}
+EXPORT_SYMBOL(keygen_port_scheme_free);
+
+/* keygen_port_hashing_init
+ *
+ * Initializes a port for Rx Hashing with specified configuration parameters
+ *
+ * keygen: KeyGen handle
+ * hw_port_id: HW Port ID
+ * hash_base_fqid: Hashing Base FQID used for spreading
+ * hash_size: Hashing size
+ *
+ * Return: Zero for success or error code in case of failure
+ */
+int keygen_port_hashing_init(struct fman_keygen *keygen, u8 hw_port_id,
+			     u32 hash_base_fqid, u32 hash_size)
+{
+	struct fman_kg_scheme_params params = {
+		.base_fqid = hash_base_fqid,
+		.hash_fqid_count = hash_size,
+		.extract_known_fields = DEFAULT_HASH_KEY_EXTRACT_FIELDS,
+		.extract_known_default =
+			(KG_SCH_DEF_USE_KGSE_DV_0 << KG_SCH_DEF_IP_ADDR_SHIFT) |
+			(KG_SCH_DEF_USE_KGSE_DV_1 << KG_SCH_DEF_L4_PORT_SHIFT),
+		.default_value0 = DEFAULT_HASH_KEY_IPv4_ADDR,
+		.default_value1 = DEFAULT_HASH_KEY_L4_PORT,
+		.use_hashing = true,
+		.symmetric_hash = DEFAULT_SYMMETRIC_HASH,
+		.hash_shift = DEFAULT_HASH_SHIFT,
+		.match_vector = 0,
+	};
+	u8 scheme_id;
+
+	return keygen_port_scheme_alloc(keygen, hw_port_id, &params, &scheme_id);
+}
 EXPORT_SYMBOL(keygen_port_hashing_init);
--- a/drivers/net/ethernet/freescale/fman/fman_keygen.h
+++ b/drivers/net/ethernet/freescale/fman/fman_keygen.h
@@ -11,8 +11,26 @@
 struct fman_keygen;
 struct fman_kg_regs;
 
+struct fman_kg_scheme_params {
+	u32 base_fqid;
+	u32 hash_fqid_count;
+	u32 extract_known_fields;
+	u32 extract_known_default;
+	u32 default_value0;
+	u32 default_value1;
+	u32 match_vector;
+	bool use_hashing;
+	bool symmetric_hash;
+	u8 hash_shift;
+};
+
 struct fman_keygen *keygen_init(struct fman_kg_regs __iomem *keygen_regs);
 
+int keygen_port_scheme_alloc(struct fman_keygen *keygen, u8 hw_port_id,
+			     const struct fman_kg_scheme_params *params,
+			     u8 *scheme_id);
+int keygen_port_scheme_free(struct fman_keygen *keygen, u8 scheme_id);
+
 int keygen_port_hashing_init(struct fman_keygen *keygen, u8 hw_port_id,
 			     u32 hash_base_fqid, u32 hash_size);
 
--- a/drivers/net/ethernet/freescale/fman/fman_port.c
+++ b/drivers/net/ethernet/freescale/fman/fman_port.c
@@ -1718,6 +1718,39 @@
 }
 EXPORT_SYMBOL(fman_port_get_offload_info);
 
+int fman_port_add_kg_scheme(struct fman_port *port,
+			    const struct fman_kg_scheme_params *params,
+			    u8 *scheme_id)
+{
+	if (!port || !params || !scheme_id)
+		return -EINVAL;
+
+	if (port->port_type != FMAN_PORT_TYPE_RX)
+		return -EOPNOTSUPP;
+
+	if (!port->dts_params.fman || !port->dts_params.fman->keygen)
+		return -EOPNOTSUPP;
+
+	return keygen_port_scheme_alloc(port->dts_params.fman->keygen,
+					port->port_id, params, scheme_id);
+}
+EXPORT_SYMBOL(fman_port_add_kg_scheme);
+
+int fman_port_del_kg_scheme(struct fman_port *port, u8 scheme_id)
+{
+	if (!port)
+		return -EINVAL;
+
+	if (port->port_type != FMAN_PORT_TYPE_RX)
+		return -EOPNOTSUPP;
+
+	if (!port->dts_params.fman || !port->dts_params.fman->keygen)
+		return -EOPNOTSUPP;
+
+	return keygen_port_scheme_free(port->dts_params.fman->keygen, scheme_id);
+}
+EXPORT_SYMBOL(fman_port_del_kg_scheme);
+
 /**
  * fman_port_get_device
  * @port:	Pointer to the FMan port device
--- a/drivers/net/ethernet/freescale/fman/fman_port.h
