+int keygen_get_state(struct fman_keygen *keygen,
+		     struct fman_keygen_state *state)
+{
+	u8 i, used = 0;
+
+	if (!keygen || !state)
+		return -EINVAL;
+
+	for (i = 0; i < FM_KG_MAX_NUM_OF_SCHEMES; i++)
+		if (keygen->schemes[i].used)
+			used++;
+
+	state->scheme_total = FM_KG_MAX_NUM_OF_SCHEMES;
+	state->scheme_in_use = used;
+
+	return 0;
+}
+EXPORT_SYMBOL(keygen_get_state);
