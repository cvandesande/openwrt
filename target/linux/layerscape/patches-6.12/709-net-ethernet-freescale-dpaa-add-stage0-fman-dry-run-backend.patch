diff --git a/drivers/net/ethernet/freescale/fman/fman_port.c b/drivers/net/ethernet/freescale/fman/fman_port.c
@@ -1708,12 +1708,32 @@
 int fman_port_get_offload_info(struct fman_port *port,
 			       struct fman_port_offload_info *info)
 {
+	struct fman_keygen_state kg_state;
+	bool kg_api_available;
+	int err;
+
 	if (!port || !info)
 		return -EINVAL;
 
+	memset(info, 0, sizeof(*info));
 	info->port_id = port->port_id;
 	info->kg_hash_enabled = port->kg_hash_enabled;
 
+	kg_api_available = port->port_type == FMAN_PORT_TYPE_RX &&
+			   port->dts_params.fman &&
+			   port->dts_params.fman->keygen;
+	if (!kg_api_available)
+		return 0;
+
+	err = keygen_get_state(port->dts_params.fman->keygen, &kg_state);
+	if (err)
+		return err;
+
+	info->kg_scheme_api_available = true;
+	info->kg_scheme_total = kg_state.scheme_total;
+	info->kg_scheme_in_use = kg_state.scheme_in_use;
+	info->kg_scheme_free = kg_state.scheme_total - kg_state.scheme_in_use;
+
 	return 0;
 }
 EXPORT_SYMBOL(fman_port_get_offload_info);
