+struct dpaa_ft_hw_result {
+	enum dpaa_ft_hw_backend_state state;
+	enum dpaa_ft_hw_dry_run_result dry_run;
+	enum dpaa_ft_hw_degrade_reason degrade;
+	enum dpaa_ft_reject_reason reject_reason;
+	int err;
+	const char *message;
+};
+
+struct dpaa_ft_hw_backend_ops {
+	void (*prepare)(struct dpaa_priv *priv);
+	int (*dry_run)(struct dpaa_priv *priv,
+		       const struct dpaa_ft_entry *entry,
+		       struct dpaa_ft_hw_result *result);
+	int (*install)(struct dpaa_priv *priv, struct dpaa_ft_entry *entry);
+	int (*remove)(struct dpaa_priv *priv, struct dpaa_ft_entry *entry);
+	int (*stats)(struct dpaa_priv *priv, struct dpaa_ft_entry *entry);
+};
+
+static const char *dpaa_ft_fman_hw_disabled_reason(const struct dpaa_priv *priv)
+{
+	if (!priv->fman.ports_bound)
+		return "hardware flow offloading requested, but the FMAN backend is disabled because FMAN port state is unavailable; flows stay on the normal Linux path";
+
+	if (!priv->fman.rx.kg_hash_enabled)
+		return "hardware flow offloading requested, but the FMAN backend is disabled because RX KeyGen hashing is off; flows stay on the normal Linux path";
+
+	if (!priv->fman.rx.kg_scheme_api_available)
+		return "hardware flow offloading requested, but the FMAN backend is disabled because the RX KeyGen scheme API is unavailable; flows stay on the normal Linux path";
+
+	if (!priv->fman.rx_pcd_fq_count)
+		return "hardware flow offloading requested, but the FMAN backend is disabled because the RX PCD queue span is unavailable; flows stay on the normal Linux path";
+
+	return "hardware flow offloading requested, but the FMAN backend is disabled because backend prerequisites are incomplete; flows stay on the normal Linux path";
+}
+
+static void dpaa_ft_hw_reset_observation(struct dpaa_ft_hw_backend *hw)
+{
+	hw->last_dry_run = DPAA_FT_HW_DRY_RUN_NONE;
+	hw->last_degrade = DPAA_FT_HW_DEGRADE_NONE;
+	hw->last_error = 0;
+	hw->res.rx_port = NULL;
+	hw->res.tx_port = NULL;
+	hw->res.rx_bound = false;
+	hw->res.tx_bound = false;
+	hw->res.keygen_api_available = false;
+	hw->res.dry_run_scheme_allocated = false;
+	hw->res.dry_run_scheme_id = 0;
+}
+
+static void dpaa_ft_hw_note_degrade(struct dpaa_priv *priv,
+				    enum dpaa_ft_hw_degrade_reason reason,
+				    const char *message)
+{
+	struct dpaa_ft_hw_backend *hw = &priv->ft.hw;
+
+	if (reason <= DPAA_FT_HW_DEGRADE_NONE ||
+	    reason >= DPAA_FT_HW_DEGRADE_MAX)
+		return;
+
+	hw->degrade_events[reason]++;
+	if (hw->last_degrade == reason)
+		return;
+
+	hw->last_degrade = reason;
+	if (message)
+		net_warn_ratelimited("%s: %s\n", netdev_name(priv->net_dev),
+				     message);
+}
+
+static void dpaa_ft_fman_hw_prepare(struct dpaa_priv *priv)
+{
+	struct dpaa_ft_hw_backend *hw = &priv->ft.hw;
+
+	dpaa_ft_hw_reset_observation(hw);
+	hw->state = DPAA_FT_HW_BACKEND_NOT_IMPLEMENTED;
+
+	if (!priv->mac_dev)
+		return;
+
+	hw->res.rx_port = priv->mac_dev->port[RX];
+	hw->res.tx_port = priv->mac_dev->port[TX];
+	hw->res.rx_bound = !!hw->res.rx_port;
+	hw->res.tx_bound = !!hw->res.tx_port;
+	hw->res.keygen_api_available = priv->fman.rx.kg_scheme_api_available;
+
+	if (!hw->res.rx_bound || !hw->res.tx_bound ||
+	    !priv->fman.ports_bound || !priv->fman.rx.kg_hash_enabled ||
+	    !priv->fman.rx.kg_scheme_api_available ||
+	    !priv->fman.rx_pcd_fq_count) {
+		hw->state = DPAA_FT_HW_BACKEND_DISABLED;
+		hw->last_error = -EOPNOTSUPP;
+		return;
+	}
+
+	hw->state = DPAA_FT_HW_BACKEND_READY;
+}
+
+static bool
+dpaa_ft_fman_hw_is_stage0_lowerable(struct dpaa_priv *priv,
+				    const struct dpaa_ft_entry *entry,
+				    const char **reason)
+{
+	if (entry->tuple.is_ipv6) {
+		*reason = "hardware flow offloading requested, but the FMAN backend dry-run only covers exact outbound IPv4 flows for now; flows stay on the normal Linux path";
+		return false;
+	}
+
+	if (entry->tuple.ingress_ifindex != priv->net_dev->ifindex) {
+		*reason = "hardware flow offloading requested, but the FMAN backend dry-run only covers direct lower-device ingress for now; flows stay on the normal Linux path";
+		return false;
+	}
+
+	if (entry->ingress.vlan_match.present || entry->ingress.vlan_pop ||
+	    entry->ingress.pppoe_decap) {
+		*reason = "hardware flow offloading requested, but the FMAN backend dry-run does not cover reply-half or recovered ingress recipes yet; flows stay on the normal Linux path";
+		return false;
+	}
+
+	if (!entry->egress.out_dev || entry->egress.out_dev->type != ARPHRD_ETHER) {
+		*reason = "hardware flow offloading requested, but the FMAN backend dry-run requires exact Ethernet redirect; flows stay on the normal Linux path";
+		return false;
+	}
+
+	if (entry->egress.nat.type != DPAA_FT_NAT_SNAT ||
+	    !entry->egress.nat.addr_valid) {
+		*reason = "hardware flow offloading requested, but the FMAN backend dry-run requires exact IPv4 SNAT; flows stay on the normal Linux path";
+		return false;
+	}
+
+	if (!dpaa_ft_egress_recipe_supports_outbound_encap(entry)) {
+		*reason = "hardware flow offloading requested, but the FMAN backend dry-run requires exact VLAN and PPPoE outbound encapsulation; flows stay on the normal Linux path";
+		return false;
+	}
+
+	if (!priv->fman.rx.kg_scheme_free) {
+		*reason = "hardware flow offloading requested, but the FMAN backend dry-run found no free RX KeyGen scheme slots; flows stay on the normal Linux path";
+		return false;
+	}
+
+	return true;
+}
+
+static int dpaa_ft_fman_hw_dry_run(struct dpaa_priv *priv,
+				   const struct dpaa_ft_entry *entry,
+				   struct dpaa_ft_hw_result *result)
+{
+	struct dpaa_ft_hw_backend *hw = &priv->ft.hw;
+	const char *reason = NULL;
+
+	memset(result, 0, sizeof(*result));
+	result->state = hw->state;
+	result->err = hw->last_error;
+	hw->dry_run_attempts++;
+
+	switch (hw->state) {
+	case DPAA_FT_HW_BACKEND_NOT_IMPLEMENTED:
+		result->degrade = DPAA_FT_HW_DEGRADE_NOT_IMPLEMENTED;
+		result->reject_reason = DPAA_FT_REJECT_HW_MODE_UNAVAILABLE;
+		result->err = -EOPNOTSUPP;
+		result->message = "hardware flow offloading requested, but the FMAN backend is not implemented in this build; flows stay on the normal Linux path";
+		return result->err;
+	case DPAA_FT_HW_BACKEND_DISABLED:
+		result->degrade = DPAA_FT_HW_DEGRADE_DISABLED;
+		result->reject_reason = DPAA_FT_REJECT_HW_BACKEND_DISABLED;
+		result->err = hw->last_error ? hw->last_error : -EOPNOTSUPP;
+		result->message = dpaa_ft_fman_hw_disabled_reason(priv);
+		return result->err;
+	default:
+		break;
+	}
+
+	if (!dpaa_ft_fman_hw_is_stage0_lowerable(priv, entry, &reason)) {
+		hw->dry_run_not_lowerable++;
+		hw->last_dry_run = DPAA_FT_HW_DRY_RUN_NOT_LOWERABLE;
+		result->dry_run = DPAA_FT_HW_DRY_RUN_NOT_LOWERABLE;
+		result->degrade = DPAA_FT_HW_DEGRADE_EXACT_UNSUPPORTED;
+		result->reject_reason = DPAA_FT_REJECT_HW_NOT_LOWERABLE;
+		result->err = -EOPNOTSUPP;
+		result->message = reason;
+		return result->err;
+	}
+
+	hw->dry_run_lowerable++;
+	hw->last_dry_run = DPAA_FT_HW_DRY_RUN_LOWERABLE;
+	result->dry_run = DPAA_FT_HW_DRY_RUN_LOWERABLE;
+	result->degrade = DPAA_FT_HW_DEGRADE_DRY_RUN_ONLY;
+	result->reject_reason = DPAA_FT_REJECT_HW_DRY_RUN_ONLY;
+	result->err = -EOPNOTSUPP;
+	result->message = "hardware flow offloading requested, and the FMAN backend dry-run says this exact contract appears lowerable, but live FMAN install is not enabled yet; flows stay on the normal Linux path";
+
+	return result->err;
+}
+
+static int dpaa_ft_fman_hw_install_stub(struct dpaa_priv *priv,
+					struct dpaa_ft_entry *entry)
+{
+	priv->ft.hw.install_attempts++;
+	priv->ft.hw.state = DPAA_FT_HW_BACKEND_INSTALL_FAILED;
+	priv->ft.hw.install_failures++;
+	priv->ft.hw.last_error = -EOPNOTSUPP;
+	entry->hw.state = DPAA_FT_HW_BACKEND_INSTALL_FAILED;
+	entry->hw.last_error = -EOPNOTSUPP;
+
+	return -EOPNOTSUPP;
+}
+
+static int dpaa_ft_fman_hw_remove_stub(struct dpaa_priv *priv,
+				       struct dpaa_ft_entry *entry)
+{
+	priv->ft.hw.remove_attempts++;
+	priv->ft.hw.remove_failures++;
+	priv->ft.hw.last_error = -EOPNOTSUPP;
+	entry->hw.last_error = -EOPNOTSUPP;
+
+	return -EOPNOTSUPP;
+}
+
+static int dpaa_ft_fman_hw_stats_stub(struct dpaa_priv *priv,
+				      struct dpaa_ft_entry *entry)
+{
+	priv->ft.hw.stats_queries++;
+	entry->hw.last_error = -EOPNOTSUPP;
+
+	return -EOPNOTSUPP;
+}
+
+static const struct dpaa_ft_hw_backend_ops dpaa_ft_fman_hw_backend_ops = {
+	.prepare = dpaa_ft_fman_hw_prepare,
+	.dry_run = dpaa_ft_fman_hw_dry_run,
+	.install = dpaa_ft_fman_hw_install_stub,
+	.remove = dpaa_ft_fman_hw_remove_stub,
+	.stats = dpaa_ft_fman_hw_stats_stub,
+};
+
+static const struct dpaa_ft_hw_backend_ops *
+dpaa_ft_hw_backend_ops(const struct dpaa_priv *priv)
+{
+	if (!priv->mac_dev)
+		return NULL;
+
+	return &dpaa_ft_fman_hw_backend_ops;
+}
+
+static void dpaa_ft_hw_backend_prepare(struct dpaa_priv *priv)
+{
+	const struct dpaa_ft_hw_backend_ops *ops = dpaa_ft_hw_backend_ops(priv);
+
+	dpaa_ft_hw_reset_observation(&priv->ft.hw);
+	priv->ft.hw.state = DPAA_FT_HW_BACKEND_NOT_IMPLEMENTED;
+	if (!ops)
+		return;
+
+	ops->prepare(priv);
+}
