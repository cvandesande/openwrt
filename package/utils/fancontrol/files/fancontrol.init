#!/bin/sh /etc/rc.common
# SPDX-License-Identifier: GPL-2.0-only
#
# Fan control init script for EMC2305
#
# Copyright (C) 2025 Mono Technologies Inc.

START=90
STOP=10

USE_PROCD=1

start_service() {
    # Check if EMC2305 is present
    if ! grep -q emc2305 /sys/class/hwmon/*/name 2>/dev/null; then
        echo "fancontrol: EMC2305 not detected, skipping"
        return 1
    fi
    
    procd_open_instance
    procd_set_param command /usr/sbin/fancontrol-emc2305
    procd_set_param respawn
    procd_set_param stdout 0
    procd_set_param stderr 0
    procd_close_instance
}
