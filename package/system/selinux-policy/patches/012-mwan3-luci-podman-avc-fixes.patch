diff -Naur a/src/agent/sysagent/swanmonsysagent.cil b/src/agent/sysagent/swanmonsysagent.cil
--- a/src/agent/sysagent/swanmonsysagent.cil	1970-01-01 01:00:00.000000000 +0100
+++ b/src/agent/sysagent/swanmonsysagent.cil	2026-07-20 22:40:39.935565601 +0100
@@ -0,0 +1,63 @@
+;; SPDX-FileCopyrightText: © 2026 Mono OpenWrt <mono-openwrt@local>
+;; SPDX-License-Identifier: Unlicense
+
+;; swanmon serialises strongSwan's VICI output to JSON for LuCI's
+;; luci-app-strongswan-swanctl status page, which execs it through cgi-exec.
+;; cgi-exec IS confined, so without a label on the executable the binary stays
+;; generic exec.file, cgiio cannot getattr or execute it, and the IPsec status
+;; page fails under enforcing.
+;;
+;; charon itself is left unconfined; only its VICI socket is typed, following
+;; the pattern patch 012 already uses for mwan3's runtime state. That is enough
+;; to let swanmon connect to the socket without granting it access to every
+;; other runtime socket on the system, and mirrors refpolicy's split of
+;; ipsec_var_run_t from the ipsec_mgmt_t management domain.
+
+(block strongswan
+
+  (block runtmp
+
+    ;; charon recreates this on every boot (/tmp is tmpfs), so it picks up the
+    ;; type from the transition below rather than needing a relabel
+    (filecon "/tmp/run/charon\.vici" socket file_context)
+
+    (macro unix_stream_connect ((type ARG1))
+	   (call write_file_sock_files (ARG1))
+	   (call search_file_dirs (ARG1)))
+
+    (macro runtmp_file_type_transition_file ((type ARG1)(name ARG2))
+	   (call .runtmp.file_type_transition
+		 (ARG1 file sock_file ARG2)))
+
+    (blockinherit .file.macro_template_dirs)
+    (blockinherit .file.macro_template_sock_files)
+    (blockinherit .file.tmp.run.base_template)))
+
+(block swanmon
+
+  (blockinherit .sys.agent.template)
+
+  (allow subj self create_unix_stream_stream_socket)
+
+  ;; the VICI client connection
+  (allow subj .strongswan.runtmp.file (unix_stream_socket (connectto)))
+
+  (call .strongswan.runtmp.unix_stream_connect (subj))
+
+  (call .locales.client.type (subj)))
+
+(in file.unconfined
+
+    (call .strongswan.runtmp.runtmp_file_type_transition_file
+	  (typeattr "charon.vici"))
+
+    (call .swanmon.exec.exec_file_type_transition_file (typeattr)))
+
+(in after swanmon.exec
+
+    ;; file_contexts.subs_dist maps /usr/sbin -> /usr/bin
+    (filecon "/usr/bin/swanmon" file file_context)
+
+    (macro exec_file_type_transition_file ((type ARG1))
+	   (call .exec.file_type_transition
+		 (ARG1 file file "swanmon"))))
