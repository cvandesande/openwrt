diff -Naur a/src/agent/sysagent/mwan3sysagent.cil b/src/agent/sysagent/mwan3sysagent.cil
--- a/src/agent/sysagent/mwan3sysagent.cil	1970-01-01 01:00:00.000000000 +0100
+++ b/src/agent/sysagent/mwan3sysagent.cil	2026-07-20 22:36:26.276706749 +0100
@@ -0,0 +1,76 @@
+;; SPDX-FileCopyrightText: © 2026 Mono OpenWrt <mono-openwrt@local>
+;; SPDX-License-Identifier: Unlicense
+
+;; mwan3 keeps runtime state under /tmp/run/mwan3 (policy marks/masks) and
+;; /tmp/run/mwan3track (per-interface tracker state). Scoping the state lets
+;; confined readers (hotplug-call, rpcd) be granted read access without
+;; opening up generic runtmp.
+;;
+;; /usr/sbin/mwan3 is a /bin/sh script, so this domain follows the
+;; boarddetect/hotplug-call pattern for script agents: shell.client for the
+;; interpreter, functions/libubox for the sourced shell libraries, and a
+;; subj_type_transition for each helper it spawns so they run confined in
+;; their own domains rather than inheriting this one.
+;;
+;; Needed because LuCI's mwan3 status pages exec it through cgi-exec, which
+;; IS confined: without a label on the executable the binary stays generic
+;; exec.file, cgiio cannot even getattr it, and every mwan3 page fails.
+
+(block mwan3
+
+  (blockinherit .sys.agent.template)
+
+  (call .functions.client.type (subj))
+
+  (call .libubox.data.list_file_dirs (subj))
+  (call .libubox.data.read_file_files (subj))
+
+  (call .shell.client.type (subj))
+
+  ;; helpers: ubus/uci for config, jsonfilter for parsing, ip for the policy
+  ;; routing tables, iptables-nft/ipset for the marking rules
+  (call .iproute2.ip.subj_type_transition (subj))
+  (call .jsonfilter.subj_type_transition (subj))
+  (call .ubus.subj_type_transition (subj))
+  (call .uci.subj_type_transition (subj))
+  (call .xtables.subj_type_transition (subj))
+
+  ;; its own runtime state (mmx_mask and friends)
+  (call runtmp.list_file_dirs (subj))
+  (call runtmp.manage_file_files (subj))
+  (call runtmp.readwrite_file_dirs (subj))
+
+  (call .tmp.deletename_fs_dirs (subj))
+
+  (block runtmp
+
+    (filecon "/tmp/run/mwan3" dir file_context)
+    (filecon "/tmp/run/mwan3/.*" any file_context)
+
+    (filecon "/tmp/run/mwan3track" dir file_context)
+    (filecon "/tmp/run/mwan3track/.*" any file_context)
+
+    (macro runtmp_file_type_transition_file ((type ARG1))
+	   (call .runtmp.file_type_transition
+		 (ARG1 file dir "mwan3"))
+	   (call .runtmp.file_type_transition
+		 (ARG1 file dir "mwan3track")))
+
+    (blockinherit .file.macro_template_dirs)
+    (blockinherit .file.macro_template_files)
+    (blockinherit .file.tmp.run.base_template)))
+
+(in file.unconfined
+
+    (call .mwan3.exec.exec_file_type_transition_file (typeattr))
+    (call .mwan3.runtmp.runtmp_file_type_transition_file (typeattr)))
+
+(in after mwan3.exec
+
+    ;; file_contexts.subs_dist maps /usr/sbin -> /usr/bin, so the on-disk
+    ;; /usr/sbin/mwan3 must be written as /usr/bin/mwan3 here
+    (filecon "/usr/bin/mwan3" file file_context)
+
+    (macro exec_file_type_transition_file ((type ARG1))
+	   (call .exec.file_type_transition
+		 (ARG1 file file "mwan3"))))
