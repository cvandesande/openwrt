--- /dev/null
+++ b/src/file/conffile/sensorsconffile.cil
@@ -0,0 +1,26 @@
+;; SPDX-FileCopyrightText: © 2025 Dominick Grift <dominick.grift@defensec.nl>
+;; SPDX-License-Identifier: Unlicense
+
+(in file.unconfined
+
+    (call .sensors.conf.conf_file_type_transition_file (typeattr)))
+
+(block sensors
+
+    (block conf
+
+      (filecon "/etc/sensors3\.conf" file file_context)
+      (filecon "/etc/sensors3\.conf\..*" file file_context)
+
+      (filecon "/etc/sensors\.conf" file file_context)
+      (filecon "/etc/sensors\.conf\..*" file file_context)
+
+      (filecon "/etc/sensors\.d" dir file_context)
+      (filecon "/etc/sensors\.d/.*" any file_context)
+
+      (macro conf_file_type_transition_file ((type ARG1))
+	     (call .conf.file_type_transition (ARG1 file dir "sensors.d"))
+	     (call .conf.file_type_transition (ARG1 file file "sensors.conf"))
+	     (call .conf.file_type_transition (ARG1 file file "sensors3.conf")))
+
+      (blockinherit .file.conf.template)))
