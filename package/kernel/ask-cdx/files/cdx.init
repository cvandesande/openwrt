START=18
STOP=90

start() {
	insmod cdx
}

stop() {
	if [ "${CDX_UNSAFE_UNLOAD:-0}" != "1" ]; then
		echo "Refusing to unload cdx: CEETM teardown is incomplete and normal unload can leak hardware resources. Set CDX_UNSAFE_UNLOAD=1 only for debug recovery."
		return 1
	fi

	rmmod cdx
}
