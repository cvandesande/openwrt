+int dpa_get_lan_tx_channel_wq(uint32_t wan_itf_id,
+		uint32_t *channel, uint32_t *wq,
+		uint8_t *mac_addr, struct net_device **net_dev)
+{
+	struct dpa_iface_info *iface_info;
+	struct dpa_iface_info *fallback = NULL;
+	struct dpa_iface_info *selected = NULL;
+	struct net_device *dev;
+
+	iface_info = dpa_interface_info;
+	while (iface_info) {
+		if ((iface_info->if_flags & IF_TYPE_ETHERNET) &&
+		    iface_info->itf_id != wan_itf_id) {
+			dev = iface_info->eth_info.net_dev;
+			if (!dev) {
+				iface_info = iface_info->next;
+				continue;
+			}
+
+			/* Keep the first non-WAN ethernet as fallback, but prefer
+			 * an operational interface to avoid binding to DOWN ports
+			 * (seen as lan_dev=eth4 in live failure runs). */
+			if (!fallback)
+				fallback = iface_info;
+
+			if (!(dev->flags & IFF_UP) || !netif_carrier_ok(dev)) {
+				iface_info = iface_info->next;
+				continue;
+			}
+
+			selected = iface_info;
+			break;
+		}
+		iface_info = iface_info->next;
+	}
+
+	if (!selected)
+		selected = fallback;
+	if (!selected)
+		return -ENODEV;
+
+	*channel = selected->eth_info.tx_channel_id;
+	*wq = selected->eth_info.tx_wq;
+	memcpy(mac_addr, selected->eth_info.mac_addr, ETH_ALEN);
+	*net_dev = selected->eth_info.net_dev;
+	return 0;
+}
+
+int dpa_get_lan_compat_tx_info(uint32_t wan_itf_id,
+		uint32_t *channel, uint32_t *wq,
+		uint8_t *l2_tmpl, uint8_t *l2_len,
+		struct net_device **net_dev)
+{
+	struct dpa_iface_info *iface_info;
+	struct dpa_iface_info *eth_fallback = NULL;
+	struct dpa_iface_info *eth_selected = NULL;
+	struct dpa_iface_info *vlan_selected = NULL;
+	struct dpa_iface_info *parent;
+	struct net_device *dev;
+	uint8_t *src_mac;
+	uint16_t tci;
+
+	if (!channel || !wq || !l2_tmpl || !l2_len || !net_dev)
+		return -EINVAL;
+
+	iface_info = dpa_interface_info;
+	while (iface_info) {
+		if (iface_info->if_flags & IF_TYPE_VLAN) {
+			parent = iface_info->vlan_info.parent;
+			if (!parent || !(parent->if_flags & IF_TYPE_ETHERNET)) {
+				iface_info = iface_info->next;
+				continue;
+			}
+			if (parent->itf_id == wan_itf_id) {
+				iface_info = iface_info->next;
+				continue;
+			}
+			dev = parent->eth_info.net_dev;
+			if (!dev) {
+				iface_info = iface_info->next;
+				continue;
+			}
+			if (!(dev->flags & IFF_UP) || !netif_carrier_ok(dev)) {
+				iface_info = iface_info->next;
+				continue;
+			}
+			/* Prefer bridged VLAN interfaces so source MAC matches
+			 * bridge domain and wire format keeps required VLAN tag. */
+			if (!vlan_selected ||
+			    (iface_info->vlan_info.is_bridged &&
+			     !vlan_selected->vlan_info.is_bridged))
+				vlan_selected = iface_info;
+		} else if ((iface_info->if_flags & IF_TYPE_ETHERNET) &&
+			   iface_info->itf_id != wan_itf_id) {
+			dev = iface_info->eth_info.net_dev;
+			if (!dev) {
+				iface_info = iface_info->next;
+				continue;
+			}
+			if (!eth_fallback)
+				eth_fallback = iface_info;
+			if (!(dev->flags & IFF_UP) || !netif_carrier_ok(dev)) {
+				iface_info = iface_info->next;
+				continue;
+			}
+			if (!eth_selected)
+				eth_selected = iface_info;
+		}
+		iface_info = iface_info->next;
+	}
+
+	if (vlan_selected) {
+		parent = vlan_selected->vlan_info.parent;
+		*channel = parent->eth_info.tx_channel_id;
+		*wq = parent->eth_info.tx_wq;
+		*net_dev = parent->eth_info.net_dev;
+
+		memset(l2_tmpl, 0, 18);
+		if (vlan_selected->vlan_info.is_bridged)
+			src_mac = vlan_selected->vlan_info.br_mac_addr;
+		else
+			src_mac = vlan_selected->vlan_info.mac_addr;
+		memcpy(l2_tmpl + ETH_ALEN, src_mac, ETH_ALEN);
+		l2_tmpl[12] = 0x81;
+		l2_tmpl[13] = 0x00;
+		tci = vlan_selected->vlan_info.vlan_id;
+		l2_tmpl[14] = (uint8_t)((tci >> 8) & 0xff);
+		l2_tmpl[15] = (uint8_t)(tci & 0xff);
+		l2_tmpl[16] = 0x08;
+		l2_tmpl[17] = 0x00;
+		*l2_len = 18;
+		return 0;
+	}
+
+	if (!eth_selected)
+		eth_selected = eth_fallback;
+	if (!eth_selected)
+		return -ENODEV;
+
+	*channel = eth_selected->eth_info.tx_channel_id;
+	*wq = eth_selected->eth_info.tx_wq;
+	*net_dev = eth_selected->eth_info.net_dev;
+	memset(l2_tmpl, 0, 14);
+	memcpy(l2_tmpl + ETH_ALEN, eth_selected->eth_info.mac_addr, ETH_ALEN);
+	l2_tmpl[12] = 0x08;
+	l2_tmpl[13] = 0x00;
+	*l2_len = 14;
+	return 0;
+}
