+int dpa_get_out_tx_channel_wq_by_itf_id(PRouteEntry rt_entry,
+		uint32_t *channel, uint32_t *wq)
+{
+	struct dpa_iface_info *iface_info;
+	struct eth_iface_info *eth_info;
+	int retval = FAILURE;
+
+	if (!rt_entry || !channel || !wq) {
+		DPA_ERROR("%s::NULL parameter\n", __FUNCTION__);
+		return retval;
+	}
+
+	spin_lock(&dpa_devlist_lock);
+	iface_info = dpa_get_ifinfo_by_itfid(rt_entry->itf->index);
+	iface_info = dpa_get_phys_iface(iface_info);
+	if (!iface_info || !(iface_info->if_flags & IF_TYPE_ETHERNET))
+		goto out;
+
+	eth_info = &iface_info->eth_info;
+	*channel = eth_info->tx_channel_id;
+	*wq = eth_info->tx_wq;
+	retval = SUCCESS;
+out:
+	spin_unlock(&dpa_devlist_lock);
+	if (retval != SUCCESS)
+		DPA_ERROR("%s::unable to resolve tx channel/wq\n", __FUNCTION__);
+
+	return retval;
+}
