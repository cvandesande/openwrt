+	sed '/^[[:space:]]*delete flowtable inet fw4 ft[[:space:]]*$/d' "$1" >"$2"
+}
+
+recreate_ruleset_file() {
+	local recreate rc
+
+	recreate="$(mktemp)" || return 1
+	prepare_recreate_ruleset_file "$1" "$recreate"
+	nft delete table inet fw4 2>/dev/null || true
+	apply_ruleset_file "$recreate" "$2"
+	rc=$?
