+print_nft_errors() {
+	[ -n "$QUIET" ] || cat "$1" >&2
+}
+
+render_ruleset() {
+	ACTION=start \
+		utpl -S $MAIN >"$1"
+}
+
+run_includes() {
+	ACTION=includes \
+		utpl -S $MAIN
+}
+
+flowtable_switch_error() {
+	grep -q 'Could not process rule: Resource busy' "$1" &&
+	grep -q 'flowtable ft' "$1"
+}
+
+apply_ruleset_file() {
+	nft $VERBOSE -f "$1" 2>"$2"
+}
+
+check_ruleset_file() {
+	nft $VERBOSE -c -f "$1" 2>"$2"
+}
+
+recreate_ruleset_file() {
+	nft delete table inet fw4 2>/dev/null || true
+	apply_ruleset_file "$1" "$2"
+}
