+	grep -q 'flowtable ft' "$1"
+}
+
+extract_flowtable_devices() {
+	sed -n 's/.*devices[[:space:]]*=[[:space:]]*{[[:space:]]*\(.*\)[[:space:]]*}.*/\1/p' |
+		tr ',' '\n' |
+		tr -d '"' |
+		sed 's/^[[:space:]]*//;s/[[:space:]]*$//' |
+		sed '/^$/d'
+}
+
+sorted_device_set() {
+	LC_ALL=C sort -u | tr '\n' ' ' | sed 's/[[:space:]]*$//'
+}
+
+live_flowtable_device_set() {
+	nft list table inet fw4 2>/dev/null |
+		sed -n '/^[[:space:]]*flowtable[[:space:]]\+ft[[:space:]]*{/,/^[[:space:]]*}[[:space:]]*$/p' |
+		extract_flowtable_devices |
+		sorted_device_set
+}
+
+rendered_flowtable_device_set() {
+	sed -n '/^[[:space:]]*flowtable[[:space:]]\+ft[[:space:]]*{/,/^[[:space:]]*}[[:space:]]*$/p' "$1" |
+		extract_flowtable_devices |
+		sorted_device_set
+}
+
+flowtable_device_set_changed() {
+	local live_set rendered_set
+
+	live_set="$(live_flowtable_device_set)"
+	rendered_set="$(rendered_flowtable_device_set "$1")"
+
+	[ -n "$live_set" ] &&
+	[ -n "$rendered_set" ] &&
+	[ "$live_set" != "$rendered_set" ]
+}
+
+apply_ruleset_file() {
+	nft $VERBOSE -f "$1" 2>"$2"
