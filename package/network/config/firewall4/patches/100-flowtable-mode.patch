+normalize_bool() {
+	case "$1" in
+	1|on|true|yes)
+		echo 1
+		return 0
+	;;
+	esac
+
+	echo 0
+}
+
+state_default_bool() {
+	[ -f /var/run/fw4.state ] || return 1
+	jsonfilter -s "$(cat /var/run/fw4.state 2>/dev/null)" -e "@.defaults.$1" 2>/dev/null
+}
+
+flow_control_mode_changed() {
+	[ -f /var/run/fw4.state ] || return 0
+
+	current_flow_offloading="$(normalize_bool "$(uci -q get firewall.@defaults[0].flow_offloading)")"
+	current_flow_offloading_hw="$(normalize_bool "$(uci -q get firewall.@defaults[0].flow_offloading_hw)")"
+	current_lower_device_flowtable="$(normalize_bool "$(uci -q get firewall.@defaults[0].lower_device_flowtable)")"
+
+	loaded_flow_offloading="$(normalize_bool "$(state_default_bool flow_offloading)")"
+	loaded_flow_offloading_hw="$(normalize_bool "$(state_default_bool flow_offloading_hw)")"
+	loaded_lower_device_flowtable="$(normalize_bool "$(state_default_bool lower_device_flowtable)")"
+
+	[ "$current_flow_offloading" != "$loaded_flow_offloading" ] ||
+	[ "$current_flow_offloading_hw" != "$loaded_flow_offloading_hw" ] ||
+	[ "$current_lower_device_flowtable" != "$loaded_lower_device_flowtable" ]
+}
+
 service_triggers() {
 	procd_add_reload_trigger firewall
 	procd_add_reload_data_trigger firewall
@@ -22,6 +54,12 @@ stop_service() {
 }
 
 reload_service() {
+	if flow_control_mode_changed; then
+		logger -t firewall "Restarting firewall due to flow control mode change"
+		fw4 restart
+		return $?
+	fi
+
 	fw4 reload
 }
 
