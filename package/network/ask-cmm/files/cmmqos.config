# CMM hardware egress (TX/upload) port shaper configuration.
# Select a physical CMM/QM port only; PPPoE and VLAN devices are not valid.
# This initial single-port implementation owns CMM CLI channel 1.
config shaper 'wan'
	option enabled '0'
	option device 'eth4'
	option rate '107000'
	option bucketsize '8192'
