<cfgdata>
<config>
  <!-- Mono Gateway DK port configuration -->
  <engine name="fm0">
    <!-- 1G Ethernet ports -->
    <port type="1G" number="1" policy="cdx_ethport_1_policy" portid="1"/>
    <port type="1G" number="4" policy="cdx_ethport_4_policy" portid="4"/>
    <port type="1G" number="5" policy="cdx_ethport_5_policy" portid="5"/>
    <!-- Stage 2 is exact-scope to the wired first class. Keep the unvalidated
         10G ports out of the FMC bootstrap until their own milestone. -->
    <!-- OFFLINE ports for CDX -->
    <!-- number="1" -> dpa-fman0-oh@2 (IPsec), number="2" -> dpa-fman0-oh@3 (WiFi) -->
    <!-- Keep offline logical port IDs in the vendor >=9 range expected by the
         soft parser rules, even though WiFi/IPsec remain deferred here. -->
    <port type="OFFLINE" number="1" policy="cdx_port_of2_policy" portid="9"/>
    <port type="OFFLINE" number="2" policy="cdx_port_of3_policy" portid="10"/>
  </engine>
</config>
</cfgdata>
