<cfgdata>
<config>
  <!-- Mono Gateway DK port configuration -->
  <engine name="fm0">
    <!-- 1G Ethernet ports -->
    <port type="1G" number="1" policy="cdx_ethport_1_policy" portid="1"/>
    <port type="1G" number="4" policy="cdx_ethport_4_policy" portid="4"/>
    <port type="1G" number="5" policy="cdx_ethport_5_policy" portid="5"/>
    <!-- 10G/SFP+ ports. This board's single qoriq-fman3-0 FMan has a hard
         CDX_CTRL_MAX_PORTS_PER_FMAN = 5 port-count ceiling, so both OFFLINE
         OH ports (IPsec, WiFi) had to be dropped to fit 3x1G + 2x10G. -->
    <port type="10G" number="0" policy="cdx_ethport_6_policy" portid="6"/>
    <port type="10G" number="1" policy="cdx_ethport_7_policy" portid="7"/>
  </engine>
</config>
</cfgdata>
