#!/bin/sh
# Wrapper script for dpa_app. Set ASK_DPA_APP_DEBUG=1 to capture debug logs.
LOG=/tmp/dpa_app.log
CFG_DIR=/usr/share/ask-dpa-app

case "$ASK_DPA_APP_DEBUG" in
1|yes|true|on)
	;;
*)
	exec /usr/bin/dpa_app "$@"
	;;
esac

echo "=== dpa_app wrapper started at $(date) ===" >> "$LOG"
echo "Args: $@" >> "$LOG"
echo "PWD: $(pwd)" >> "$LOG"
echo "LD_LIBRARY_PATH: $LD_LIBRARY_PATH" >> "$LOG"
if [ -f "$CFG_DIR/cdx_cfg.xml" ]; then
	echo "Bootstrap ports from $CFG_DIR/cdx_cfg.xml:" >> "$LOG"
	grep "<port " "$CFG_DIR/cdx_cfg.xml" >> "$LOG" 2>&1
fi
if [ -e /etc/cdx_cfg.xml ]; then
	echo "Legacy /etc/cdx_cfg.xml present but ignored:" >> "$LOG"
	ls -l /etc/cdx_cfg.xml >> "$LOG" 2>&1
fi
echo "Environment:" >> "$LOG"
env >> "$LOG" 2>&1
echo "=== Running dpa_app ===" >> "$LOG"

if [ -x /usr/bin/strace ]; then
	/usr/bin/strace -f -o /tmp/dpa_app_strace.log /usr/bin/dpa_app "$@" >> "$LOG" 2>&1
	RC=$?
else
	/usr/bin/dpa_app "$@" >> "$LOG" 2>&1
	RC=$?
fi

echo "=== dpa_app exited with code $RC ===" >> "$LOG"
exit $RC
