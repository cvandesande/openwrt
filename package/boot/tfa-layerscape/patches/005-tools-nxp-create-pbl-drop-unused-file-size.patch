From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Mono Build <build@mono.local>
Date: Wed, 6 May 2026 18:00:00 +0100
Subject: [PATCH] tools/nxp: create_pbl: drop unused file_size

Newer host compilers warn that file_size is set but not used in
add_cpy_cmd(). The create_pbl host tool is built with -Werror, so this
warning breaks host builds even though the loop is already driven by
fread()/feof().

Drop the dead variable and assignments.
---
 tools/nxp/create_pbl/create_pbl.c | 3 ---
 1 file changed, 3 deletions(-)

--- a/tools/nxp/create_pbl/create_pbl.c
+++ b/tools/nxp/create_pbl/create_pbl.c
@@ -613,7 +613,6 @@ int add_cpy_cmd(FILE *fp_rcw_pbi_op)
 	uint32_t ALTCBAR_ADDRESS = BYTE_SWAP_32(0x09570158);
 	uint32_t WAIT_CMD_WRITE_ADDRESS = BYTE_SWAP_32(0x096100c0);
 	uint32_t WAIT_CMD = BYTE_SWAP_32(0x000FFFFF);
-	int file_size;
 	uint32_t pbi_cmd, altcbar;
 	uint8_t pbi_data[MAX_PBI_DATA_LEN_BYTE];
 	uint32_t dst_offset;
@@ -628,7 +627,6 @@ int add_cpy_cmd(FILE *fp_rcw_pbi_op)
 		      pblimg.sec_imgnm);
 		goto add_cpy_err;
 	}
-	file_size = get_filesize(pblimg.sec_imgnm);
 	altcbar = 0xfff00000 & altcbar;
 	altcbar = BYTE_SWAP_32(altcbar >> 16);
 	if (fwrite(&ALTCBAR_ADDRESS, sizeof(ALTCBAR_ADDRESS), NUM_MEM_BLOCK,
@@ -679,7 +677,6 @@ int add_cpy_cmd(FILE *fp_rcw_pbi_op)
 			goto add_cpy_err;
 		}
 		dst_offset += MAX_PBI_DATA_LEN_BYTE;
-		file_size -= MAX_PBI_DATA_LEN_BYTE;
 	} while (!feof(fp_img));
 
 	ret = SUCCESS;
